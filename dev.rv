// raven-web dev server and live reload. Kept in a separate module so a project
// that only generates static output does not pull in the HTTP and filesystem
// machinery. Import from "github.com/martian56/raven-web/dev".
//
// The live-reload client is part of raven-web's owned runtime: the author never
// writes JavaScript for it either.

import std/http { Server, Request, Response }
import std/fs { create_dir_all, read, walk, exists, is_file, join, dirname }
import std/time { now_millis, sleep_millis }
import std/io { println }
import std/env { args, exit, os_name }
import std/process { Output, run }

// Shared reload state. The watcher bumps the token and records the last build
// error; the reload endpoint serves both; the injected client reloads on a new
// token and shows the error as an overlay while one exists. A plain struct is
// enough for a dev tool: a missed tick only delays one reload.
struct Reloader {
    token: Int,
    error: String,
}

fun reloader() -> Reloader {
    return Reloader { token: 0, error: "" }
}

// What the reload endpoint serves: the token, a newline, then the current
// build error (empty when the last build was good).
fun status_body(state: Reloader) -> String {
    return state.token.to_string().concat("\n").concat(state.error)
}

// The live-reload client. Polls `endpoint` once a second; reloads when the
// token changes, and shows or clears a build-error overlay. The error text
// reaches the DOM through textContent only. Written without backslash
// literals, double quotes, or template literals, like the rest of the owned
// runtime.
fun _reload_client(endpoint: String) -> String {
    let out = "(function(){'use strict';var last=null;var nl=String.fromCharCode(10);"
    out = out.concat(
        "function clear(){var el=document.getElementById('__rw_overlay');if(el&&el.parentNode){el.parentNode.removeChild(el);}}",
    )
    out = out.concat("function show(msg){var el=document.getElementById('__rw_overlay');")
    out = out.concat("if(!el){el=document.createElement('div');el.id='__rw_overlay';")
    out = out.concat(
        "el.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;z-index:2147483647;background:rgba(12,12,16,0.96);color:#f4f4f5;overflow:auto;padding:2rem;font-family:ui-monospace,Consolas,monospace;';",
    )
    out = out.concat(
        "var h=document.createElement('div');h.textContent='raven-web: build failed';h.style.cssText='font-weight:700;margin-bottom:1rem;color:#fda4af;';",
    )
    out = out.concat(
        "var p=document.createElement('pre');p.id='__rw_overlay_text';p.style.cssText='white-space:pre-wrap;margin:0;font-size:0.9rem;line-height:1.5;';",
    )
    out = out.concat("el.appendChild(h);el.appendChild(p);document.body.appendChild(el);}")
    out = out.concat("document.getElementById('__rw_overlay_text').textContent=msg;}")
    out = out.concat("function poll(){fetch('").concat(endpoint).concat(
        "',{cache:'no-store'}).then(function(r){return r.text();})",
    )
    out = out.concat(".then(function(t){var i=t.indexOf(nl);var tok=i<0?t:t.substring(0,i);")
    out = out.concat("var err=i<0?'':t.substring(i+1);if(err===''){clear();}else{show(err);}")
    out = out.concat(
        "if(last===null){last=tok;}else if(err===''&&tok!==last){location.reload();}})",
    )
    out = out.concat(".catch(function(){});}")
    return out.concat("setInterval(poll,1000);poll();})();")
}

// Insert the reload client before </body>, or append it if there is no body tag.
fun inject_reload(html: String, endpoint: String) -> String {
    let script = "<script>".concat(_reload_client(endpoint)).concat("</script>")
    if html.contains("</body>") {
        return html.replace("</body>", script.concat("</body>"))
    }
    return html.concat(script)
}

// Map a request path to a safe file path under `dir`. Rejects any path that
// tries to escape the directory, and maps directory-style paths to index.html.
fun resolve_path(dir: String, url_path: String) -> Option<String> {
    if url_path.contains("..") {
        return None
    }
    let rel = url_path
    while rel.starts_with("/") {
        rel = rel.substring(1, rel.length())
    }
    if rel == "" {
        return Some(join(dir, "index.html"))
    }
    if rel.ends_with("/") {
        return Some(join(dir, rel.concat("index.html")))
    }
    return Some(join(dir, rel))
}

fun _is_html(path: String) -> Bool {
    return path.ends_with(".html") || path.ends_with(".htm")
}

// A request for a named file ("/app.js") is a miss when the file is absent. A
// request without an extension ("/tasks/5") is a path a client router may own,
// so it gets the fallback instead.
fun _names_a_file(url_path: String) -> Bool {
    let segments = url_path.split("/")
    if segments.len() == 0 {
        return false
    }
    return segments.get(segments.len() - 1).contains(".")
}

// Serve 404.html when nothing matched, which is what static hosts do: a page
// marked spa() writes the app there, so a deep link into a client route
// resolves in dev exactly as it will in production. For a non-SPA site the same
// file is the real not-found page, so this stays correct either way.
fun _fallback(dir: String, endpoint: String, url_path: String) -> Response {
    let page = join(dir, "404.html")
    if _names_a_file(url_path) || !is_file(page) {
        return Response.not_found()
    }
    return match read(page) {
        Ok(body) -> Response.html(inject_reload(body, endpoint)),
        Err(_) -> Response.not_found(),
    }
}

fun _serve_one(dir: String, endpoint: String, req: Request) -> Response {
    // The reload endpoint is served before any file lookup.
    if req.path == endpoint {
        return Response.not_found()
    }
    return match resolve_path(dir, req.path) {
        Some(path) -> {
            // Test is_file, not exists: a clean URL like /app names a directory,
            // which exists but must be served as its index.html.
            let target = if is_file(path) {
                path
            } else {
                join(path, "index.html")
            }
            if !exists(target) {
                _fallback(dir, endpoint, req.path)
            } else if _is_html(target) {
                match read(target) {
                    Ok(body) -> Response.html(inject_reload(body, endpoint)),
                    Err(_) -> Response.not_found(),
                }
            } else {
                Response.file(target)
            }
        },
        None -> Response.not_found(),
    }
}

// Serve `dir` over HTTP on `port` with live reload. Blocks. Register the same
// file handler for several path depths (the router matches by segment count),
// which covers any static site up to five path segments deep.
fun serve(dir: String, port: Int, state: Reloader) {
    let app = Server.new()
    let endpoint = "/__rw_reload"
    app.get(endpoint, fun(req: Request) -> Response = Response.text(status_body(state)))
    let handler = fun(req: Request) -> Response = _serve_one(dir, endpoint, req)
    app.get("/", handler)
    app.get("/:a", handler)
    app.get("/:a/:b", handler)
    app.get("/:a/:b/:c", handler)
    app.get("/:a/:b/:c/:d", handler)
    app.get("/:a/:b/:c/:d/:e", handler)
    println("raven-web dev server on http://localhost:".concat(port.to_string()))
    app.listen("127.0.0.1:".concat(port.to_string()))
}

// Rewrite Windows separators to forward slashes so path checks see one shape.
// Raven string literals make a backslash awkward, so the byte is compared
// directly (92) and the rest of the path is copied as-is.
fun _slashes(path: String) -> String {
    let out = ""
    let i = 0
    while i < path.length() {
        if path.byte_at(i) == 92 {
            out = out.concat("/")
        } else {
            out = out.concat(path.substring(i, i + 1))
        }
        i += 1
    }
    return out
}

// Whether any path segment names an excluded directory, or the file is a
// compiled executable. This is what keeps the build's own output (dist,
// target) from retriggering the watcher forever.
fun excluded(path: String, excludes: List<String>) -> Bool {
    let clean = _slashes(path)
    if clean.to_lower().ends_with(".exe") {
        return true
    }
    for segment in clean.split("/") {
        for name in excludes {
            if segment == name && name != "" {
                return true
            }
        }
    }
    return false
}

// A content signature of the watched files: their paths and contents joined.
// Changing, adding, or removing a file changes the signature. Entries whose
// path hits `excludes` are ignored.
fun _signature_excluding(paths: List<String>, excludes: List<String>) -> String {
    let out = ""
    for root in paths {
        match walk(root) {
            Ok(entries) -> {
                for entry in entries {
                    if !excluded(entry, excludes) {
                        out = out.concat(entry).concat("|")
                        match read(entry) {
                            Ok(body) -> {
                                out = out.concat(body).concat("\n")
                            },
                            Err(_) -> {},
                        }
                    }
                }
            },
            Err(_) -> {
                match read(root) {
                    Ok(body) -> {
                        out = out.concat(root).concat("|").concat(body).concat("\n")
                    },
                    Err(_) -> {},
                }
            },
        }
    }
    return out
}

fun _signature(paths: List<String>) -> String {
    let excludes: List<String> = []
    return _signature_excluding(paths, excludes)
}

// Poll `paths` for changes; on each change run `rebuild` and bump the reload
// token so connected browsers refresh. Blocks; run it in a goroutine alongside
// serve, or call serve in a goroutine and this on the main thread.
fun watch(paths: List<String>, state: Reloader, rebuild: fun() -> Unit) {
    let previous = _signature(paths)
    while true {
        sleep_millis(400)
        let current = _signature(paths)
        if current != previous {
            previous = current
            rebuild()
            state.token = state.token + 1
            println("raven-web rebuilt; reloading")
        }
    }
}

// The subcommand for a generator invocation: argv[1], defaulting to "build".
// Split out so it is testable without a real process argv.
fun command_from(argv: List<String>) -> String {
    if argv.len() < 2 {
        return "build"
    }
    let name = argv.get(1)
    if name == "" {
        return "build"
    }
    return name
}

// The standard raven-web project harness. Wraps a site generator in a small
// CLI (build, dev, serve, help), so every project gets the same workflow:
//
//   fun main() {
//       cli("site.rv", "dist").run(fun() -> Unit {
//           build()
//       })
//   }
//
// `entry` is the .rv file main lives in; dev mode recompiles it with the
// raven compiler whenever a watched file changes, regenerates the output by
// running the fresh executable with `build`, and live-reloads the browser. A
// compile error appears in the browser as an overlay instead of a reload.
struct Dev {
    entry: String,
    dist: String,
    serve_port: Int,
    extra: List<String>,
}

fun cli(entry: String, dist: String) -> Dev {
    let extra: List<String> = []
    return Dev { entry, dist, serve_port: 8080, extra }
}

impl Dev {
    fun port(self, value: Int) -> Dev {
        self.serve_port = value
        return self
    }

    // Watch another path besides the entry file's directory (assets kept
    // outside the project directory, a shared package).
    fun watch(self, path: String) -> Dev {
        self.extra.push(path)
        return self
    }

    fun run(self, build: fun() -> Unit) {
        let name = command_from(args())
        if name == "build" {
            _build_once(build)
            return
        }
        if name == "serve" {
            _build_once(build)
            serve(self.dist, self.serve_port, reloader())
            return
        }
        if name == "dev" {
            if !is_file(self.entry) {
                println("raven-web: entry file not found: ".concat(self.entry))
                println("cli() needs the path of the .rv file your main lives in")
                exit(1)
            }
            _build_once(build)
            let state = reloader()
            let entry = self.entry
            let roots = self._watch_roots()
            let excludes = self._excludes()
            spawn(fun() -> Unit {
                _watch_and_recompile(entry, roots, excludes, state)
            })
            println("raven-web dev: watching ".concat(_join_list(roots, ", ")))
            serve(self.dist, self.serve_port, state)
            return
        }
        if name == "help" {
            _usage()
            return
        }
        println("raven-web: unknown command ".concat(name))
        _usage()
        exit(1)
    }

    fun _watch_roots(self) -> List<String> {
        let roots: List<String> = [dirname(self.entry)]
        for path in self.extra {
            roots.push(path)
        }
        return roots
    }

    fun _excludes(self) -> List<String> {
        return [self.dist, "target", ".git", "node_modules"]
    }
}

fun _join_list(items: List<String>, separator: String) -> String {
    let out = ""
    for item in items {
        if out != "" {
            out = out.concat(separator)
        }
        out = out.concat(item)
    }
    return out
}

fun _build_once(build: fun() -> Unit) {
    let started = now_millis()
    build()
    println("raven-web: built in ".concat((now_millis() - started).to_string()).concat(" ms"))
}

fun _usage() {
    println("usage: <site> [command]")
    println("  build   generate the site into the output directory (default)")
    println("  dev     build, serve with live reload, and rebuild on source changes")
    println("  serve   build once and serve, without watching")
    println("  help    show this message")
}

// Poll the watched roots; on a change, recompile the entry file and regenerate
// the output. A failed compile lands in state.error, which the reload client
// shows as an overlay; a good build clears it and bumps the token.
fun _watch_and_recompile(
    entry: String,
    roots: List<String>,
    excludes: List<String>,
    state: Reloader,
) {
    let previous = _signature_excluding(roots, excludes)
    while true {
        sleep_millis(400)
        let current = _signature_excluding(roots, excludes)
        if current != previous {
            previous = current
            let started = now_millis()
            match _recompile(entry) {
                Ok(report) -> {
                    state.error = ""
                    state.token = state.token + 1
                    let trimmed = report.trim()
                    if trimmed != "" {
                        println(trimmed)
                    }
                    println(
                        "raven-web: rebuilt in ".concat((now_millis() - started).to_string()).concat(
                            " ms; reloading",
                        ),
                    )
                    // The regenerated output must not count as a source change.
                    previous = _signature_excluding(roots, excludes)
                },
                Err(message) -> {
                    state.error = message
                    println("raven-web: build failed; the error is shown in the browser")
                    println(message)
                },
            }
        }
    }
}

// The package name out of an rv.toml body: the first `name = "..."` line.
// Split out so it is testable without a file.
fun package_name_from(toml: String) -> Option<String> {
    for line in toml.split("\n") {
        let clean = line.trim()
        if clean.starts_with("name") {
            let rest = clean.substring(4, clean.length()).trim()
            if rest.starts_with("=") {
                let value = _name_token(rest.substring(1, rest.length()))
                if value != "" {
                    return Some(value)
                }
            }
        }
    }
    return None
}

// The name characters of a TOML string value, quotes and spaces dropped.
// Package names are [A-Za-z0-9._-], so keeping only those characters strips
// the quotes without naming the quote character (Raven string escaping makes
// that awkward).
fun _name_token(value: String) -> String {
    let out = ""
    let i = 0
    while i < value.length() {
        let b = value.byte_at(i)
        if (b >= 48 && b <= 57) || (b >= 65 && b <= 90) || (b >= 97 && b <= 122) || b == 45 || b == 95 || b == 46 {
            out = out.concat(value.substring(i, i + 1))
        }
        i += 1
    }
    return out
}

// Recompile a package project through rvpm, which resolves dependencies the
// single-file compiler does not. Returns the generator's stdout.
fun _recompile_package(name: String) -> Result<String, String> {
    return match run("rvpm", ["build"]) {
        Err(error) -> Err("could not run rvpm: ".concat(error.message)),
        Ok(compile) -> {
            if !compile.success() {
                Err(_output_text(compile))
            } else {
                let suffix = if os_name() == "windows" {
                    ".exe"
                } else {
                    ""
                }
                let exe = join(join("target", "raven-out"), name.concat(suffix))
                match run(exe, ["build"]) {
                    Err(error) -> Err("could not run the rebuilt generator: ".concat(error.message)),
                    Ok(regen) -> {
                        if !regen.success() {
                            Err(_output_text(regen))
                        } else {
                            Ok(regen.stdout)
                        }
                    },
                }
            }
        },
    }
}

// Compile `entry` into a scratch executable and run it with `build`. Returns
// the generator's stdout on success and the compiler's or generator's output
// on failure. The scratch name is fixed and lives under target, which is
// excluded from watching. A project with an rv.toml is a package: it is
// recompiled through rvpm instead, because only package mode resolves rvpm
// dependencies.
fun _recompile(entry: String) -> Result<String, String> {
    // Package mode needs an application package: an rv.toml alone may belong
    // to a library (raven-web's own repo is one), and rvpm only builds an
    // executable when src/main.rv exists.
    if is_file("rv.toml") && is_file(join("src", "main.rv")) {
        match read("rv.toml") {
            Ok(toml) -> {
                match package_name_from(toml) {
                    Some(name) -> {
                        return _recompile_package(name)
                    },
                    None -> {},
                }
            },
            Err(_) -> {},
        }
    }
    let _dir = create_dir_all("target")
    let scratch = join("target", ".rw-dev.exe")
    return match run("raven", ["build", entry, "-o", scratch]) {
        Err(error) -> Err("could not run the raven compiler: ".concat(error.message)),
        Ok(compile) -> {
            if !compile.success() {
                Err(_output_text(compile))
            } else {
                match run(scratch, ["build"]) {
                    Err(error) -> Err("could not run the rebuilt generator: ".concat(error.message)),
                    Ok(regen) -> {
                        if !regen.success() {
                            Err(_output_text(regen))
                        } else {
                            Ok(regen.stdout)
                        }
                    },
                }
            }
        },
    }
}

fun _output_text(out: Output) -> String {
    let text = out.stderr.trim()
    if text == "" {
        return out.stdout.trim()
    }
    if out.stdout.trim() == "" {
        return text
    }
    return text.concat("\n").concat(out.stdout.trim())
}
