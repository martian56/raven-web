import std/fs { create_dir_all, exists, read, write }
import std/test { assert_false, assert_true }
import "./lib" { Behavior, Ctx, CssRule, Expr, FeedEntry, Layout, Node, Page, Router, Signal, Site, StaticFile, Stylesheet, Theme, app, atom_feed, chunks, highlight, load_documents, markdown, parse_document, query_param, request, signal, sort_documents_desc, syntax_styles, transition_styles }

fun test_html_escapes_text_and_keeps_class_names() {
    let root = Node.div().class_name("min-h-screen bg-slate-950 hover:bg-slate-900 md:p-8").child_text(
        "<script>alert('x')</script>",
    )
    let html = root.render()
    assert_true(html.contains("min-h-screen bg-slate-950"))
    assert_true(html.contains("&lt;script&gt;"))
    assert_false(html.contains("<script>alert"))
}

fun test_attributes_reject_executable_names() {
    let html = Node.div().attr("onclick", "alert(1)").attr("style", "color: red").data(
        "id",
        "card-1",
    ).aria("label", "Card").title("A safe title").render()
    assert_false(html.contains("onclick"))
    assert_false(html.contains("style="))
    assert_true(html.contains("data-id="))
    assert_true(html.contains("aria-label="))
    assert_true(html.contains("title="))
}

fun test_urls_reject_javascript() {
    let bad = Node.link("Bad", "javascript:alert(1)").render()
    let good = Node.link("Docs", "/docs").render()
    assert_false(bad.contains("href="))
    assert_true(good.contains("href="))
}

fun test_css_rules_and_raw_css() {
    let css = Stylesheet.new().raw(".raw-card { color: red; }").raw(
        ".text-brand { color: #7dd3fc; }",
    ).render()
    assert_true(css.contains(".raw-card"))
    assert_true(css.contains(".text-brand"))

    // Infallible builders: no match needed to author a valid rule.
    let rule = CssRule.class_name("card").set("border-radius", "12px")
    let rendered = Stylesheet.new().add(rule).render()
    assert_true(rendered.contains(".card"))
    assert_true(rendered.contains("border-radius: 12px"))

    // try_set still reports an invalid declaration for callers that want it.
    match rule.try_set("border-radius", "12px") {
        Ok(_) -> assert_true(true),
        Err(_) -> assert_true(false),
    }

    // An invalid selector renders nothing and is skipped by the stylesheet;
    // try_new reports it for callers that want the signal.
    let bad = Stylesheet.new().add(CssRule.new(".card {").set("color", "red")).render()
    assert_true(bad == "")
    match CssRule.try_new(".card {") {
        Ok(_) -> assert_true(false),
        Err(_) -> assert_true(true),
    }
}

fun test_page_metadata_and_fixed_runtime() {
    let root = Node.fragment().child(
        Node.button("Reveal").on_click(Behavior.new().set_text("#status", "Saved")),
    ).child(Node.input_field("Search").on_input(Behavior.new().add_class("#status", "searching"))).child(
        Node.p().id("status").child_text("Hidden"),
    )
    let page = Page.new("A < B", root).lang("en-US").description("A safe page description").css_file(
        "assets/theme.css",
        ".p-4 { padding: 1rem; }",
    )
    assert_true(page.html().contains("lang="))
    assert_true(page.html().contains("description"))
    assert_true(page.html().contains("./assets/theme.css"))
    assert_true(page.html().contains("data-rw-click="))
    assert_true(page.html().contains("data-rw-input="))
    assert_false(page.html().contains("onclick"))

    // The runtime is a fixed constant: it never embeds the author's selectors or
    // values (those live in the HTML), and it interprets the serialized data.
    let js = page.js()
    assert_true(js.contains("addEventListener"))
    assert_true(js.contains("rw_dispatch"))
    assert_true(js.contains("JSON.parse"))
    assert_false(js.contains("#status"))
    assert_false(js.contains("Saved"))
}

fun test_behaviors_serialize_into_attributes() {
    let form = Node.form().on_submit(
        Behavior.new().prevent_default().set_value("#title", "").set_attribute(
            "#title",
            "aria-live",
            "polite",
        ).add_class("#title", "is-saved").remove_class("#title", "is-editing").focus("#title"),
    ).child(Node.input_field("Title").id("title")).child(Node.submit_button("Save"))
    let html = form.render()
    assert_true(html.contains("data-rw-submit="))
    // Serialized as escaped JSON, so quotes become &quot; and the prevent flag
    // and effect strings survive the round trip through the attribute.
    assert_true(html.contains("&quot;p&quot;:1"))
    assert_true(html.contains("aria-live"))
    assert_true(html.contains("is-saved"))
    // A javascript: navigation target is rejected before it reaches the output.
    let unsafe = Node.button("Bad").on_click(Behavior.new().navigate("javascript:alert(1)")).render()
    assert_false(unsafe.contains("javascript"))
}

fun test_expanded_effects_and_events() {
    let panel = Node.div().on_mouse_enter(Behavior.new().show("#tip")).on_mouse_leave(
        Behavior.new().hide("#tip"),
    ).on_key_down(Behavior.new().toggle_visible("#tip")).child(
        Node.button("Copy").on_click(Behavior.new().copy_to_clipboard("#code")),
    ).child(Node.link("Top", "#top").on_click(Behavior.new().prevent_default().scroll_to("#top")))
    let html = panel.render()
    assert_true(html.contains("data-rw-mouseover="))
    assert_true(html.contains("data-rw-mouseout="))
    assert_true(html.contains("data-rw-keydown="))
    assert_true(html.contains("data-rw-click="))
}

fun test_client_state_and_bindings() {
    let ui = Node.div().child(Node.p().id("out")).child(
        Node.button("inc").on_click(Behavior.new().increment_state("counter", 1)),
    ).child(Node.button("reset").on_click(Behavior.new().set_state("counter", "0"))).child(
        Node.button("toggle").on_click(Behavior.new().toggle_state("drawer")),
    )
    let page = Page.new("Counter", ui).state("counter", "0").state("drawer", "0").bind_text(
        "#out",
        "counter",
    ).bind_visible("#panel", "drawer").bind_class("#box", "drawer", "is-open")

    // The runtime config carries initial state and bindings; the fixed runtime
    // applies them and re-applies after each state change.
    let js = page.js()
    assert_true(js.contains("window.RW_INIT="))
    assert_true(js.contains("rw_apply"))
    assert_true(js.contains("counter"))
    assert_true(js.contains("is-open"))

    // The state-changing behaviors are serialized into the element attributes.
    let html = page.html()
    assert_true(html.contains("data-rw-click="))
    assert_true(html.contains("counter"))
}

fun test_fetch_effect_serializes_typed_request() {
    let login = Node.button("Sign in").on_click(
        Behavior.new().fetch(
            request("POST", "/login").field("email", "#email").field("password", "#password").store(
                "auth",
            ).on_ok(Behavior.new().hide("#login").set_text("#msg", "Welcome")).on_error(
                Behavior.new().set_text("#msg", "Bad credentials"),
            ),
        ),
    ).render()
    assert_true(login.contains("data-rw-click="))
    // The request is serialized as data: method, url, body fields, store key.
    assert_true(login.contains("fetch"))
    assert_true(login.contains("POST"))
    assert_true(login.contains("/login"))
    assert_true(login.contains("#email"))
    assert_true(login.contains("auth"))

    // An authenticated GET carries the bearer state key, not a literal token.
    let refresh = Node.button("Refresh").on_click(
        Behavior.new().fetch(request("GET", "/tasks").auth("auth.token").store("tasks")),
    ).render()
    assert_true(refresh.contains("auth.token"))

    // A javascript: URL is rejected before it can reach the output.
    let unsafe = Node.button("Bad").on_click(
        Behavior.new().fetch(request("GET", "javascript:alert(1)")),
    ).render()
    assert_false(unsafe.contains("javascript"))
}

fun test_list_binding_and_persisted_state() {
    // {{field}} placeholders are filled per item by the runtime.
    let row = Node.li().class_name("task").child(Node.span().child_text("{{title}}")).child(
        Node.button("Done").on_click(
            Behavior.new().fetch(request("POST", "/tasks/{{id}}/status").auth("auth.token")),
        ),
    )
    let page = Page.new("Board", Node.ul().id("todo")).state("auth", "").persist_key("auth").bind_list_where(
        "#todo",
        "tasks.tasks",
        row,
        "status",
        "todo",
    ).bind_text("#org", "auth.org_id")

    let js = page.js()
    // The template, the filter, and the persisted key all reach the config.
    assert_true(js.contains("list"))
    assert_true(js.contains("tasks.tasks"))
    assert_true(js.contains("{{title}}"))
    assert_true(js.contains("status"))
    assert_true(js.contains("auth.org_id"))
    // The runtime fills templates without innerHTML for item data.
    assert_true(js.contains("rw_fill"))
    assert_true(js.contains("setAttribute"))
    assert_true(js.contains("localStorage"))
    assert_true(js.contains("rw_fetch"))
}

fun test_updates_are_targeted_and_lists_reconcile() {
    let page = Page.new("x", Node.ul().id("rows")).state("n", "0").state("rows", "").bind_text(
        "#n",
        "n",
    ).bind_list("#rows", "rows", Node.li().child_text("{{title}}")).bind_text("#org", "auth.org_id")
    let js = page.js()

    // The dependency graph is resolved at build time: state key -> the bindings
    // that read it. A dotted path depends on its root key.
    assert_true(js.contains("\"d\":{"))
    assert_true(js.contains("\"n\":[0]"))
    assert_true(js.contains("\"rows\":[1]"))
    assert_true(js.contains("\"auth\":[2]"))

    // A state write notifies only that key's bindings, instead of re-running all.
    assert_true(js.contains("function rw_setstate(k,v){rw_state[k]=v;rw_persist(k);rw_notify(k);}"))
    assert_true(js.contains("var ids=rw_deps[key]"))

    // Lists reconcile by key and update rows in place: no subtree wipe, so focus
    // and DOM identity survive an update.
    assert_true(js.contains("function rw_key(it,i)"))
    assert_true(js.contains("insertBefore"))
    assert_false(js.contains("box.innerHTML=''"))
}

fun test_typed_signals_need_no_selectors_or_state_strings() {
    // Declared once, then passed by value. Nothing below names a CSS selector
    // or repeats a state string, so a typo is a compile error, not a silent
    // no-op that renders an empty page.
    let count = signal("count", "0")
    let auth = signal("auth", "")
    let tasks = signal("tasks", "")

    let view = Node.main_node().child(Node.span().text_of(count)).child(
        Node.button("+").on_click(Behavior.new().increment(count, 1)),
    ).child(Node.section().visible_if(auth).child(Node.span().text_of(auth.at("org_id")))).child(
        Node.p().hidden_if(auth).child_text("Please sign in"),
    ).child(
        Node.ul().each_where(tasks.at("tasks"), Node.li().child_text("{{title}}"), "status", "todo"),
    )
    let page = Page.new("app", view).signal(count).signal(auth).signal(tasks).persist(auth)
    let js = page.js()

    // raven-web marked the elements itself; the author wrote no selector.
    assert_true(page.html().contains("data-rw-b="))
    // The marker value is quoted: an unquoted CSS attribute value cannot
    // start with a digit, so it would be an invalid selector.
    assert_true(js.contains("[data-rw-b=\\\"0\\\"]"))

    // Bindings carry the signal's path, and deps key off its root.
    assert_true(js.contains("\"count\":["))
    assert_true(js.contains("auth.org_id"))
    assert_true(js.contains("\"auth\":["))
    assert_true(js.contains("tasks.tasks"))

    // Registration and persistence came from the handles.
    assert_true(js.contains("\"count\":\"0\""))
    assert_true(js.contains("localStorage"))

    // The list filter survives the typed path.
    assert_true(js.contains("\"status\""))
    assert_true(js.contains("\"todo\""))
}

fun test_expressions_give_conditionals_and_derived_text() {
    let tasks = signal("tasks", "")
    let n = signal("n", "0")

    // "if the list is empty, show this" and "1 task" vs "N tasks": neither was
    // expressible before, because a behavior was a flat list of effects.
    let empty_state = Node.p().child_text("Nothing yet").visible_when(Expr.is_empty(Expr.of(tasks)))
    let counter = Node.span().text_expr(
        Expr.ternary(
            Expr.eq(Expr.of(n), Expr.int(1)),
            Expr.text("1 task"),
            Expr.concat(Expr.of(n), Expr.text(" tasks")),
        ),
    )
    // An expression may read several signals; the binding must depend on both.
    let both = Node.div().class_when(
        Expr.and(Expr.gt(Expr.of(n), Expr.int(0)), Expr.not(Expr.is_empty(Expr.of(tasks)))),
        "ready",
    )

    let page = Page.new("x", Node.main_node().child(empty_state).child(counter).child(both)).signal(
        tasks,
    ).signal(n)
    let js = page.js()

    // The expression is emitted as a data tree, never as evaluated code, so the
    // no-eval safety model holds.
    assert_true(js.contains("\"empty\""))
    assert_true(js.contains("\"if\""))
    assert_true(js.contains("\"cat\""))
    assert_true(js.contains("\"and\""))
    // No JS eval anywhere: the tree is interpreted, so no unsafe-eval is needed.
    // (a naive "eval(" check would trip on rw_eval, the interpreter's own name)
    assert_false(js.contains("new Function"))
    assert_false(js.contains("window.eval"))
    assert_false(js.contains("=eval("))

    // The runtime interprets the tree.
    assert_true(js.contains("function rw_eval(e)"))

    // Dependencies are derived from the tree: the third binding reads both
    // signals, so it is listed under each.
    assert_true(js.contains("\"tasks\":[0,2]"))
    assert_true(js.contains("\"n\":[1,2]"))
}

fun test_theme_tokens_light_and_dark() {
    let css = Theme.new().color("bg", "#ffffff", "#0b1020").color("fg", "#111111", "#e6edf6").scale(
        "space-3",
        "1rem",
    ).css()
    assert_true(css.contains(":root{"))
    assert_true(css.contains("--color-bg:#ffffff;"))
    assert_true(css.contains("--space-3:1rem;"))
    assert_true(css.contains("prefers-color-scheme:dark"))
    assert_true(css.contains("--color-bg:#0b1020;"))
    assert_true(css.contains(":root[data-theme=dark]"))
    assert_true(css.contains(":root[data-theme=light]"))

    // An invalid token name is rejected and never reaches the output.
    let bad = Theme.new().token("bad name", "x", "y").css()
    assert_false(bad.contains("bad name"))
}

fun test_multi_page_site_with_layout() {
    let layout = Layout.new().lang("en").description("Demo site").header(
        Node.header().child_text("SiteChrome"),
    ).footer(Node.footer().child_text("SiteFooter")).with_styles(Stylesheet.new().raw("body{margin:0}"))
    let home = layout.wrap("Home", Node.h1().child_text("Welcome"))
    let about = layout.wrap("About", Node.p().child_text("About us"))
    let site = Site.new("https://example.com").page("/", home).page("/about", about)

    match site.write_static("target/raven-web-site-output") {
        Ok(out) -> {
            assert_true(out.page_count() == 2)
            assert_true(out.contains("/"))
            assert_true(out.contains("/about/"))
            assert_true(exists("target/raven-web-site-output/index.html"))
            assert_true(exists("target/raven-web-site-output/about/index.html"))
            assert_true(exists("target/raven-web-site-output/sitemap.xml"))
            assert_true(exists("target/raven-web-site-output/404.html"))
            match read("target/raven-web-site-output/about/index.html") {
                Ok(html) -> {
                    assert_true(html.contains("About us"))
                    assert_true(html.contains("SiteChrome"))
                    assert_true(html.contains("SiteFooter"))
                },
                Err(_) -> assert_true(false),
            }
            match read("target/raven-web-site-output/sitemap.xml") {
                Ok(xml) -> {
                    assert_true(xml.contains("https://example.com/about/"))
                    assert_true(xml.contains("urlset"))
                },
                Err(_) -> assert_true(false),
            }
        },
        Err(_) -> assert_true(false),
    }
}

struct Item {
    label: String,
}

fun test_composition_helpers_and_new_elements() {
    let items: List<Item> = []
    items.push(Item { label: "a" })
    items.push(Item { label: "b" })

    let list = Node.ul().child_each(items, fun(it: Item) -> Node = Node.li().child_text(it.label)).render()
    assert_true(list.contains("<li>a</li>"))
    assert_true(list.contains("<li>b</li>"))

    let cond = Node.div().child_when(true, Node.span().child_text("yes")).child_when(
        false,
        Node.span().child_text("no"),
    ).render()
    assert_true(cond.contains("yes"))
    assert_false(cond.contains("no"))

    let frag = Node.each(items, fun(it: Item) -> Node = Node.p().child_text(it.label)).render()
    assert_true(frag.contains("<p>a</p>"))
    assert_true(frag.contains("<p>b</p>"))
    assert_true(Node.when(false, Node.div().child_text("hidden")).render() == "")

    let controls = Node.fieldset().child(Node.legend().child_text("Group")).child(
        Node.radio("choice", "x"),
    ).child(Node.details().child(Node.summary().child_text("More"))).render()
    assert_true(controls.contains("<fieldset>"))
    assert_true(controls.contains("<legend>Group</legend>"))
    assert_true(controls.contains("<details>"))
    assert_true(controls.contains("<summary>More</summary>"))
}

fun test_static_files_are_written_safely() {
    // Infallible StaticFile.new: no match needed for a valid path.
    let manifest = StaticFile.new("manifest.webmanifest", "{}")
    let page = Page.new("Assets", Node.div()).css_file("assets/theme.css", ".theme { color: red; }").file(
        manifest,
    )
    match page.write_static("target/raven-web-test-output") {
        Ok(output) -> {
            assert_true(output.contains("index.html"))
            assert_true(output.contains("assets/theme.css"))
            assert_true(output.contains("manifest.webmanifest"))
            assert_true(output.file_count() == 5)
            assert_true(exists("target/raven-web-test-output/assets/theme.css"))
            assert_true(exists("target/raven-web-test-output/manifest.webmanifest"))
            match read("target/raven-web-test-output/assets/theme.css") {
                Ok(css) -> assert_true(css.contains(".theme")),
                Err(_) -> assert_true(false),
            }
        },
        Err(_) -> assert_true(false),
    }

    // An unsafe path yields an empty-path file that Page.file drops, so the
    // output holds only the three base files. try_css reports the rejection
    // for callers that want the signal.
    match Page.new("Drop", Node.div()).file(StaticFile.new("../escape.txt", "x")).write_static(
        "target/raven-web-drop-output",
    ) {
        Ok(output) -> {
            assert_true(output.file_count() == 3)
            assert_false(output.contains("../escape.txt"))
        },
        Err(_) -> assert_true(false),
    }
    match StaticFile.try_css("../bad.css", "body {}") {
        Ok(_) -> assert_true(false),
        Err(_) -> assert_true(true),
    }
}

// A component: props are typed parameters, so the compiler checks the call.
// It declares local state without naming a global key.
fun disclosure(ctx: Ctx, label: String) -> Node {
    let open = ctx.local("open", "")
    return Node.div().class_name("disclosure").child(
        Node.button(label).on_click(Behavior.new().toggle(open)),
    ).child(Node.p().child_text(label.concat(" body")).visible_if(open))
}

fun test_a_component_used_twice_gets_independent_state() {
    let ui = app()
    let view = Node.div().child(disclosure(ui.instance(), "First")).child(
        disclosure(ui.instance(), "Second"),
    )
    let page = ui.page("Components", view)

    // Two instances of one component, so two distinct state keys exist without
    // the author having written either one.
    let js = page.js()
    assert_true(js.contains("c0_open"))
    assert_true(js.contains("c1_open"))

    // Each instance's bindings and behaviors address only its own key, so
    // opening the first cannot move the second.
    let first_only = 0
    let second_only = 0
    for binding in page.all_bindings() {
        if binding.key == "c0_open" {
            first_only = first_only + 1
        }
        if binding.key == "c1_open" {
            second_only = second_only + 1
        }
    }
    assert_true(first_only == 1)
    assert_true(second_only == 1)

    // The dependency graph keeps them apart: a write to one wakes one binding.
    assert_true(js.contains("\"c0_open\""))
    assert_true(js.contains("\"c1_open\""))
}

fun test_components_nest_and_props_reach_the_markup() {
    let ui = app()
    let outer = ui.instance()
    let panel = Node.section().child(disclosure(outer.instance(), "Inner")).child(
        disclosure(outer.instance(), "Sibling"),
    )
    let page = ui.page("Nested", panel)
    let html = page.html()

    // Props render, and a component nested inside another still gets its own
    // scope rather than colliding with its parent's.
    assert_true(html.contains("Inner body"))
    assert_true(html.contains("Sibling body"))
    assert_true(page.js().contains("c1_open"))
    assert_true(page.js().contains("c2_open"))
}

// An HTML parser keeps the first copy of a repeated attribute and drops the
// rest, so emitting it twice made the second write a silent no-op. That bites
// hardest when a caller adds a class to a component that already set its own.
fun test_repeated_attributes_compose_instead_of_colliding() {
    // class accumulates, in author order, without repeating a token.
    let merged = Node.div().class_name("card").class_name("wide").render()
    assert_true(merged.contains("class=\"card wide\""))
    let deduped = Node.div().class_name("btn").class_name("btn-primary").class_name("btn").render()
    assert_true(deduped.contains("class=\"btn btn-primary\""))
    // Whole-token matching: "b" already present must not swallow "btn".
    let tokens = Node.div().class_name("a b").class_name("b c").render()
    assert_true(tokens.contains("class=\"a b c\""))

    // Every other attribute is replaced, and emitted once.
    let replaced = Node.div().attr("data-x", "1").attr("data-x", "2").render()
    assert_true(replaced.contains("data-x=\"2\""))
    assert_false(replaced.contains("data-x=\"1\""))
    let ids = Node.div().id("first").id("second").render()
    assert_true(ids.contains("id=\"second\""))
    assert_false(ids.contains("first"))

    // A component that sets its own class stays composable from outside.
    let composed = disclosure(app().instance(), "Head").class_name("mt-4").render()
    assert_true(composed.contains("disclosure mt-4"))
}

fun test_router_renders_routes_params_and_guards() {
    let auth = signal("auth", "")
    let router = Router.new()
    let _routes = router.route("/", Node.h1().child_text("Home")).route(
        "/tasks/:id",
        Node.span().text_of(router.param("id")),
    ).route("/settings", Node.h1().child_text("Settings")).requires(auth, "/login").not_found(
        Node.h1().child_text("Nope"),
    )
    assert_true(router.route_count() == 3)

    let html = Page.new("App", router.to_node()).signal(auth).html()
    // Every view is rendered once, hidden, and tagged with its pattern. The
    // runtime picks one, so nothing flashes before it does.
    assert_true(html.contains("data-rw-route=\"/\""))
    assert_true(html.contains("data-rw-route=\"/tasks/:id\""))
    assert_true(html.contains("data-rw-route=\"*\""))
    assert_true(html.contains("hidden=\"hidden\""))
    assert_true(html.contains("Home"))
    assert_true(html.contains("Nope"))
    // The guard travels as data on the route it protects.
    assert_true(html.contains("data-rw-guard="))
    assert_true(html.contains("/login"))

    // A trailing slash names the same route, and a pattern must be a path.
    let normalized = Router.new().route("/about/", Node.div()).to_node().render()
    assert_true(normalized.contains("data-rw-route=\"/about\""))
    assert_true(Router.new().route("not-a-path", Node.div()).route_count() == 0)
    match Router.new().try_route("/ok", Node.div()) {
        Ok(_) -> assert_true(true),
        Err(_) -> assert_true(false),
    }
    match Router.new().try_route("bad pattern", Node.div()) {
        Ok(_) -> assert_true(false),
        Err(_) -> assert_true(true),
    }

    // A route link stays a real link, so it still opens in a new tab.
    let link = Node.route_link("Task", "/tasks/1").render()
    assert_true(link.contains("href=\"/tasks/1\""))
    assert_true(link.contains("data-rw-link=\"/tasks/1\""))
}

fun test_spa_writes_a_fallback_document() {
    let router = Router.new().route("/", Node.h1().child_text("Home"))
    match Page.new("App", router.to_node()).spa().write_static("target/raven-web-spa-output") {
        Ok(output) -> {
            // Static hosts serve 404.html for a path they have no file for, so
            // the app has to live there too for a deep link to survive a reload.
            assert_true(output.contains("404.html"))
            assert_true(output.contains("index.html"))
        },
        Err(_) -> assert_true(false),
    }
    // A page that is not an SPA does not claim paths it does not own.
    match Page.new("Plain", Node.div()).write_static("target/raven-web-plain-output") {
        Ok(output) -> assert_false(output.contains("404.html")),
        Err(_) -> assert_true(false),
    }
}

fun test_forms_model_fields_and_express_validation() {
    let email = signal("email", "")
    let accepted = signal("accepted", "")
    let invalid = Expr.or(
        Expr.not(Expr.matches(Expr.of(email), "^[^@]+@[^@]+$")),
        Expr.not(Expr.of(accepted)),
    )

    let form = Node.form().child(Node.input_field("Email").bind_value(email)).child(
        Node.checkbox().bind_value(accepted),
    ).child(Node.submit_button("Save").disabled_when(invalid))
    let page = Page.new("Form", form).signal(email).signal(accepted)

    // A modelled field is marked, so typing writes the signal back.
    let html = page.html()
    assert_true(html.contains("data-rw-model=\"email\""))
    assert_true(html.contains("data-rw-model=\"accepted\""))

    // The rule travels as data, and the button subscribes to both fields it
    // reads, so it re-evaluates whichever one changes.
    let js = page.js()
    assert_true(js.contains("\"re\""))
    assert_true(js.contains("disabled"))
    assert_true(js.contains("\"email\":["))
    assert_true(js.contains("\"accepted\":["))
    // Still no code: the pattern is compiled as a RegExp, never eval'd.
    assert_false(js.contains("new Function"))
    assert_false(js.contains("window.eval"))

    // A field path is a read-only view, so modelling one is refused rather than
    // silently failing to write.
    let auth = signal("auth", "")
    assert_false(
        Node.input_field("Token").bind_value(auth.at("token")).render().contains("data-rw-model"),
    )
    match Node.input_field("Token").try_bind_value(auth.at("token")) {
        Ok(_) -> assert_true(false),
        Err(_) -> assert_true(true),
    }
    match Node.input_field("Email").try_bind_value(email) {
        Ok(_) -> assert_true(true),
        Err(_) -> assert_true(false),
    }
}

// raven-web claims to own all of the page's JavaScript. These are the ways that
// claim could be broken, each of which worked until v0.9.0.
fun test_no_element_can_smuggle_in_script() {
    // <script> took a raw JS string and it executed. Now the element cannot be
    // built at all, and its contents do not survive as page text either.
    let smuggled = Node.new("script").child_text("alert(1)").render()
    assert_true(smuggled == "")
    assert_false(smuggled.contains("alert"))

    // Elements that execute or hand the page away are refused wholesale.
    assert_true(Node.new("iframe").attr("srcdoc", "<script>alert(1)</script>").render() == "")
    assert_true(Node.new("base").attr("href", "https://evil.example").render() == "")
    assert_true(Node.new("object").render() == "")
    assert_true(Node.new("embed").render() == "")
    assert_true(Node.new("style").child_text("body{}").render() == "")
    match Node.try_new("script") {
        Ok(_) -> assert_true(false),
        Err(_) -> assert_true(true),
    }

    // srcdoc and http-equiv inject markup and behaviour, so no value is safe.
    assert_false(Node.div().attr("srcdoc", "<script>alert(1)</script>").render().contains("srcdoc"))
    assert_false(Node.div().attr("http-equiv", "refresh").render().contains("http-equiv"))

    // The raw attr() escape hatch is checked exactly like link()/image() are.
    // Every one of these used to be emitted verbatim.
    assert_false(Node.new("a").attr("href", "javascript:alert(1)").render().contains("javascript"))
    assert_false(Node.new("img").attr("src", "javascript:alert(1)").render().contains("javascript"))
    assert_false(
        Node.new("form").attr("action", "javascript:alert(1)").render().contains("javascript"),
    )
    assert_false(
        Node.new("button").attr("formaction", "javascript:alert(1)").render().contains("javascript"),
    )
    // Spelling tricks: case, and the control characters browsers strip out of a
    // scheme before following it.
    assert_false(Node.new("a").attr("href", "  JaVaScRiPt:alert(1)").render().contains("alert"))
    assert_false(Node.new("a").attr("href", "java\tscript:alert(1)").render().contains("alert"))
    assert_false(Node.new("a").attr("href", "java\nscript:alert(1)").render().contains("alert"))
    assert_false(Node.new("a").attr("href", "data:text/html,<script>").render().contains("data:"))
}

// Judging a URL by its scheme rather than by a prefix allowlist means ordinary
// relative paths work. "rows.json" used to be dropped, which was a silent no-op.
fun test_relative_urls_are_allowed_and_schemes_are_judged() {
    assert_true(Node.new("a").attr("href", "rows.json").render().contains("href=\"rows.json\""))
    assert_true(Node.image("logo.png", "Logo").render().contains("src=\"logo.png\""))
    assert_true(Node.link("Docs", "/docs").render().contains("href=\"/docs\""))
    assert_true(Node.link("Up", "../x").render().contains("href="))
    assert_true(Node.link("Site", "https://example.com").render().contains("href="))
    assert_true(Node.link("Mail", "mailto:a@b.co").render().contains("href="))
    assert_true(Node.link("Anchor", "#top").render().contains("href="))
    // A colon that is not a scheme (it comes after a slash) is still a path.
    assert_true(Node.new("a").attr("href", "a/b:c").render().contains("href="))
    // An unknown scheme is not allowed through.
    assert_false(Node.link("Bad", "vbscript:msgbox(1)").render().contains("href="))
    assert_false(Node.link("Bad", "file:///etc/passwd").render().contains("href="))
}

// ARIA states are the words true and false. raven-web's truthiness is "1" and
// "", so attr_of(open, "aria-expanded") writes aria-expanded="1", which is
// invalid and silently leaves a control announcing as collapsed. aria_if exists
// to make that impossible.
fun test_aria_states_bind_to_the_words_true_and_false() {
    let open = signal("open", "")
    let page = Page.new("A", Node.button("Menu").aria_if(open, "expanded")).signal(open)
    let js = page.js()
    assert_true(js.contains("\"aria\""))
    assert_true(js.contains("aria-expanded"))
    // The runtime writes the words, never the raw state value.
    assert_true(js.contains("'true':'false'"))

    // An expression works the same way, so a rule can drive aria-invalid.
    let touched = signal("touched", "")
    let bad = Page.new("B", Node.input_field("Email").aria_when(Expr.of(touched), "invalid")).signal(
        touched,
    ).js()
    assert_true(bad.contains("aria-invalid"))
    assert_true(bad.contains("\"touched\":["))
}

// A component used twice cannot hard-code a DOM id, but accessible markup has
// to point at elements by id. id_for scopes one per instance.
fun test_instance_ids_are_unique_and_scoped() {
    let ui = app()
    let first = ui.instance()
    let second = ui.instance()
    assert_true(first.id_for("panel") != second.id_for("panel"))
    // Stable: asking twice gives the same id, so markup can point at it.
    assert_true(first.id_for("panel") == first.id_for("panel"))
    // Distinct names within one instance stay distinct.
    assert_true(first.id_for("panel") != first.id_for("input"))

    let panel = first.id_for("panel")
    let open = first.local("open", "")
    let html = Node.section().child(
        Node.button("Head").attr("aria-controls", panel).aria_if(open, "expanded"),
    ).child(Node.div().id(panel).visible_if(open)).render()
    assert_true(html.contains("aria-controls=\"".concat(panel).concat("\"")))
    assert_true(html.contains("id=\"".concat(panel).concat("\"")))
}

fun test_router_containers_can_take_focus_without_joining_the_tab_order() {
    let html = Page.new("R", Router.new().route("/", Node.h1().child_text("Home")).to_node()).html()
    assert_true(html.contains("tabindex=\"-1\""))
    // Focus moves on a navigation, but not on the first paint.
    let js = Page.new("R", Router.new().route("/", Node.div()).to_node()).js()
    assert_true(js.contains("rw_booted"))
    assert_true(js.contains("hit.focus()"))
}

fun test_semantic_constructors_render() {
    let html = Node.form().child(Node.checkbox().id("ready")).child(Node.textarea("Notes")).child(
        Node.select().child(Node.option("Raven", "raven")),
    ).child(
        Node.table().child(
            Node.tr().child(Node.th().child_text("Name")).child(Node.td().child_text("Web")),
        ),
    ).render()
    assert_true(html.contains("<input type="))
    assert_true(html.contains("<textarea"))
    assert_true(html.contains("<select>"))
    assert_true(html.contains("<option value="))
    assert_true(html.contains("<table>"))
    assert_true(html.contains("<th>Name</th>"))
}

fun _has_warning(warnings: List<String>, needle: String) -> Bool {
    for warning in warnings {
        if warning.contains(needle) {
            return true
        }
    }
    return false
}

fun test_dropped_node_inputs_become_warnings() {
    let root = Node.div().attr("onclick", "alert(1)").child(Node.new("script")).child(
        Node.link("Bad", "javascript:alert(1)"),
    )
    let warnings = Page.new("W", root).warnings()
    assert_true(_has_warning(warnings, "onclick"))
    assert_true(_has_warning(warnings, "script"))
    assert_true(_has_warning(warnings, "unsafe URL"))
    // The page itself still renders, and still renders safely.
    let html = Page.new("W", root).html()
    assert_false(html.contains("onclick"))
    assert_false(html.contains("<script>alert"))
}

fun test_behavior_and_fetch_drops_reach_the_page() {
    let bad_click = Behavior.new().navigate("javascript:alert(1)").set_text("#ok {", "x")
    let spec = request("POST", "/save").field("title", "#title {")
    let root = Node.div().child(Node.button("Go").on_click(bad_click)).child(
        Node.button("Save").on_click(Behavior.new().fetch(spec)),
    )
    let warnings = Page.new("W", root).warnings()
    assert_true(_has_warning(warnings, "navigate"))
    assert_true(_has_warning(warnings, "set_text"))
    assert_true(_has_warning(warnings, "fetch field"))
}

fun test_style_and_theme_drops_reach_the_page() {
    let sheet = Stylesheet.new().add(CssRule.new(".card {").set("color", "red")).add(
        CssRule.class_name("ok").set("bad prop", "red"),
    )
    let warnings = Page.new("W", Node.div()).with_styles(sheet).warnings()
    assert_true(_has_warning(warnings, "invalid selector"))
    assert_true(_has_warning(warnings, "invalid property"))

    let themed = Theme.new().color("bg", "#fff", "#000").token("bad name", "1", "2").stylesheet()
    let theme_warnings = Page.new("T", Node.div()).with_styles(themed).warnings()
    assert_true(_has_warning(theme_warnings, "theme token"))
}

fun test_list_templates_and_router_drops_reach_the_page() {
    let rows = signal("rows", "")
    let template = Node.li().attr("onmouseover", "steal()")
    let list = Node.ul().each_of(rows, template)
    let router = Router.new().route("no-leading-slash", Node.div()).route("/", list)
    let warnings = Page.new("W", router.to_node()).warnings()
    assert_true(_has_warning(warnings, "onmouseover"))
    assert_true(_has_warning(warnings, "invalid pattern"))
}

fun test_page_level_drops_become_warnings() {
    let page = Page.new("W", Node.div()).state("bad key;", "1").lang("bad lang!").favicon(
        "javascript:alert(1)",
    ).persist_key("also bad;")
    let warnings = page.warnings()
    assert_true(_has_warning(warnings, "state declaration"))
    assert_true(_has_warning(warnings, "language tag"))
    assert_true(_has_warning(warnings, "favicon"))
    assert_true(_has_warning(warnings, "persist"))
}

fun test_a_clean_page_has_no_warnings() {
    let n = signal("n", "0")
    let page = Page.new(
        "Clean",
        Node.main_node().child(Node.h1().child_text("Hi")).child(
            Node.button("+").on_click(Behavior.new().increment(n, 1)),
        ).child(Node.span().text_of(n)),
    ).signal(n).with_styles(Stylesheet.new().add(CssRule.class_name("hero").set("padding", "4rem")))
    assert_true(page.warnings().len() == 0)
}

fun test_strict_pages_refuse_to_write_with_warnings() {
    let dirty = Node.div().attr("onclick", "alert(1)")
    match Page.new("Strict", dirty).strict().write_static("target/raven-web-strict-output") {
        Ok(_) -> assert_true(false),
        Err(error) -> assert_true(error.message.contains("warning")),
    }
    // Without strict the same page writes, so warnings stay non-breaking.
    match Page.new("Loose", dirty).write_static("target/raven-web-loose-output") {
        Ok(output) -> assert_true(output.contains("index.html")),
        Err(_) -> assert_true(false),
    }
}

fun test_head_metadata_renders_and_escapes() {
    let fields: Map<String, JsonValue> = Map.new()
    fields.set("name", JsonValue.Str("Fuad"))
    fields.set("evil", JsonValue.Str("</script><script>alert(1)</script>"))
    let ld = JsonValue.Object(fields)
    let page = Page.new("Head", Node.div()).meta("robots", "index, follow").meta_property(
        "og:title",
        "A <quoted> title",
    ).canonical("https://example.com/").theme_color("#000000").preconnect(
        "https://fonts.gstatic.com",
        true,
    ).preconnect("https://cdn.example.com", false).structured_data(ld)
    let html = page.html()
    assert_true(html.contains("name=\"robots\""))
    assert_true(html.contains("property=\"og:title\""))
    assert_true(html.contains("content=\"A &lt;quoted&gt; title\""))
    assert_true(html.contains("rel=\"canonical\" href=\"https://example.com/\""))
    assert_true(html.contains("name=\"theme-color\" content=\"#000000\""))
    assert_true(html.contains("rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin"))
    assert_true(html.contains("rel=\"preconnect\" href=\"https://cdn.example.com\">"))
    assert_true(html.contains("application/ld+json"))
    // The JSON-LD payload cannot close its script element: angle brackets are
    // escaped inside the JSON, so the attack string never appears as markup.
    assert_false(html.contains("<script>alert"))
    assert_true(html.contains("u003c/script"))
    assert_true(page.warnings().len() == 0)
}

fun test_head_metadata_rejects_bad_input_loudly() {
    let page = Page.new("Head", Node.div()).meta("onload", "x").canonical("javascript:alert(1)").meta_property(
        "bad prop",
        "x",
    )
    let html = page.html()
    assert_false(html.contains("onload"))
    assert_false(html.contains("javascript:alert"))
    let warnings = page.warnings()
    assert_true(_has_warning(warnings, "dropped meta"))
    assert_true(_has_warning(warnings, "dropped canonical"))
    assert_true(_has_warning(warnings, "dropped meta_property"))
}

fun test_meta_names_allow_underscores() {
    let page = Page.new("U", Node.div()).meta_property("og:site_name", "Fuad Alizada").meta_property(
        "article:published_time",
        "2026-07-16",
    )
    let html = page.html()
    assert_true(html.contains("property=\"og:site_name\""))
    assert_true(html.contains("property=\"article:published_time\""))
    assert_true(page.warnings().len() == 0)
    // The executable names stay refused by name, not by character.
    let bad = Node.div().attr("on_click", "x").render()
    assert_false(bad.contains("on_click"))
}

fun test_alternates_render_and_validate() {
    let page = Page.new("Alt", Node.div()).alternate("az", "https://example.com/").alternate(
        "en",
        "https://example.com/en/",
    ).alternate("x-default", "https://example.com/").alternate("bad lang!", "https://x.com/").alternate(
        "en",
        "javascript:alert(1)",
    )
    let html = page.html()
    assert_true(html.contains("hreflang=\"az\" href=\"https://example.com/\""))
    assert_true(html.contains("hreflang=\"en\" href=\"https://example.com/en/\""))
    assert_true(html.contains("hreflang=\"x-default\""))
    assert_false(html.contains("bad lang"))
    assert_false(html.contains("javascript:alert"))
    assert_true(_has_warning(page.warnings(), "dropped alternate"))
}

fun test_sitemap_carries_lastmod() {
    let site = Site.new("https://example.com").page("/", Page.new("Home", Node.div())).lastmod(
        "2026-07-16",
    ).page("/about", Page.new("About", Node.div()))
    match site.write_static("target/raven-web-lastmod-output") {
        Ok(_) -> {
            match read("target/raven-web-lastmod-output/sitemap.xml") {
                Ok(xml) -> {
                    assert_true(xml.contains("<lastmod>2026-07-16</lastmod>"))
                    // Only the dated route carries one.
                    assert_true(xml.contains("<loc>https://example.com/about/</loc></url>"))
                },
                Err(_) -> assert_true(false),
            }
        },
        Err(_) -> assert_true(false),
    }
}

fun test_query_params_are_typed_state() {
    let tab = query_param("tab")
    assert_true(tab.key == "query")
    assert_true(tab.path == "query.tab")
    let router = Router.new().route("/", Node.div())
    let via_router = router.query("tab")
    assert_true(via_router.path == "query.tab")
    // The runtime parses the query string into the reserved key on boot.
    let js = Page.new("Q", Node.div().text_of(tab)).js()
    assert_true(js.contains("rw_query"))
    assert_true(js.contains("location.search"))
}

fun test_images_default_lazy_and_size() {
    let plain = Node.image("/a.png", "A").render()
    assert_true(plain.contains("loading=\"lazy\""))
    assert_true(plain.contains("decoding=\"async\""))
    let sized = Node.image_sized("/a.png", "A", 800, 400).render()
    assert_true(sized.contains("width=\"800\""))
    assert_true(sized.contains("height=\"400\""))
    let hero = Node.image_sized("/hero.png", "Hero", 1600, 900).eager().render()
    assert_true(hero.contains("loading=\"eager\""))
    assert_true(hero.contains("fetchpriority=\"high\""))
    let responsive = Node.image("/a.png", "A").srcset_add("/a-640.png", 640).srcset_add(
        "/a-1280.png",
        1280,
    ).sizes("(max-width: 640px) 100vw, 640px").render()
    assert_true(responsive.contains("srcset=\"/a-640.png 640w, /a-1280.png 1280w\""))
    assert_true(responsive.contains("sizes="))
    let bad = Node.image("/a.png", "A").srcset_add("javascript:alert(1)", 640)
    assert_true(_has_warning(bad.warnings, "srcset"))
}

fun test_css_minifier_is_conservative() {
    let css = ".a {  color: red;  }\n/* gone */\n.a :hover { content: \"a  b\"; }\n@media (min-width: 920px) { .b > .c { margin: calc(100% - 2px); } }"
    let page = Page.new("M", Node.div()).with_css(css).optimize()
    let out = page.css()
    assert_false(out.contains("gone"))
    assert_true(out.contains(".a{color:red}"))
    // Space before a colon is a descendant selector and must survive.
    assert_true(out.contains(".a :hover"))
    // Quoted strings keep their internal spacing.
    assert_true(out.contains("\"a  b\""))
    // calc() keeps the spaces its operators require.
    assert_true(out.contains("calc(100% - 2px)"))
    assert_true(out.contains("@media (min-width:920px)"))
}

fun test_optimize_fingerprints_and_cleans_stale() {
    let first = Page.new("F", Node.div()).with_css(".a { color: red; }").optimize()
    let css_name = first.css_asset_name()
    assert_true(css_name.starts_with("styles."))
    assert_true(css_name.ends_with(".css"))
    assert_true(css_name.length() == 19)
    assert_true(first.html().contains(css_name))
    assert_true(first.html().contains(first.js_asset_name()))
    match first.write_static("target/raven-web-fp-output") {
        Ok(out) -> assert_true(out.contains(css_name)),
        Err(_) -> assert_true(false),
    }
    // A content change renames the asset and removes the old one.
    let second = Page.new("F", Node.div()).with_css(".a { color: blue; }").optimize()
    let renamed = second.css_asset_name()
    assert_false(renamed == css_name)
    match second.write_static("target/raven-web-fp-output") {
        Ok(_) -> {
            assert_false(exists("target/raven-web-fp-output/".concat(css_name)))
            assert_true(exists("target/raven-web-fp-output/".concat(renamed)))
        },
        Err(_) -> assert_true(false),
    }
    // Without optimize the names stay fixed.
    let plain = Page.new("F", Node.div())
    assert_true(plain.css_asset_name() == "styles.css")
    assert_true(plain.js_asset_name() == "app.js")
}

fun test_base_path_prefixes_assets_and_config() {
    let page = Page.new("B", Node.div()).base_path("/repo")
    let html = page.html()
    assert_true(html.contains("href=\"/repo/styles.css\""))
    assert_true(html.contains("src=\"/repo/app.js\""))
    assert_true(page.js().contains("\"z\":\"/repo\""))
    // The runtime strips and restores the prefix around routing.
    assert_true(page.js().contains("rw_base"))
    // Root base means no prefix, and an invalid base is dropped loudly.
    let root = Page.new("B", Node.div()).base_path("/")
    assert_true(root.html().contains("href=\"styles.css\""))
    let bad = Page.new("B", Node.div()).base_path("no space allowed here?")
    assert_true(_has_warning(bad.warnings(), "base_path"))
}

fun test_frontmatter_parses_and_survives_edge_cases() {
    let source = "---\ntitle: Hello: a colon survives\ndate: \"2026-07-16\"\n---\nBody line one.\nBody line two."
    let doc = parse_document(source)
    assert_true(doc.get("title") == "Hello: a colon survives")
    assert_true(doc.get("date") == "2026-07-16")
    assert_true(doc.body.contains("Body line one."))
    assert_true(doc.body.contains("Body line two."))
    // No frontmatter: the whole source is body.
    let plain = parse_document("Just text.")
    assert_true(plain.body == "Just text.")
    assert_true(plain.get_or("title", "none") == "none")
    // An unclosed header is treated as body, not swallowed.
    let broken = parse_document("---\ntitle: half\nno closing fence")
    assert_true(broken.body.contains("no closing fence"))
    assert_true(broken.get("title") == "")
}

fun test_markdown_renders_block_structure() {
    let source = "# Title\n\nA paragraph that\nspans two lines.\n\n## Section\n\n- one\n- two\n\n1. first\n2. second\n\n> quoted *text*\n\n---\n\n```raven\nlet x = 1\n```"
    let html = markdown(source).render()
    assert_true(html.contains("<h1>Title</h1>"))
    assert_true(html.contains("<p>A paragraph that spans two lines.</p>"))
    assert_true(html.contains("<h2>Section</h2>"))
    assert_true(html.contains("<ul><li>one</li><li>two</li></ul>"))
    assert_true(html.contains("<ol><li>first</li><li>second</li></ol>"))
    assert_true(html.contains("<blockquote>"))
    assert_true(html.contains("<em>text</em>"))
    assert_true(html.contains("<hr>"))
    assert_true(html.contains("language-raven"))
    // The fenced block is highlighted now: the keyword is a span, and the
    // rest of the line survives as escaped text.
    assert_true(html.contains("tok-kw\">let"))
    assert_true(html.contains("tok-num\">1"))
}

fun test_markdown_renders_inline_marks() {
    let html = markdown(
        "Mix **strong** and *em* and `code` and a [link](/docs) and escaped \\*stars\\*.",
    ).render()
    assert_true(html.contains("<strong>strong</strong>"))
    assert_true(html.contains("<em>em</em>"))
    assert_true(html.contains("<code>code</code>"))
    assert_true(html.contains("href=\"/docs\""))
    assert_true(html.contains("*stars*"))
    // Unmatched markers stay literal instead of vanishing.
    let loose = markdown("a * b and [not a link").render()
    assert_true(loose.contains("a * b"))
    assert_true(loose.contains("[not a link"))
}

fun test_markdown_is_safe_by_construction() {
    let source = "<script>alert(1)</script>\n\nA [bad](javascript:alert(1)) link and ![img](javascript:alert(2)).\n\n<img src=x onerror=alert(3)>"
    let node = markdown(source)
    let html = node.render()
    assert_false(html.contains("<script>"))
    assert_true(html.contains("&lt;script&gt;"))
    assert_false(html.contains("javascript:alert"))
    // The raw img tag is text, not markup: escaped, its onerror is inert.
    assert_false(html.contains("<img src=x"))
    assert_true(html.contains("&lt;img src=x onerror"))
    // The drops are loud, like every other builder.
    let warnings = Page.new("W", node).warnings()
    assert_true(warnings.len() >= 2)
    // A markdown image gets the image defaults.
    let img = markdown("![alt text](/pic.png)").render()
    assert_true(img.contains("loading=\"lazy\""))
    assert_true(img.contains("alt=\"alt text\""))
}

fun test_documents_load_sort_and_chunk() {
    let _mk = create_dir_all("target/rw-content-test")
    let _a = write(
        "target/rw-content-test/a-first.md",
        "---\ntitle: First\ndate: 2026-07-01\n---\nAlpha",
    )
    let _b = write(
        "target/rw-content-test/b-second.md",
        "---\ntitle: Second\ndate: 2026-07-16\n---\nBeta",
    )
    let docs = load_documents("target/rw-content-test")
    assert_true(docs.len() == 2)
    let sorted = sort_documents_desc(docs, "date")
    assert_true(sorted.get(0).get("title") == "Second")
    assert_true(sorted.get(1).get("title") == "First")
    assert_true(sorted.get(0).slug == "b-second")
    assert_true(sorted.get(0).html().render().contains("Beta"))
    let pages = chunks(sorted, 1)
    assert_true(pages.len() == 2)
    assert_true(pages.get(0).len() == 1)
}

fun test_atom_feed_escapes_and_dates() {
    let entries: List<FeedEntry> = [
        FeedEntry {
            title: "One <two>",
            url: "https://example.com/blog/one/",
            date: "2026-07-16",
            summary: "A & B",
        },
    ]
    let xml = atom_feed(
        "My <blog>",
        "https://example.com/",
        "https://example.com/feed.xml",
        "2026-07-16",
        entries,
    )
    assert_true(xml.contains("<title>My &lt;blog&gt;</title>"))
    assert_true(xml.contains("<title>One &lt;two&gt;</title>"))
    assert_true(xml.contains("<summary>A &amp; B</summary>"))
    assert_true(xml.contains("<updated>2026-07-16T00:00:00Z</updated>"))
    assert_true(xml.contains("rel=\"self\""))
    assert_false(xml.contains("<two>"))
}

fun test_key_filtered_events_serialize() {
    let close = Behavior.new().close_dialog("#help")
    let html = Node.div().on_key("Escape", close).render()
    assert_true(html.contains("data-rw-keydown="))
    assert_true(html.contains("&quot;k&quot;:&quot;Escape&quot;"))
    assert_true(html.contains("dcl"))
    // A bad key name is dropped loudly and binds nothing.
    let bad = Node.div().on_key("Esc ape!", Behavior.new().hide("#x"))
    assert_false(bad.render().contains("data-rw-keydown"))
    assert_true(_has_warning(bad.warnings, "on_key"))
}

fun test_debounce_serializes_and_validates() {
    let search = Behavior.new().debounce(300).set_state("q", "x")
    let html = Node.input_field("Search").on_input(search).render()
    assert_true(html.contains("&quot;w&quot;:300"))
    let bad = Behavior.new().debounce(0)
    assert_true(_has_warning(bad.warnings, "debounce"))
    // The runtime carries the per-element timer machinery.
    let js = Page.new("D", Node.div()).js()
    assert_true(js.contains("clearTimeout"))
    assert_true(js.contains("setTimeout"))
}

fun test_page_timers_serialize_and_validate() {
    let poll = Behavior.new().fetch(request("GET", "/rows.json").store("rows"))
    let page = Page.new("T", Node.div()).every(5000, poll)
    let js = page.js()
    assert_true(js.contains("\"t\":[[5000,"))
    assert_true(js.contains("setInterval"))
    let fast = Page.new("T", Node.div()).every(16, Behavior.new().toggle_state("x"))
    assert_true(_has_warning(fast.warnings(), "every"))
    assert_false(fast.js().contains("[[16,"))
}

fun test_dialog_effects_and_element() {
    let open = Behavior.new().open_dialog("#confirm")
    let html = Node.div().child(
        Node.dialog().id("confirm").child(Node.p().child_text("Sure?")).child(
            Node.button("Close").on_click(Behavior.new().close_dialog("#confirm")),
        ),
    ).child(Node.button("Open").on_click(open)).render()
    assert_true(html.contains("<dialog id=\"confirm\">"))
    assert_true(html.contains("dop"))
    assert_true(html.contains("dcl"))
    // The runtime prefers showModal and falls back to the open attribute.
    let js = Page.new("Dlg", Node.dialog()).js()
    assert_true(js.contains("showModal"))
}

fun test_transition_tags_and_runtime() {
    let sig = signal("open", "")
    let node = Node.div().visible_if(sig).transition().render()
    assert_true(node.contains("data-rw-trans"))
    // The runtime toggles the class for a transition element and display for
    // a plain one.
    let js = Page.new("T", Node.div().visible_if(sig).transition()).js()
    assert_true(js.contains("data-rw-trans"))
    assert_true(js.contains("rw-hidden"))
    assert_true(js.contains("classList.remove"))
    // The default styles are reduced-motion safe.
    let css = transition_styles().render()
    assert_true(css.contains("[data-rw-trans].rw-hidden"))
    assert_true(css.contains("prefers-reduced-motion: no-preference"))
}

fun test_highlight_classes_tokens_and_stays_safe() {
    let node = highlight("let x = 42 // a </script> comment\nlet s = \"hi\"", "raven")
    let html = node.render()
    assert_true(html.contains("class=\"language-raven\""))
    assert_true(html.contains("tok-kw\">let"))
    assert_true(html.contains("tok-num\">42"))
    assert_true(html.contains("tok-com"))
    assert_true(html.contains("tok-str"))
    // Highlighting escapes like everything else: the comment cannot inject.
    assert_false(html.contains("</script>"))
    assert_true(html.contains("&lt;/script&gt;"))
    // An unknown language is plain escaped text, no spans.
    let plain = highlight("<b>x</b>", "klingon").render()
    assert_false(plain.contains("tok-"))
    assert_true(plain.contains("&lt;b&gt;"))
}

fun test_markdown_fenced_block_is_highlighted() {
    let html = markdown("```python\ndef f():\n    return 1  # done\n```").render()
    assert_true(html.contains("<pre><code class=\"language-python\">"))
    assert_true(html.contains("tok-kw\">def"))
    assert_true(html.contains("tok-com\"># done"))
    // A fenced block with no language stays plain.
    let plain = markdown("```\njust text\n```").render()
    assert_false(plain.contains("tok-"))
    assert_true(plain.contains("just text"))
}

fun test_syntax_styles_exposes_the_tokens() {
    let css = syntax_styles().render()
    assert_true(css.contains(".tok-kw"))
    assert_true(css.contains(".tok-str"))
    assert_true(css.contains(".tok-com"))
    assert_true(css.contains(".tok-num"))
}
