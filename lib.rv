// A page interval: run these effects every `ms` milliseconds, for carousels,
// clocks, and polling refreshes.
struct TimerSpec {
    ms: Int,
    effects: List<Effect>,
}

struct StatePair {
    key: String,
    value: String,
    raw: Bool,
}

// A reflection of client state to the DOM. kind is text, class, attr, visible,
// or list; arg carries the class name, attribute name, or (for list) the
// rendered item template. A list binding may filter items by a field value.
struct Binding {
    kind: String,
    selector: String,
    key: String,
    arg: String,
    filter_field: String,
    filter_value: String,
    expr: String,
    dep_keys: List<String>,
}

fun _binding(kind: String, selector: String, key: String, arg: String) -> Binding {
    let dep_keys: List<String> = [_root_key(key)]
    return Binding {
        kind,
        selector,
        key,
        arg,
        filter_field: "",
        filter_value: "",
        expr: "",
        dep_keys,
    }
}

// Marker assignment. A node that declares bindings gets a data-rw-b marker, so
// the generated binding can target it without the author writing a selector.
// Assignment is idempotent and pre-order, so html() and js() agree on markers
// whichever runs first.
struct BindCounter {
    next: Int,
}

fun _assign_marks(node: Node, counter: BindCounter) {
    if node.binds.len() > 0 && node.mark < 0 {
        node.mark = counter.next
        counter.next = counter.next + 1
        node.attrs.push(Attribute { name: "data-rw-b", value: node.mark.to_string() })
    }
    for kid in node.kids {
        _assign_marks(kid, counter)
    }
}

// The value must be quoted: an unquoted CSS attribute value cannot start with a
// digit, so [data-rw-b=0] is invalid and silently matches nothing.
fun _mark_selector(mark: Int) -> String {
    return "[data-rw-b=\"".concat(mark.to_string()).concat("\"]")
}

// Gather every warning in the tree, depth first. Dropped nodes stay in their
// parent's kids list precisely so this walk still reaches them.
fun _collect_warnings(node: Node, out: List<String>) {
    for warning in node.warnings {
        out.push(warning)
    }
    for kid in node.kids {
        _collect_warnings(kid, out)
    }
}

fun _collect_binds(node: Node, out: List<Binding>) {
    if node.mark >= 0 {
        let selector = _mark_selector(node.mark)
        for bind in node.binds {
            out.push(
                Binding {
                    kind: bind.kind,
                    selector,
                    key: bind.path,
                    arg: bind.arg,
                    filter_field: bind.filter_field,
                    filter_value: bind.filter_value,
                    expr: bind.expr,
                    dep_keys: bind.dep_keys,
                },
            )
        }
    }
    for kid in node.kids {
        _collect_binds(kid, out)
    }
}

// A binding reads a dotted path; it depends on the root state key.
fun _root_key(path: String) -> String {
    let parts = path.split(".")
    if parts.len() == 0 {
        return path
    }
    return parts[0]
}

fun _contains_str(list: List<String>, value: String) -> Bool {
    for item in list {
        if item == value {
            return true
        }
    }
    return false
}

// The dependency graph, resolved at build time: state key to the bindings that
// read it. The runtime uses this to update only what changed, instead of
// re-running every binding on every state write.
fun _serialize_deps(bindings: List<Binding>) -> String {
    let out = "{"
    let seen: List<String> = []
    let first = true
    let i = 0
    while i < bindings.len() {
        for key in bindings[i].dep_keys {
            if !_contains_str(seen, key) {
                seen.push(key)
                if !first {
                    out = out.concat(",")
                }
                out = out.concat(_js_string(key)).concat(":[")
                let j = 0
                let ifirst = true
                while j < bindings.len() {
                    if _contains_str(bindings[j].dep_keys, key) {
                        if !ifirst {
                            out = out.concat(",")
                        }
                        out = out.concat(j.to_string())
                        ifirst = false
                    }
                    j = j + 1
                }
                out = out.concat("]")
                first = false
            }
        }
        i = i + 1
    }
    return out.concat("}")
}

fun _serialize_config(
    state: List<StatePair>,
    bindings: List<Binding>,
    persisted: List<String>,
    load_effects: List<Effect>,
    timers: List<TimerSpec>,
    base: String,
) -> String {
    let out = "{".concat(_js_string("s")).concat(":{")
    let first = true
    for pair in state {
        if !first {
            out = out.concat(",")
        }
        let encoded = if pair.raw {
            pair.value
        } else {
            _js_string(pair.value)
        }
        out = out.concat(_js_string(pair.key)).concat(":").concat(encoded)
        first = false
    }
    out = out.concat("},").concat(_js_string("b")).concat(":[")
    let bfirst = true
    for binding in bindings {
        if !bfirst {
            out = out.concat(",")
        }
        out = out.concat("[").concat(_js_string(binding.kind)).concat(",").concat(
            _js_string(binding.selector),
        ).concat(",").concat(_js_string(binding.key)).concat(",").concat(_js_string(binding.arg)).concat(
            ",",
        ).concat(_js_string(binding.filter_field)).concat(",").concat(_js_string(binding.filter_value)).concat(
            ",",
        )
        if binding.expr == "" {
            out = out.concat("null")
        } else {
            out = out.concat(binding.expr)
        }
        out = out.concat("]")
        bfirst = false
    }
    out = out.concat("],").concat(_js_string("p")).concat(":[")
    let pfirst = true
    for key in persisted {
        if !pfirst {
            out = out.concat(",")
        }
        out = out.concat(_js_string(key))
        pfirst = false
    }
    out = out.concat("],").concat(_js_string("l")).concat(":").concat(
        _serialize_effects(load_effects),
    )
    out = out.concat(",").concat(_js_string("d")).concat(":").concat(_serialize_deps(bindings))
    out = out.concat(",").concat(_js_string("z")).concat(":").concat(_js_string(base))
    out = out.concat(",").concat(_js_string("t")).concat(":[")
    let tfirst = true
    for timer in timers {
        if !tfirst {
            out = out.concat(",")
        }
        out = out.concat("[").concat(timer.ms.to_string()).concat(",").concat(
            _serialize_effects(timer.effects),
        ).concat("]")
        tfirst = false
    }
    return out.concat("]}")
}

struct Page {
    title: String,
    root: Node,
    styles: Stylesheet,
    language: String,
    description: String,
    favicon: String,
    files: List<StaticFile>,
    css_links: List<String>,
    state: List<StatePair>,
    bindings: List<Binding>,
    persisted: List<String>,
    load_effects: List<Effect>,
    timers: List<TimerSpec>,
    single_page: Bool,
    // Typed head metadata: name/content metas, property/content metas (Open
    // Graph, Twitter), preconnect origins, serialized JSON-LD blocks, and the
    // singular canonical URL and theme color.
    metas: List<Attribute>,
    meta_props: List<Attribute>,
    preconnects: List<Attribute>,
    structured: List<String>,
    // hreflang alternates: name is the language code, value is the URL.
    alternates: List<Attribute>,
    canonical_url: String,
    theme_color_value: String,
    // With optimize set, the emitted CSS is minified and styles.css/app.js
    // carry a content hash in their names, so far-future caching is safe.
    optimize_mode: Bool,
    // A deployment prefix ("/repo" on a project page). Asset references
    // become absolute under it and the client router works in site-local
    // paths beneath it.
    base: String,
    // Page-level dropped inputs; warnings() adds the tree's and the styles'.
    page_warnings: List<String>,
    // With strict set, write_static refuses to write while any warning exists.
    strict_mode: Bool,
}

struct StaticOutput {
    directory: String,
    paths: List<String>,
}

impl StaticOutput {
    fun directory(self) -> String {
        return self.directory
    }

    fun paths(self) -> List<String> {
        return self.paths
    }

    fun file_count(self) -> Int {
        return self.paths.len()
    }

    fun contains(self, path: String) -> Bool {
        for item in self.paths {
            if item == path {
                return true
            }
        }
        return false
    }
}

fun _empty_css_links() -> List<String> {
    let css_links: List<String> = []
    return css_links
}

fun _empty_files() -> List<StaticFile> {
    let files: List<StaticFile> = []
    return files
}

fun _empty_state() -> List<StatePair> {
    let state: List<StatePair> = []
    return state
}

fun _empty_bindings() -> List<Binding> {
    let bindings: List<Binding> = []
    return bindings
}

fun _empty_persisted() -> List<String> {
    let persisted: List<String> = []
    return persisted
}

fun _empty_effects() -> List<Effect> {
    let effects: List<Effect> = []
    return effects
}

// A backslash character without a backslash literal: serialize a string that
// contains a quote and read the escape the JSON writer produced.
fun _backslash() -> String {
    return stringify(JsonValue.Str(_quote())).substring(1, 2)
}

// JSON destined for a script element must not be able to close it. Replacing
// every angle bracket with its JSON unicode escape keeps the payload valid
// JSON and inert as markup, whatever strings the data carries.
fun _escape_json_for_script(json: String) -> String {
    let bs = _backslash()
    return json.replace("<", bs.concat("u003c")).replace(">", bs.concat("u003e"))
}

// An eight-hex-digit content fingerprint. Not cryptographic; it only has to
// change when the content changes, so caches can be immutable.
fun _fingerprint(content: String) -> String {
    let h = fnv1a(content)
    if h < 0 {
        h = 0 - h
    }
    let digits = "0123456789abcdef"
    let out = ""
    let i = 0
    while i < 8 {
        let d = h % 16
        out = digits.substring(d, d + 1).concat(out)
        h = h / 16
        i += 1
    }
    return out
}

// A conservative CSS minifier: strips comments, collapses whitespace runs,
// and removes spaces around structural punctuation. Quoted strings pass
// through untouched. Space before a colon is kept on purpose: ".a :hover"
// and ".a:hover" are different selectors.
fun _minify_css(css: String) -> String {
    let out = ""
    let i = 0
    let n = css.length()
    let quote = 0
    let pending = false
    while i < n {
        let b = css.byte_at(i)
        if quote != 0 {
            out = out.concat(css.substring(i, i + 1))
            if b == quote {
                quote = 0
            }
            i += 1
        } else if b == 34 || b == 39 {
            if pending && out.length() > 0 {
                out = out.concat(" ")
            }
            pending = false
            quote = b
            out = out.concat(css.substring(i, i + 1))
            i += 1
        } else if b == 47 && i + 1 < n && css.byte_at(i + 1) == 42 {
            i += 2
            while i + 1 < n && !(css.byte_at(i) == 42 && css.byte_at(i + 1) == 47) {
                i += 1
            }
            i += 2
        } else if b == 32 || b == 9 || b == 10 || b == 13 {
            pending = true
            i += 1
        } else {
            let eats_before = b == 123 || b == 125 || b == 59 || b == 44 || b == 62
            if pending && !eats_before && out.length() > 0 {
                let last = out.byte_at(out.length() - 1)
                let eats_after = last == 123 || last == 125 || last == 59 || last == 44 || last == 62 || last == 58
                if !eats_after {
                    out = out.concat(" ")
                }
            }
            pending = false
            if b == 125 && out.length() > 0 && out.byte_at(out.length() - 1) == 59 {
                out = out.substring(0, out.length() - 1)
            }
            out = out.concat(css.substring(i, i + 1))
            i += 1
        }
    }
    return out.trim()
}

// A language tag ("az", "en-US") or the reserved "x-default".
fun _valid_hreflang(value: String) -> Bool {
    return value == "x-default" || _valid_language(value)
}

fun _warn_binding(method: String, selector: String, key: String) -> String {
    return "dropped ".concat(method).concat(": invalid selector or key (selector ").concat(
        _quote_word(selector),
    ).concat(", key ").concat(_quote_word(key)).concat(")")
}

// Remove earlier fingerprinted copies of an emitted asset: files in `dir`
// matching prefix and suffix that are not the current name. Only raven-web's
// own two asset names are managed; author files are never touched.
fun _remove_stale_assets(dir: String, prefix: String, suffix: String, current: String) {
    match list_dir(dir) {
        Ok(entries) -> {
            for entry in entries {
                if entry != current && entry.starts_with(prefix) && entry.ends_with(suffix) {
                    let _ = remove_file(join(dir, entry))
                }
            }
        },
        Err(_) -> {},
    }
}

fun _valid_language(value: String) -> Bool {
    if value.length() == 0 || !_ascii_letter(value.byte_at(0)) {
        return false
    }
    let i = 1
    while i < value.length() {
        let b = value.byte_at(i)
        if !_ascii_letter(b) && !(b >= 48 && b <= 57) && b != 45 {
            return false
        }
        i += 1
    }
    return true
}

impl Page {
    // Components cross the package boundary as their rendered Node value.
    fun new(title: String, root: Node) -> Page {
        let page_warnings: List<String> = []
        let metas: List<Attribute> = []
        let meta_props: List<Attribute> = []
        let preconnects: List<Attribute> = []
        let structured: List<String> = []
        let alternates: List<Attribute> = []
        let timers: List<TimerSpec> = []
        return Page {
            title,
            root,
            styles: Stylesheet.new(),
            language: "en",
            description: "",
            favicon: "",
            files: _empty_files(),
            css_links: _empty_css_links(),
            state: _empty_state(),
            bindings: _empty_bindings(),
            persisted: _empty_persisted(),
            load_effects: _empty_effects(),
            timers,
            single_page: false,
            metas,
            meta_props,
            preconnects,
            structured,
            alternates,
            canonical_url: "",
            theme_color_value: "",
            optimize_mode: false,
            base: "",
            page_warnings,
            strict_mode: false,
        }
    }

    // Production output: minified CSS, and content-hashed names for
    // styles.css and app.js so deploys can never serve a stale asset.
    fun optimize(self) -> Page {
        self.optimize_mode = true
        return self
    }

    // Deploying under a subpath (https://user.github.io/repo/) needs the
    // prefix declared, or the SPA fallback and deep links resolve assets
    // against the wrong directory.
    fun base_path(self, path: String) -> Page {
        if !_valid_route_pattern(path) {
            self.page_warnings.push("dropped base_path: invalid path ".concat(_quote_word(path)))
            return self
        }
        let clean = _normalize_path(path)
        self.base = if clean == "/" {
            ""
        } else {
            clean
        }
        return self
    }

    // The emitted asset names: fixed by default, content-hashed under
    // optimize().
    fun css_asset_name(self) -> String {
        if !self.optimize_mode {
            return "styles.css"
        }
        return "styles.".concat(_fingerprint(self.css())).concat(".css")
    }

    fun js_asset_name(self) -> String {
        if !self.optimize_mode {
            return "app.js"
        }
        return "app.".concat(_fingerprint(self.js())).concat(".js")
    }

    // A named meta tag: meta("robots", "index, follow"). The name is checked
    // like an attribute name; the content is escaped like any attribute value.
    fun meta(self, name: String, content: String) -> Page {
        if _valid_attr_name(name) {
            self.metas.push(Attribute { name, value: content })
        } else {
            self.page_warnings.push("dropped meta: invalid name ".concat(_quote_word(name)))
        }
        return self
    }

    // A property meta tag, the Open Graph and Twitter shape:
    // meta_property("og:title", ...).
    fun meta_property(self, property: String, content: String) -> Page {
        if _valid_attr_name(property) {
            self.meta_props.push(Attribute { name: property, value: content })
        } else {
            self.page_warnings.push(
                "dropped meta_property: invalid property ".concat(_quote_word(property)),
            )
        }
        return self
    }

    // An hreflang alternate for this page's other-language versions:
    // alternate("en", "https://example.com/en/"). Use "x-default" for the
    // fallback. Multilingual sites need one per language plus a self
    // reference, or search engines pick a language arbitrarily.
    fun alternate(self, hreflang: String, url: String) -> Page {
        if !_valid_hreflang(hreflang) {
            self.page_warnings.push("dropped alternate: invalid hreflang ".concat(_quote_word(hreflang)))
            return self
        }
        if !_safe_url(url) {
            self.page_warnings.push("dropped alternate: unsafe URL ".concat(_quote_word(url)))
            return self
        }
        self.alternates.push(Attribute { name: hreflang, value: url })
        return self
    }

    // The canonical URL for this page. One per page; the last write wins.
    fun canonical(self, url: String) -> Page {
        if _safe_url(url) {
            self.canonical_url = url
        } else {
            self.page_warnings.push("dropped canonical: unsafe URL ".concat(_quote_word(url)))
        }
        return self
    }

    fun theme_color(self, value: String) -> Page {
        if _css_safe_text(value) {
            self.theme_color_value = value
        } else {
            self.page_warnings.push("dropped theme_color: invalid value ".concat(_quote_word(value)))
        }
        return self
    }

    // A preconnect hint. Set `cors` for origins fetched with CORS (font
    // files), which need the crossorigin attribute on the hint to be reused.
    fun preconnect(self, url: String, cors: Bool) -> Page {
        if _safe_url(url) {
            let flag = if cors {
                "1"
            } else {
                ""
            }
            self.preconnects.push(Attribute { name: url, value: flag })
        } else {
            self.page_warnings.push("dropped preconnect: unsafe URL ".concat(_quote_word(url)))
        }
        return self
    }

    // Structured data (JSON-LD), from a typed JsonValue. The value is
    // serialized here and every angle bracket is escaped inside the JSON, so
    // no string in the data can close the script element: it stays data.
    fun structured_data(self, value: JsonValue) -> Page {
        self.structured.push(_escape_json_for_script(stringify(value)))
        return self
    }

    // Refuse to write while any warning exists. This is what a CI build wants:
    // a dropped input fails the build instead of shipping a page that silently
    // does less than the source says.
    fun strict(self) -> Page {
        self.strict_mode = true
        return self
    }

    // Every dropped input this page knows about: its own, the view tree's, and
    // the stylesheet's. Empty means every builder call did what it said.
    fun warnings(self) -> List<String> {
        let out: List<String> = []
        for warning in self.page_warnings {
            out.push(warning)
        }
        _collect_warnings(self.root, out)
        for warning in self.styles.all_warnings() {
            out.push(warning)
        }
        return out
    }

    // Mark the page as a client-routed app, so write_static also emits 404.html
    // with the same content. Static hosts serve that for a path they have no
    // file for, which is how a deep link into a Router route survives a reload.
    fun spa(self) -> Page {
        self.single_page = true
        return self
    }

    // Declare a client state key with an initial value. Behaviors mutate it via
    // set_state/toggle_state/increment_state, and bindings reflect it to the DOM.
    fun state(self, key: String, initial: String) -> Page {
        if _css_safe_text(key) {
            self.state.push(StatePair { key, value: initial, raw: false })
        } else {
            self.page_warnings.push("dropped state declaration: invalid key ".concat(_quote_word(key)))
        }
        return self
    }

    // Register a typed Signal so its initial value reaches the client. A signal
    // made with signal_of keeps its structure rather than arriving as a quoted
    // string.
    fun signal(self, source: Signal) -> Page {
        if !_css_safe_text(source.key) {
            self.page_warnings.push(
                "dropped signal registration: invalid key ".concat(_quote_word(source.key)),
            )
            return self
        }
        self.state.push(StatePair { key: source.key, value: source.initial, raw: source.raw })
        return self
    }

    // Structured initial state, straight from a typed Raven value. This is the
    // seam the domain crosses without a fetch: the data is in the document on
    // first paint, so there is no request and no empty flash.
    fun data(self, key: String, value: JsonValue) -> Page {
        if _css_safe_text(key) {
            self.state.push(StatePair { key, value: stringify(value), raw: true })
        } else {
            self.page_warnings.push("dropped data: invalid key ".concat(_quote_word(key)))
        }
        return self
    }

    // Every binding the view declared about itself, plus any added through the
    // low-level selector API. Markers are assigned here, idempotently.
    fun all_bindings(self) -> List<Binding> {
        let counter = BindCounter { next: 0 }
        _assign_marks(self.root, counter)
        let all: List<Binding> = []
        for binding in self.bindings {
            all.push(binding)
        }
        _collect_binds(self.root, all)
        return all
    }

    fun bind_text(self, selector: String, key: String) -> Page {
        if _css_safe_text(selector) && _css_safe_text(key) {
            self.bindings.push(_binding("text", selector, key, ""))
        } else {
            self.page_warnings.push(_warn_binding("bind_text", selector, key))
        }
        return self
    }

    fun bind_class(self, selector: String, key: String, class_name: String) -> Page {
        if _css_safe_text(selector) && _css_safe_text(key) && _valid_class_token(class_name) {
            self.bindings.push(_binding("class", selector, key, class_name))
        } else {
            self.page_warnings.push(_warn_binding("bind_class", selector, key))
        }
        return self
    }

    fun bind_attr(self, selector: String, key: String, attr: String) -> Page {
        if _css_safe_text(selector) && _css_safe_text(key) && _valid_attr_name(attr) {
            self.bindings.push(_binding("attr", selector, key, attr))
        } else {
            self.page_warnings.push(_warn_binding("bind_attr", selector, key))
        }
        return self
    }

    fun bind_visible(self, selector: String, key: String) -> Page {
        if _css_safe_text(selector) && _css_safe_text(key) {
            self.bindings.push(_binding("visible", selector, key, ""))
        } else {
            self.page_warnings.push(_warn_binding("bind_visible", selector, key))
        }
        return self
    }

    // The inverse of bind_visible: hidden while state[key] is set. Lets a signed
    // out view and a signed in view key off the same value.
    fun bind_hidden(self, selector: String, key: String) -> Page {
        if _css_safe_text(selector) && _css_safe_text(key) {
            self.bindings.push(_binding("hidden", selector, key, ""))
        } else {
            self.page_warnings.push(_warn_binding("bind_hidden", selector, key))
        }
        return self
    }

    // Run `behavior` every `ms` milliseconds, starting after boot: a
    // carousel advance, a clock, or a polling fetch that keeps a list fresh.
    // Sub-100ms intervals are refused; that cadence belongs to CSS.
    fun every(self, ms: Int, behavior: Behavior) -> Page {
        for warning in behavior.warnings {
            self.page_warnings.push(warning)
        }
        if ms < 100 {
            self.page_warnings.push(
                "dropped every: intervals under 100 ms are refused (got ".concat(ms.to_string()).concat(")"),
            )
            return self
        }
        self.timers.push(TimerSpec { ms, effects: behavior.effects })
        return self
    }

    // Run `behavior` once after the page loads and persisted state is restored,
    // so a view can fetch its data without the user clicking anything.
    fun on_load(self, behavior: Behavior) -> Page {
        for warning in behavior.warnings {
            self.page_warnings.push(warning)
        }
        for effect in behavior.effects {
            self.load_effects.push(effect)
        }
        return self
    }

    // Render `template` once per item in the array at state path `key`, into
    // `selector`. Inside the template, {{field}} is replaced by that item's
    // field. Substitution goes through textContent and setAttribute, never
    // innerHTML, so item data can never inject markup.
    fun bind_list(self, selector: String, key: String, template: Node) -> Page {
        _collect_warnings(template, self.page_warnings)
        if _css_safe_text(selector) && _css_safe_text(key) {
            self.bindings.push(_binding("list", selector, key, template.render()))
        } else {
            self.page_warnings.push(_warn_binding("bind_list", selector, key))
        }
        return self
    }

    // bind_list, but only items whose `field` equals `value` (board columns).
    fun bind_list_where(
        self,
        selector: String,
        key: String,
        template: Node,
        field: String,
        value: String,
    ) -> Page {
        _collect_warnings(template, self.page_warnings)
        if _css_safe_text(selector) && _css_safe_text(key) {
            let dep_keys: List<String> = [_root_key(key)]
            self.bindings.push(
                Binding {
                    kind: "list",
                    selector,
                    key,
                    arg: template.render(),
                    filter_field: field,
                    filter_value: value,
                    expr: "",
                    dep_keys,
                },
            )
        } else {
            self.page_warnings.push(_warn_binding("bind_list_where", selector, key))
        }
        return self
    }

    // Keep a signal in localStorage, so it survives a reload (a login token).
    fun persist(self, source: Signal) -> Page {
        return self.persist_key(source.key)
    }

    // The low-level form, for state declared with the string API.
    fun persist_key(self, key: String) -> Page {
        if _css_safe_text(key) {
            self.persisted.push(key)
        } else {
            self.page_warnings.push("dropped persist: invalid state key ".concat(_quote_word(key)))
        }
        return self
    }

    fun with_styles(self, styles: Stylesheet) -> Page {
        self.styles = styles
        return self
    }

    fun with_css(self, css: String) -> Page {
        self.styles.raw(css)
        return self
    }

    fun lang(self, value: String) -> Page {
        if _valid_language(value) {
            self.language = value
        } else {
            self.page_warnings.push("dropped lang: invalid language tag ".concat(_quote_word(value)))
        }
        return self
    }

    fun description(self, value: String) -> Page {
        self.description = value
        return self
    }

    fun favicon(self, url: String) -> Page {
        if _safe_url(url) {
            self.favicon = url
        } else {
            self.page_warnings.push("dropped favicon: unsafe URL ".concat(_quote_word(url)))
        }
        return self
    }

    fun file(self, file: StaticFile) -> Page {
        if _valid_static_path(file.path) {
            self.files.push(file)
        } else {
            self.page_warnings.push(
                "dropped static file: invalid or reserved path ".concat(_quote_word(file.path)),
            )
        }
        return self
    }

    // Write a local stylesheet and add the matching relative link tag.
    fun css_file(self, path: String, css: String) -> Page {
        match StaticFile.try_css(path, css) {
            Ok(file) -> {
                let href = _asset_href(file.path)
                self.files.push(file)
                self.css_links.push(href)
            },
            Err(reason) -> {
                self.page_warnings.push(
                    "dropped css_file ".concat(_quote_word(path)).concat(": ").concat(reason),
                )
            },
        }
        return self
    }

    fun link_stylesheet(self, url: String) -> Page {
        if _safe_url(url) {
            self.css_links.push(url)
        } else {
            self.page_warnings.push("dropped link_stylesheet: unsafe URL ".concat(_quote_word(url)))
        }
        return self
    }

    fun html(self) -> String {
        let counter = BindCounter { next: 0 }
        _assign_marks(self.root, counter)
        let q = _quote()
        let out = "<!doctype html><html lang=".concat(q).concat(_escape_html(self.language)).concat(
            q,
        ).concat("><head><meta charset=").concat(q).concat("utf-8").concat(q).concat("><meta name=").concat(
            q,
        ).concat("viewport").concat(q).concat(" content=").concat(q).concat(
            "width=device-width, initial-scale=1",
        ).concat(q).concat("><title>").concat(_escape_html(self.title)).concat("</title><link rel=").concat(
            q,
        ).concat("stylesheet").concat(q).concat(" href=").concat(q).concat(
            _escape_html(self._ref(self.css_asset_name())),
        ).concat(q).concat(">")
        if self.description.length() > 0 {
            out = out.concat("<meta name=").concat(q).concat("description").concat(q).concat(" content=").concat(
                q,
            ).concat(_escape_html(self.description)).concat(q).concat(">")
        }
        if self.favicon.length() > 0 {
            out = out.concat("<link rel=").concat(q).concat("icon").concat(q).concat(" href=").concat(q).concat(
                _escape_html(self.favicon),
            ).concat(q).concat(">")
        }
        for hint in self.preconnects {
            out = out.concat("<link rel=").concat(q).concat("preconnect").concat(q).concat(" href=").concat(
                q,
            ).concat(_escape_html(hint.name)).concat(q)
            if hint.value != "" {
                out = out.concat(" crossorigin")
            }
            out = out.concat(">")
        }
        for url in self.css_links {
            out = out.concat("<link rel=").concat(q).concat("stylesheet").concat(q).concat(" href=").concat(
                q,
            ).concat(_escape_html(url)).concat(q).concat(">")
        }
        for item in self.metas {
            out = out.concat("<meta name=").concat(q).concat(_escape_html(item.name)).concat(q).concat(
                " content=",
            ).concat(q).concat(_escape_html(item.value)).concat(q).concat(">")
        }
        for item in self.meta_props {
            out = out.concat("<meta property=").concat(q).concat(_escape_html(item.name)).concat(q).concat(
                " content=",
            ).concat(q).concat(_escape_html(item.value)).concat(q).concat(">")
        }
        if self.canonical_url != "" {
            out = out.concat("<link rel=").concat(q).concat("canonical").concat(q).concat(" href=").concat(
                q,
            ).concat(_escape_html(self.canonical_url)).concat(q).concat(">")
        }
        for alt in self.alternates {
            out = out.concat("<link rel=").concat(q).concat("alternate").concat(q).concat(" hreflang=").concat(
                q,
            ).concat(_escape_html(alt.name)).concat(q).concat(" href=").concat(q).concat(
                _escape_html(alt.value),
            ).concat(q).concat(">")
        }
        if self.theme_color_value != "" {
            out = out.concat("<meta name=").concat(q).concat("theme-color").concat(q).concat(" content=").concat(
                q,
            ).concat(_escape_html(self.theme_color_value)).concat(q).concat(">")
        }
        for blob in self.structured {
            out = out.concat("<script type=").concat(q).concat("application/ld+json").concat(q).concat(">").concat(
                blob,
            ).concat("</script>")
        }
        return out.concat("</head><body>").concat(self.root.render()).concat("<script src=").concat(
            q,
        ).concat(_escape_html(self._ref(self.js_asset_name()))).concat(q).concat(
            " defer></script></body></html>",
        )
    }

    fun css(self) -> String {
        if self.optimize_mode {
            return _minify_css(self.styles.render())
        }
        return self.styles.render()
    }

    fun js(self) -> String {
        return "window.RW_INIT=".concat(
            _serialize_config(
                self.state,
                self.all_bindings(),
                self.persisted,
                self.load_effects,
                self.timers,
                self.base,
            ),
        ).concat(";").concat(_render_runtime())
    }

    // An emitted asset reference: relative by default (so pages in
    // subdirectories work), absolute under a base path (so the SPA fallback
    // resolves them from any URL).
    fun _ref(self, name: String) -> String {
        if self.base == "" {
            return name
        }
        return self.base.concat("/").concat(name)
    }

    fun write_static(self, dir: String) -> Result<StaticOutput, Error> {
        // Dropped inputs surface at the build boundary: printed always, fatal
        // under strict(). This is the loud end of the infallible builder API.
        let warns = self.warnings()
        for warning in warns {
            println("raven-web warning: ".concat(warning))
        }
        if self.strict_mode && warns.len() > 0 {
            return Err(
                Error {
                    kind: "raven-web",
                    message: "strict page has ".concat(warns.len().to_string()).concat(
                        " warning(s); first: ",
                    ).concat(warns.get(0)),
                },
            )
        }
        let _created = create_dir_all(dir)?
        let paths: List<String> = []
        let css_name = self.css_asset_name()
        let js_name = self.js_asset_name()
        // Under optimize the names carry a content hash, so earlier hashes
        // in the same directory are dead files: remove them, or dev rebuilds
        // accumulate one stale pair per edit.
        if self.optimize_mode {
            _remove_stale_assets(dir, "styles.", ".css", css_name)
            _remove_stale_assets(dir, "app.", ".js", js_name)
        }
        let _html = write(join(dir, "index.html"), self.html())?
        paths.push("index.html")
        let _css = write(join(dir, css_name), self.css())?
        paths.push(css_name)
        let _js = write(join(dir, js_name), self.js())?
        paths.push(js_name)
        // A client router owns paths the host has no file for. Most static
        // hosts serve 404.html for an unknown path, so shipping the app there
        // makes a deep link resolve instead of dying.
        if self.single_page {
            let _fallback = write(join(dir, "404.html"), self.html())?
            paths.push("404.html")
        }
        for file in self.files {
            if _valid_static_path(file.path) {
                let parent = dirname(file.path)
                if parent != "." {
                    let _parent = create_dir_all(join(dir, parent))?
                }
                let _file = write(join(dir, file.path), file.contents)?
                paths.push(file.path)
            }
        }
        return Ok(StaticOutput { directory: dir, paths })
    }
}

// A shared shell (header, footer, styles, metadata) that wraps each page body
// into a complete Page, so a multi-page site keeps one consistent chrome.
struct Layout {
    header: Node,
    footer: Node,
    styles: Stylesheet,
    description: String,
    language: String,
}

impl Layout {
    fun new() -> Layout {
        return Layout {
            header: Node.fragment(),
            footer: Node.fragment(),
            styles: Stylesheet.new(),
            description: "",
            language: "en",
        }
    }

    fun header(self, node: Node) -> Layout {
        self.header = node
        return self
    }

    fun footer(self, node: Node) -> Layout {
        self.footer = node
        return self
    }

    fun with_styles(self, styles: Stylesheet) -> Layout {
        self.styles = styles
        return self
    }

    fun description(self, value: String) -> Layout {
        self.description = value
        return self
    }

    fun lang(self, value: String) -> Layout {
        self.language = value
        return self
    }

    fun wrap(self, title: String, body: Node) -> Page {
        let shell = Node.fragment().child(self.header).child(body).child(self.footer)
        return Page.new(title, shell).lang(self.language).description(self.description).with_styles(
            self.styles,
        )
    }
}

struct Route {
    path: String,
    page: Page,
    // W3C date ("2026-07-16") for the sitemap's lastmod; empty means omitted.
    lastmod: String,
}

struct SiteOutput {
    directory: String,
    routes: List<String>,
}

impl SiteOutput {
    fun directory(self) -> String {
        return self.directory
    }

    fun routes(self) -> List<String> {
        return self.routes
    }

    fun page_count(self) -> Int {
        return self.routes.len()
    }

    fun contains(self, path: String) -> Bool {
        for item in self.routes {
            if item == path {
                return true
            }
        }
        return false
    }
}

// A set of routes written as a static site. Each route becomes a clean-URL
// directory (`/about` to `about/index.html`); write_static also emits a
// sitemap.xml and a 404.html.
struct Site {
    base_url: String,
    routes: List<Route>,
    missing: Option<Page>,
}

fun _normalize_route(path: String) -> String {
    let p = path.trim()
    while p.starts_with("/") {
        p = p.substring(1, p.length())
    }
    while p.ends_with("/") {
        p = p.substring(0, p.length() - 1)
    }
    return p
}

fun _join_url(base: String, path: String) -> String {
    let b = base
    while b.ends_with("/") {
        b = b.substring(0, b.length() - 1)
    }
    if path == "" {
        return b.concat("/")
    }
    return b.concat("/").concat(path).concat("/")
}

// A W3C sitemap date: digits and hyphens shaped like 2026-07-16 (a full
// datetime also passes: digits, hyphens, colons, T, Z, plus, dot).
fun _valid_w3c_date(value: String) -> Bool {
    if value.length() < 10 {
        return false
    }
    let i = 0
    while i < value.length() {
        let b = value.byte_at(i)
        let ok = (b >= 48 && b <= 57) || b == 45 || b == 58 || b == 84 || b == 90 || b == 43 || b == 46
        if !ok {
            return false
        }
        i += 1
    }
    return true
}

fun _default_not_found() -> Page {
    return Page.new(
        "Page not found",
        Node.main_node().child(Node.h1().child_text("404")).child(
            Node.p().child_text("This page could not be found."),
        ),
    )
}

fun _sitemap(base_url: String, routes: List<Route>) -> String {
    let q = _quote()
    let out = "<?xml version=".concat(q).concat("1.0").concat(q).concat(" encoding=").concat(q).concat(
        "UTF-8",
    ).concat(q).concat("?>")
    out = out.concat("<urlset xmlns=").concat(q).concat(
        "http://www.sitemaps.org/schemas/sitemap/0.9",
    ).concat(q).concat(">")
    for route in routes {
        out = out.concat("<url><loc>").concat(_escape_html(_join_url(base_url, route.path))).concat(
            "</loc>",
        )
        if route.lastmod != "" {
            out = out.concat("<lastmod>").concat(_escape_html(route.lastmod)).concat("</lastmod>")
        }
        out = out.concat("</url>")
    }
    return out.concat("</urlset>")
}

impl Site {
    fun new(base_url: String) -> Site {
        let routes: List<Route> = []
        return Site { base_url, routes, missing: None }
    }

    fun page(self, path: String, page: Page) -> Site {
        self.routes.push(Route { path: _normalize_route(path), page, lastmod: "" })
        return self
    }

    // Stamp the route added most recently with a last-modified date for the
    // sitemap: site.page("/blog/hello", post).lastmod("2026-07-16").
    fun lastmod(self, date: String) -> Site {
        if self.routes.len() == 0 {
            return self
        }
        if !_valid_w3c_date(date) {
            return self
        }
        let last = self.routes.get(self.routes.len() - 1)
        last.lastmod = date
        return self
    }

    fun not_found(self, page: Page) -> Site {
        self.missing = Some(page)
        return self
    }

    fun write_static(self, dir: String) -> Result<SiteOutput, Error> {
        let _created = create_dir_all(dir)?
        let written: List<String> = []
        for route in self.routes {
            let target = if route.path == "" {
                dir
            } else {
                join(dir, route.path)
            }
            let _out = route.page.write_static(target)?
            if route.path == "" {
                written.push("/")
            } else {
                written.push("/".concat(route.path).concat("/"))
            }
        }
        let _map = write(join(dir, "sitemap.xml"), _sitemap(self.base_url, self.routes))?
        let not_found = match self.missing {
            Some(page) -> page,
            None -> _default_not_found(),
        }
        let _nf = write(join(dir, "404.html"), not_found.html())?
        return Ok(SiteOutput { directory: dir, routes: written })
    }
}

// A client route: the pattern that selects it and the view it shows. A guard
// names a signal that must be truthy, and where to send the visitor if it is
// not.
struct RouteView {
    pattern: String,
    view: Node,
    guard_key: String,
    guard_to: String,
}

// A client-side router. Every route's view is rendered once at build time; the
// runtime shows the one whose pattern matches the address and hides the rest,
// so navigation changes no document and reloads nothing. State survives a
// navigation, which is the point: a fetched list stays fetched.
//
//   let router = Router.new().route("/", home).route("/tasks/:id", detail).route(
//       "/settings", settings,
//   ).requires(auth, "/login").not_found(missing)
//
//   Page.new("App", router.to_node()).spa()
//
// A pattern segment written `:name` matches one segment and binds it, readable
// as `router.param("name")`. Params live under the reserved state key `route`.
struct Router {
    routes: List<RouteView>,
    missing: Option<Node>,
    // Dropped routes and guards, carried into the Node built by to_node().
    warnings: List<String>,
}

impl Router {
    fun new() -> Router {
        let routes: List<RouteView> = []
        let warnings: List<String> = []
        return Router { routes, missing: None, warnings }
    }

    // Add a route. An invalid pattern is dropped, like every other builder here;
    // try_route reports it instead.
    fun route(self, pattern: String, view: Node) -> Router {
        if _valid_route_pattern(pattern) {
            self.routes.push(
                RouteView { pattern: _normalize_path(pattern), view, guard_key: "", guard_to: "" },
            )
        } else {
            self.warnings.push(
                "dropped route: invalid pattern ".concat(_quote_word(pattern)).concat(
                    "; its view is not reachable",
                ),
            )
        }
        return self
    }

    fun try_route(self, pattern: String, view: Node) -> Result<Router, String> {
        if !_valid_route_pattern(pattern) {
            return Err("invalid route pattern: ".concat(pattern))
        }
        return Ok(self.route(pattern, view))
    }

    // Guard the route added most recently: if `source` is falsy when the route
    // matches, the runtime redirects to `redirect_to` instead of showing it.
    // This is a convenience, not a security boundary; the data still has to be
    // protected by the server.
    fun requires(self, source: Signal, redirect_to: String) -> Router {
        if self.routes.len() == 0 {
            self.warnings.push("dropped guard: requires() was called before any route")
            return self
        }
        if !_valid_route_pattern(redirect_to) {
            self.warnings.push("dropped guard: invalid redirect path ".concat(_quote_word(redirect_to)))
            return self
        }
        let last = self.routes.get(self.routes.len() - 1)
        last.guard_key = source.path
        last.guard_to = _normalize_path(redirect_to)
        return self
    }

    fun not_found(self, view: Node) -> Router {
        self.missing = Some(view)
        return self
    }

    // A route parameter, read like any other signal.
    fun param(self, name: String) -> Signal {
        return Signal { key: "route", path: "route.".concat(name), initial: "", raw: false }
    }

    // A query-string parameter (?tab=general), read like any other signal.
    fun query(self, name: String) -> Signal {
        return query_param(name)
    }

    fun route_count(self) -> Int {
        return self.routes.len()
    }

    // Every route view, wrapped in a container the runtime shows or hides. The
    // containers are hidden at build time so no route flashes before the
    // runtime picks one.
    fun to_node(self) -> Node {
        let out = Node.fragment()
        for warning in self.warnings {
            out.warnings.push(warning)
        }
        for item in self.routes {
            // tabindex -1 keeps the container out of the tab order while still
            // letting the runtime move focus here on a navigation, which is
            // what tells a screen reader the view changed.
            let holder = Node.div().attr("data-rw-route", item.pattern).attr("hidden", "hidden").attr(
                "tabindex",
                "-1",
            ).child(item.view)
            if item.guard_key != "" {
                let _ = holder.attr("data-rw-guard", _guard_json(item.guard_key, item.guard_to))
            }
            let _ = out.child(holder)
        }
        match self.missing {
            Some(view) -> {
                let _ = out.child(
                    Node.div().attr("data-rw-route", "*").attr("hidden", "hidden").attr("tabindex", "-1").child(
                        view,
                    ),
                )
            },
            None -> {},
        }
        return out
    }
}

fun _guard_json(key: String, to: String) -> String {
    return "{".concat(_js_string("k")).concat(":").concat(_js_string(key)).concat(",").concat(
        _js_string("to"),
    ).concat(":").concat(_js_string(to)).concat("}")
}

// A query-string parameter as a typed signal. Query values live under the
// reserved state key "query", parsed by the runtime on load and on every
// navigation, so bindings react to them like any other state. Works with or
// without a Router.
fun query_param(name: String) -> Signal {
    return Signal { key: "query", path: "query.".concat(name), initial: "", raw: false }
}

// Router paths keep their leading slash (they are matched against
// location.pathname) and drop a trailing one, so "/about/" and "/about" are the
// same route. "/" is left alone.
fun _normalize_path(path: String) -> String {
    let p = path.trim()
    if !p.starts_with("/") {
        p = "/".concat(p)
    }
    while p.ends_with("/") && p.length() > 1 {
        p = p.substring(0, p.length() - 1)
    }
    return p
}

// A pattern is an absolute path of literal segments and `:name` captures.
fun _valid_route_pattern(pattern: String) -> Bool {
    if !pattern.starts_with("/") || pattern.length() > 512 {
        return false
    }
    if pattern.contains(" ") || pattern.contains("\"") || pattern.contains("<") || pattern.contains(
        ">",
    ) || pattern.contains("?") || pattern.contains("#") {
        return false
    }
    for segment in pattern.split("/") {
        if segment.starts_with(":") && segment.length() < 2 {
            return false
        }
    }
    return true
}

struct ThemeToken {
    name: String,
    light: String,
    dark: String,
}

// A design-token theme. Tokens are emitted as CSS custom properties so authors
// reference var(--color-bg) instead of hand-writing color strings. Light values
// are the default; dark values apply under prefers-color-scheme and under an
// explicit data-theme attribute (which a Behavior can set for a manual toggle).
struct Theme {
    tokens: List<ThemeToken>,
    // Dropped tokens, carried into the Stylesheet built by stylesheet().
    warnings: List<String>,
}

fun _valid_token_name(name: String) -> Bool {
    if name.length() == 0 || !_ascii_letter(name.byte_at(0)) {
        return false
    }
    let i = 1
    while i < name.length() {
        let b = name.byte_at(i)
        if !_ascii_letter(b) && !(b >= 48 && b <= 57) && b != 45 {
            return false
        }
        i += 1
    }
    return true
}

fun _theme_vars(tokens: List<ThemeToken>, use_dark: Bool) -> String {
    let out = ""
    for token in tokens {
        let value = if use_dark {
            token.dark
        } else {
            token.light
        }
        out = out.concat("--").concat(token.name).concat(":").concat(value).concat(";")
    }
    return out
}

fun theme() -> Theme {
    let tokens: List<ThemeToken> = []
    let warnings: List<String> = []
    return Theme { tokens, warnings }
}

impl Theme {
    fun new() -> Theme {
        return theme()
    }

    // A raw design token, emitted as the custom property --<name>.
    fun token(self, name: String, light: String, dark: String) -> Theme {
        if !_valid_token_name(name) {
            self.warnings.push("dropped theme token: invalid name ".concat(_quote_word(name)))
            return self
        }
        if !_css_safe_text(light) || !_css_safe_text(dark) {
            self.warnings.push("dropped theme token ".concat(_quote_word(name)).concat(": invalid value"))
            return self
        }
        self.tokens.push(ThemeToken { name, light, dark })
        return self
    }

    // A color token, prefixed color- by convention: color("bg", ...) is --color-bg.
    fun color(self, name: String, light: String, dark: String) -> Theme {
        return self.token("color-".concat(name), light, dark)
    }

    // A mode-independent token (spacing, radius, type scale).
    fun scale(self, name: String, value: String) -> Theme {
        return self.token(name, value, value)
    }

    fun css(self) -> String {
        let light = _theme_vars(self.tokens, false)
        let dark = _theme_vars(self.tokens, true)
        let out = ":root{".concat(light).concat("}")
        out = out.concat("@media (prefers-color-scheme:dark){:root{").concat(dark).concat("}}")
        out = out.concat(":root[data-theme=dark]{").concat(dark).concat("}")
        return out.concat(":root[data-theme=light]{").concat(light).concat("}")
    }

    fun stylesheet(self) -> Stylesheet {
        let out = Stylesheet.new().raw(self.css())
        for warning in self.warnings {
            out.warnings.push(warning)
        }
        return out
    }
}

// ===== The content pipeline =====
//
// Markdown, frontmatter, collections, and feeds, so a content site is
// first-class. Markdown renders through the same safe Node builders as
// everything else: text is escaped, URLs are judged by scheme, and raw HTML
// in a document is text, not markup. The dialect is a deliberate subset of
// CommonMark: ATX headings, paragraphs, fenced code, blockquotes, flat
// bullet and numbered lists, horizontal rules, emphasis, strong, inline
// code, links, images, and backslash escapes. No raw HTML passthrough (by
// design), no tables, no footnotes, no reference links, no nested lists.

// One content file: frontmatter keys, the body below them, and where it
// came from. `slug` is the file name without its extension.
struct Document {
    slug: String,
    path: String,
    meta: Map<String, String>,
    body: String,
}

impl Document {
    fun get(self, key: String) -> String {
        return self.meta.get_or(key, "")
    }

    fun get_or(self, key: String, default: String) -> String {
        return self.meta.get_or(key, default)
    }

    // The body, rendered. A convenience for the common case.
    fun html(self) -> Node {
        return markdown(self.body)
    }
}

fun _strip_value_quotes(value: String) -> String {
    let v = value.trim()
    if v.length() >= 2 && v.byte_at(0) == 34 && v.byte_at(v.length() - 1) == 34 {
        return v.substring(1, v.length() - 1)
    }
    return v
}

// Parse a document with optional frontmatter: a leading "---" line, then
// "key: value" lines (split at the first colon, so values may contain
// colons), then a closing "---". No nesting; one string value per key.
fun parse_document(source: String) -> Document {
    let meta: Map<String, String> = Map.new()
    let lines = source.split("\n")
    if lines.len() == 0 || lines.get(0).trim() != "---" {
        return Document { slug: "", path: "", meta, body: source }
    }
    let i = 1
    while i < lines.len() && lines.get(i).trim() != "---" {
        let line = lines.get(i)
        let sep = line.index_of(":")
        if sep > 0 {
            let key = line.substring(0, sep).trim()
            let value = _strip_value_quotes(line.substring(sep + 1, line.length()))
            if key != "" {
                meta.set(key, value)
            }
        }
        i += 1
    }
    if i >= lines.len() {
        // No closing fence: the whole file was a would-be header. Treat the
        // source as body so nothing silently disappears.
        let empty: Map<String, String> = Map.new()
        return Document { slug: "", path: "", meta: empty, body: source }
    }
    let body = ""
    let j = i + 1
    while j < lines.len() {
        if body != "" {
            body = body.concat("\n")
        }
        body = body.concat(lines.get(j))
        j += 1
    }
    return Document { slug: "", path: "", meta, body }
}

fun _doc_slug(path: String) -> String {
    let name = basename(path)
    if name.to_lower().ends_with(".md") {
        return name.substring(0, name.length() - 3)
    }
    return name
}

// Every .md file under `dir`, parsed, in walk order. Unreadable files are
// skipped; sort with sort_documents_desc for newest-first content.
fun load_documents(dir: String) -> List<Document> {
    let out: List<Document> = []
    match walk(dir) {
        Ok(entries) -> {
            for entry in entries {
                if entry.to_lower().ends_with(".md") {
                    match read(entry) {
                        Ok(text) -> {
                            let doc = parse_document(text)
                            doc.path = entry
                            doc.slug = _doc_slug(entry)
                            out.push(doc)
                        },
                        Err(_) -> {},
                    }
                }
            }
        },
        Err(_) -> {},
    }
    return out
}

// Sorted by a frontmatter key, descending, so ISO dates come newest first.
// Insertion sort: content lists are small and this keeps ties stable.
fun sort_documents_desc(docs: List<Document>, key: String) -> List<Document> {
    let out: List<Document> = []
    for doc in docs {
        let value = doc.get(key)
        let inserted = false
        let result: List<Document> = []
        for existing in out {
            if !inserted && existing.get(key) < value {
                result.push(doc)
                inserted = true
            }
            result.push(existing)
        }
        if !inserted {
            result.push(doc)
        }
        out = result
    }
    return out
}

// items split into pages of `size`, for pagination. A non-positive size
// yields a single page.
fun chunks<T>(items: List<T>, size: Int) -> List<List<T>> {
    let out: List<List<T>> = []
    if size <= 0 {
        out.push(items)
        return out
    }
    let current: List<T> = []
    for item in items {
        current.push(item)
        if current.len() == size {
            out.push(current)
            let next: List<T> = []
            current = next
        }
    }
    if current.len() > 0 {
        out.push(current)
    }
    return out
}

// ----- markdown -----

fun markdown(source: String) -> Node {
    let out = Node.fragment()
    let lines = source.split("\n")
    let i = 0
    while i < lines.len() {
        i = _md_block(out, lines, i)
    }
    return out
}

fun _md_all(text: String, b: Int) -> Bool {
    if text.length() == 0 {
        return false
    }
    let i = 0
    while i < text.length() {
        if text.byte_at(i) != b {
            return false
        }
        i += 1
    }
    return true
}

fun _md_is_fence(line: String) -> Bool {
    let t = line.trim()
    return t.length() >= 3 && t.byte_at(0) == 96 && t.byte_at(1) == 96 && t.byte_at(2) == 96
}

fun _md_is_bullet(line: String) -> Bool {
    return line.starts_with("- ") || line.starts_with("* ")
}

fun _md_ordered_marker(line: String) -> Int {
    let i = 0
    while i < line.length() && line.byte_at(i) >= 48 && line.byte_at(i) <= 57 {
        i += 1
    }
    if i == 0 || i + 1 >= line.length() {
        return -1
    }
    if line.byte_at(i) == 46 && line.byte_at(i + 1) == 32 {
        return i + 2
    }
    return -1
}

fun _md_heading_level(line: String) -> Int {
    let i = 0
    while i < line.length() && line.byte_at(i) == 35 {
        i += 1
    }
    if i >= 1 && i <= 6 && i < line.length() && line.byte_at(i) == 32 {
        return i
    }
    return 0
}

// Parse one block starting at `i`; append it to `out`; return the next line
// index. Always advances.
fun _md_block(out: Node, lines: List<String>, i: Int) -> Int {
    let line = lines.get(i)
    let t = line.trim()
    if t == "" {
        return i + 1
    }
    let level = _md_heading_level(t)
    if level > 0 {
        let raw = t.substring(level + 1, t.length()).trim()
        let h = Node.new("h".concat(level.to_string()))
        // A slug id lets in-page anchors and a table of contents point at the
        // heading. Empty slugs (a heading of only punctuation) are skipped.
        let slug = _md_slug(raw)
        if slug != "" {
            let _ = h.attr("id", slug)
        }
        _md_inline(h, raw)
        let _ = out.child(h)
        return i + 1
    }
    if _md_is_fence(line) {
        let info = line.trim().substring(3, line.trim().length()).trim()
        let body = ""
        let j = i + 1
        while j < lines.len() && !_md_is_fence(lines.get(j)) {
            body = body.concat(lines.get(j)).concat("\n")
            j += 1
        }
        let code = Node.code()
        if info != "" && _valid_class_token("language-".concat(info)) {
            let _ = code.class_name("language-".concat(info))
        }
        let cfg = _hl_config(info)
        if cfg.known {
            _highlight_into(code, body, cfg)
        } else {
            let _ = code.child_text(body)
        }
        let _ = out.child(Node.pre().child(code))
        return if j < lines.len() {
            j + 1
        } else {
            j
        }
    }
    if _md_all(t, 45) || _md_all(t, 42) {
        let _ = out.child(Node.hr())
        return i + 1
    }
    if t.starts_with(">") {
        let inner = ""
        let j = i
        while j < lines.len() && lines.get(j).trim().starts_with(">") {
            let stripped = lines.get(j).trim().substring(1, lines.get(j).trim().length())
            if stripped.starts_with(" ") {
                stripped = stripped.substring(1, stripped.length())
            }
            if inner != "" {
                inner = inner.concat("\n")
            }
            inner = inner.concat(stripped)
            j += 1
        }
        let _ = out.child(Node.blockquote().child(markdown(inner)))
        return j
    }
    if _md_is_bullet(line) {
        let list = Node.ul()
        let j = i
        while j < lines.len() && _md_is_bullet(lines.get(j)) {
            let item = Node.li()
            _md_inline(item, lines.get(j).substring(2, lines.get(j).length()).trim())
            let _ = list.child(item)
            j += 1
        }
        let _ = out.child(list)
        return j
    }
    if _md_ordered_marker(line) > 0 {
        let list = Node.ol()
        let j = i
        while j < lines.len() && _md_ordered_marker(lines.get(j)) > 0 {
            let start = _md_ordered_marker(lines.get(j))
            let item = Node.li()
            _md_inline(item, lines.get(j).substring(start, lines.get(j).length()).trim())
            let _ = list.child(item)
            j += 1
        }
        let _ = out.child(list)
        return j
    }
    // Paragraph: consecutive plain lines join with spaces.
    let text = t
    let j = i + 1
    while j < lines.len() {
        let peek = lines.get(j)
        let pt = peek.trim()
        let plain = pt != "" && _md_heading_level(pt) == 0 && !_md_is_fence(peek) && !_md_is_bullet(
            peek,
        ) && _md_ordered_marker(peek) < 0 && !pt.starts_with(">") && !_md_all(pt, 45) && !_md_all(pt, 42)
        if !plain {
            break
        }
        text = text.concat(" ").concat(pt)
        j += 1
    }
    let p = Node.p()
    _md_inline(p, text)
    let _ = out.child(p)
    return j
}

fun _md_find_byte(text: String, b: Int, from: Int) -> Int {
    let i = from
    while i < text.length() {
        if text.byte_at(i) == b {
            return i
        }
        i += 1
    }
    return -1
}

fun _md_find_double_star(text: String, from: Int) -> Int {
    let i = from
    while i + 1 < text.length() {
        if text.byte_at(i) == 42 && text.byte_at(i + 1) == 42 {
            return i
        }
        i += 1
    }
    return -1
}

fun _md_flush(target: Node, buf: String) -> String {
    if buf != "" {
        target.kids.push(Node.text(buf))
    }
    return ""
}

// A parsed [label](url) shape at `open` (the bracket's index), or ok=false.
struct MdLink {
    ok: Bool,
    label: String,
    url: String,
    next: Int,
}

fun _md_link_at(text: String, open: Int) -> MdLink {
    let close = _md_find_byte(text, 93, open + 1)
    if close < 0 || close + 1 >= text.length() || text.byte_at(close + 1) != 40 {
        return MdLink { ok: false, label: "", url: "", next: open }
    }
    let finish = _md_find_byte(text, 41, close + 2)
    if finish < 0 {
        return MdLink { ok: false, label: "", url: "", next: open }
    }
    return MdLink {
        ok: true,
        label: text.substring(open + 1, close),
        url: text.substring(close + 2, finish).trim(),
        next: finish + 1,
    }
}

// Inline markdown into `target`: emphasis, strong, code spans, links,
// images, backslash escapes. Unmatched markers fall through as literal
// text rather than vanishing.
fun _md_inline(target: Node, text: String) {
    let buf = ""
    let i = 0
    let n = text.length()
    while i < n {
        let b = text.byte_at(i)
        if b == 92 && i + 1 < n {
            buf = buf.concat(text.substring(i + 1, i + 2))
            i += 2
        } else if b == 96 {
            let close = _md_find_byte(text, 96, i + 1)
            if close < 0 {
                buf = buf.concat("`")
                i += 1
            } else {
                buf = _md_flush(target, buf)
                let _ = target.child(Node.code().child_text(text.substring(i + 1, close)))
                i = close + 1
            }
        } else if b == 42 && i + 1 < n && text.byte_at(i + 1) == 42 {
            let close = _md_find_double_star(text, i + 2)
            if close < 0 {
                buf = buf.concat("**")
                i += 2
            } else {
                buf = _md_flush(target, buf)
                let strong = Node.strong()
                _md_inline(strong, text.substring(i + 2, close))
                let _ = target.child(strong)
                i = close + 2
            }
        } else if b == 42 {
            let close = _md_find_byte(text, 42, i + 1)
            if close < 0 {
                buf = buf.concat("*")
                i += 1
            } else {
                buf = _md_flush(target, buf)
                let em = Node.em()
                _md_inline(em, text.substring(i + 1, close))
                let _ = target.child(em)
                i = close + 1
            }
        } else if b == 33 && i + 1 < n && text.byte_at(i + 1) == 91 {
            let link = _md_link_at(text, i + 1)
            if link.ok {
                buf = _md_flush(target, buf)
                let _ = target.child(Node.image(link.url, link.label))
                i = link.next
            } else {
                buf = buf.concat("!")
                i += 1
            }
        } else if b == 91 {
            let link = _md_link_at(text, i)
            if link.ok {
                buf = _md_flush(target, buf)
                let a = Node.new("a").href(link.url)
                _md_inline(a, link.label)
                let _ = target.child(a)
                i = link.next
            } else {
                buf = buf.concat("[")
                i += 1
            }
        } else {
            buf = buf.concat(text.substring(i, i + 1))
            i += 1
        }
    }
    let _ = _md_flush(target, buf)
}

// ----- feeds -----

// One Atom entry. `date` is an ISO date ("2026-07-16") or full RFC 3339
// timestamp; a bare date gains midnight UTC on the way out.
struct FeedEntry {
    title: String,
    url: String,
    date: String,
    summary: String,
}

fun _rfc3339(date: String) -> String {
    if date.length() == 10 {
        return date.concat("T00:00:00Z")
    }
    return date
}

// An Atom feed (RFC 4287), which takes the same ISO dates frontmatter uses.
// Serve it via Page.file: page.file(StaticFile.new("feed.xml", atom_feed(...))).
fun atom_feed(
    title: String,
    site_url: String,
    feed_url: String,
    updated: String,
    entries: List<FeedEntry>,
) -> String {
    let q = _quote()
    let out = "<?xml version=".concat(q).concat("1.0").concat(q).concat(" encoding=").concat(q).concat(
        "UTF-8",
    ).concat(q).concat("?>")
    out = out.concat("<feed xmlns=").concat(q).concat("http://www.w3.org/2005/Atom").concat(q).concat(
        ">",
    )
    out = out.concat("<title>").concat(_escape_html(title)).concat("</title>")
    out = out.concat("<link href=").concat(q).concat(_escape_html(site_url)).concat(q).concat("/>")
    out = out.concat("<link rel=").concat(q).concat("self").concat(q).concat(" href=").concat(q).concat(
        _escape_html(feed_url),
    ).concat(q).concat("/>")
    out = out.concat("<id>").concat(_escape_html(site_url)).concat("</id>")
    out = out.concat("<updated>").concat(_escape_html(_rfc3339(updated))).concat("</updated>")
    for entry in entries {
        out = out.concat("<entry>")
        out = out.concat("<title>").concat(_escape_html(entry.title)).concat("</title>")
        out = out.concat("<link href=").concat(q).concat(_escape_html(entry.url)).concat(q).concat("/>")
        out = out.concat("<id>").concat(_escape_html(entry.url)).concat("</id>")
        out = out.concat("<updated>").concat(_escape_html(_rfc3339(entry.date))).concat("</updated>")
        if entry.summary != "" {
            out = out.concat("<summary>").concat(_escape_html(entry.summary)).concat("</summary>")
        }
        out = out.concat("</entry>")
    }
    return out.concat("</feed>")
}

// ===== transitions and syntax highlighting =====

// A reduced-motion-safe default for Node.transition(): elements fade, and a
// visitor who asked for less motion gets an instant swap. Add it to the page
// styles, or write your own rule against `[data-rw-trans].rw-hidden`.
fun transition_styles() -> Stylesheet {
    let css = "[data-rw-trans].rw-hidden{opacity:0;visibility:hidden;}@media (prefers-reduced-motion: no-preference){[data-rw-trans]{transition:opacity 200ms ease, visibility 0s linear 200ms;}[data-rw-trans]:not(.rw-hidden){transition:opacity 200ms ease, visibility 0s;}}"
    return Stylesheet.new().raw(css)
}

// A dark token theme for highlight() output. The classes are tok-kw,
// tok-str, tok-com, tok-num; override them to match your design.
fun syntax_styles() -> Stylesheet {
    let css = ".tok-kw{color:#c792ea;}.tok-str{color:#c3e88d;}.tok-com{color:#8b93b8;font-style:italic;}.tok-num{color:#f78c6c;}"
    return Stylesheet.new().raw(css)
}

// How to tokenize one language.
struct HlConfig {
    known: Bool,
    slash: Bool,
    hash: Bool,
    block: Bool,
    backtick: Bool,
    keywords: List<String>,
}

fun _hl_none() -> HlConfig {
    let kw: List<String> = []
    return HlConfig {
        known: false,
        slash: false,
        hash: false,
        block: false,
        backtick: false,
        keywords: kw,
    }
}

fun _hl_c_family(keywords: List<String>, backtick: Bool) -> HlConfig {
    return HlConfig { known: true, slash: true, hash: false, block: true, backtick, keywords }
}

fun _hl_config(lang: String) -> HlConfig {
    let l = lang.to_lower()
    if l == "raven" || l == "rv" {
        return _hl_c_family(
            [
                "fun",
                "let",
                "return",
                "if",
                "else",
                "while",
                "for",
                "in",
                "match",
                "struct",
                "enum",
                "impl",
                "import",
                "true",
                "false",
                "self",
                "spawn",
                "Int",
                "String",
                "Bool",
                "Node",
                "List",
            ],
            false,
        )
    }
    if l == "rust" || l == "rs" {
        return _hl_c_family(
            [
                "fn",
                "let",
                "mut",
                "return",
                "if",
                "else",
                "while",
                "for",
                "in",
                "match",
                "struct",
                "enum",
                "impl",
                "trait",
                "use",
                "pub",
                "self",
                "true",
                "false",
                "async",
                "await",
                "move",
                "ref",
                "where",
                "type",
                "const",
                "static",
            ],
            false,
        )
    }
    if l == "js" || l == "javascript" || l == "ts" || l == "typescript" {
        return _hl_c_family(
            [
                "function",
                "let",
                "const",
                "var",
                "return",
                "if",
                "else",
                "while",
                "for",
                "of",
                "in",
                "switch",
                "case",
                "class",
                "extends",
                "import",
                "export",
                "from",
                "new",
                "this",
                "true",
                "false",
                "null",
                "undefined",
                "async",
                "await",
                "typeof",
                "interface",
                "type",
            ],
            true,
        )
    }
    if l == "go" {
        return _hl_c_family(
            [
                "func",
                "var",
                "const",
                "return",
                "if",
                "else",
                "for",
                "range",
                "switch",
                "case",
                "struct",
                "interface",
                "type",
                "package",
                "import",
                "map",
                "chan",
                "go",
                "defer",
                "true",
                "false",
                "nil",
            ],
            true,
        )
    }
    if l == "c" || l == "cpp" || l == "c++" || l == "java" {
        return _hl_c_family(
            [
                "int",
                "char",
                "void",
                "return",
                "if",
                "else",
                "while",
                "for",
                "switch",
                "case",
                "struct",
                "class",
                "public",
                "private",
                "static",
                "const",
                "new",
                "this",
                "true",
                "false",
                "null",
            ],
            false,
        )
    }
    if l == "python" || l == "py" {
        return HlConfig {
            known: true,
            slash: false,
            hash: true,
            block: false,
            backtick: false,
            keywords: [
                "def",
                "return",
                "if",
                "elif",
                "else",
                "while",
                "for",
                "in",
                "class",
                "import",
                "from",
                "as",
                "with",
                "try",
                "except",
                "finally",
                "lambda",
                "True",
                "False",
                "None",
                "and",
                "or",
                "not",
                "pass",
                "yield",
                "async",
                "await",
            ],
        }
    }
    if l == "bash" || l == "sh" || l == "shell" {
        return HlConfig {
            known: true,
            slash: false,
            hash: true,
            block: false,
            backtick: false,
            keywords: [
                "if",
                "then",
                "else",
                "elif",
                "fi",
                "for",
                "in",
                "do",
                "done",
                "while",
                "case",
                "esac",
                "function",
                "return",
                "export",
                "local",
            ],
        }
    }
    return _hl_none()
}

fun _hl_word_char(b: Int) -> Bool {
    return _ascii_letter(b) || (b >= 48 && b <= 57) || b == 95
}

fun _hl_is_keyword(word: String, keywords: List<String>) -> Bool {
    for kw in keywords {
        if kw == word {
            return true
        }
    }
    return false
}

fun _hl_span(code: Node, cls: String, text: String) {
    let _ = code.child(Node.span().class_name(cls).child_text(text))
}

// Syntax-highlight `source` into `code`: comments, strings, numbers, and
// keywords become classed spans; everything else is escaped text. All text,
// span or plain, passes through the escaping builders, so highlighting can
// never inject markup.
fun _highlight_into(code: Node, source: String, cfg: HlConfig) {
    let buf = ""
    let i = 0
    let n = source.length()
    while i < n {
        let b = source.byte_at(i)
        if cfg.block && b == 47 && i + 1 < n && source.byte_at(i + 1) == 42 {
            if buf != "" {
                let _ = code.child_text(buf)
                buf = ""
            }
            let start = i
            i += 2
            while i + 1 < n && !(source.byte_at(i) == 42 && source.byte_at(i + 1) == 47) {
                i += 1
            }
            i = i + 2
            if i > n {
                i = n
            }
            _hl_span(code, "tok-com", source.substring(start, i))
        } else if (cfg.slash && b == 47 && i + 1 < n && source.byte_at(i + 1) == 47) || (cfg.hash && b == 35) {
            if buf != "" {
                let _ = code.child_text(buf)
                buf = ""
            }
            let start = i
            while i < n && source.byte_at(i) != 10 {
                i += 1
            }
            _hl_span(code, "tok-com", source.substring(start, i))
        } else if b == 34 || b == 39 || (cfg.backtick && b == 96) {
            if buf != "" {
                let _ = code.child_text(buf)
                buf = ""
            }
            let quote = b
            let start = i
            i += 1
            while i < n && source.byte_at(i) != quote {
                if source.byte_at(i) == 92 {
                    i += 1
                }
                i += 1
            }
            i += 1
            if i > n {
                i = n
            }
            _hl_span(code, "tok-str", source.substring(start, i))
        } else if b >= 48 && b <= 57 && !(i > 0 && _hl_word_char(source.byte_at(i - 1))) {
            if buf != "" {
                let _ = code.child_text(buf)
                buf = ""
            }
            let start = i
            while i < n && (source.byte_at(i) >= 48 && source.byte_at(i) <= 57 || source.byte_at(i) == 46 || (source.byte_at(
                i,
            ) >= 97 && source.byte_at(i) <= 102) || (source.byte_at(i) >= 65 && source.byte_at(i) <= 70) || source.byte_at(
                i,
            ) == 120) {
                i += 1
            }
            _hl_span(code, "tok-num", source.substring(start, i))
        } else if _ascii_letter(b) || b == 95 {
            let start = i
            while i < n && _hl_word_char(source.byte_at(i)) {
                i += 1
            }
            let word = source.substring(start, i)
            if _hl_is_keyword(word, cfg.keywords) {
                if buf != "" {
                    let _ = code.child_text(buf)
                    buf = ""
                }
                _hl_span(code, "tok-kw", word)
            } else {
                buf = buf.concat(word)
            }
        } else {
            buf = buf.concat(source.substring(i, i + 1))
            i += 1
        }
    }
    if buf != "" {
        let _ = code.child_text(buf)
    }
}

// Highlight a standalone snippet into a <code> node. Markdown fenced blocks
// call this automatically when the info string names a known language.
fun highlight(source: String, lang: String) -> Node {
    let code = Node.code()
    if _valid_class_token("language-".concat(lang)) {
        let _ = code.class_name("language-".concat(lang))
    }
    let cfg = _hl_config(lang)
    if cfg.known {
        _highlight_into(code, source, cfg)
    } else {
        let _ = code.child_text(source)
    }
    return code
}

// ===== i18n =====
//
// The typed multi-language pattern proven on real sites: declare a locale
// set once, then localize each page. localize() sets the lang, the canonical
// URL, and the full hreflang alternate set (every locale plus x-default) in
// one call, so a multilingual site stops hand-wiring SEO per page. Each
// locale is served as its own path prefix ("" for the root language, "en"
// for /en/), which is exactly what Site.page expects.

struct Locale {
    code: String,
    prefix: String,
}

struct I18n {
    site_url: String,
    locales: List<Locale>,
    default_index: Int,
}

fun i18n(site_url: String) -> I18n {
    let locales: List<Locale> = []
    return I18n { site_url, locales, default_index: 0 }
}

fun _strip_slashes(value: String) -> String {
    let v = value.trim()
    while v.starts_with("/") {
        v = v.substring(1, v.length())
    }
    while v.ends_with("/") {
        v = v.substring(0, v.length() - 1)
    }
    return v
}

impl I18n {
    // The root language, served at "/". Call once; the first default wins.
    fun default_locale(self, code: String) -> I18n {
        self.locales.push(Locale { code, prefix: "" })
        self.default_index = self.locales.len() - 1
        return self
    }

    // Another language, served under "/<prefix>/" (e.g. locale("en", "en")).
    fun locale(self, code: String, prefix: String) -> I18n {
        self.locales.push(Locale { code, prefix: _strip_slashes(prefix) })
        return self
    }

    fun all(self) -> List<Locale> {
        return self.locales
    }

    // The Site route for a page at `subpath` in `locale`: "/", "/about",
    // "/en", "/en/about". Pass this to Site.page.
    fun route(self, locale: Locale, subpath: String) -> String {
        let sub = _strip_slashes(subpath)
        let parts: List<String> = []
        if locale.prefix != "" {
            parts.push(locale.prefix)
        }
        if sub != "" {
            parts.push(sub)
        }
        if parts.len() == 0 {
            return "/"
        }
        let out = ""
        for part in parts {
            out = out.concat("/").concat(part)
        }
        return out
    }

    // The clean canonical URL for `subpath` in `locale`, matching what Site
    // emits (a trailing slash on every route).
    fun url(self, locale: Locale, subpath: String) -> String {
        let base = self.site_url
        while base.ends_with("/") {
            base = base.substring(0, base.length() - 1)
        }
        let route = self.route(locale, subpath)
        if route == "/" {
            return base.concat("/")
        }
        return base.concat(route).concat("/")
    }

    fun _default(self) -> Locale {
        return self.locales.get(self.default_index)
    }

    // Set the page's lang, canonical URL, and hreflang alternates (every
    // locale plus x-default) for `subpath` in `locale`. One call does the
    // SEO wiring a multilingual page needs.
    fun localize(self, page: Page, locale: Locale, subpath: String) -> Page {
        let out = page.lang(locale.code).canonical(self.url(locale, subpath))
        for other in self.locales {
            let _ = out.alternate(other.code, self.url(other, subpath))
        }
        return out.alternate("x-default", self.url(self._default(), subpath))
    }
}

// ----- markdown headings, slugs, and a table of contents -----

// One heading found in a markdown source.
struct Heading {
    level: Int,
    text: String,
    slug: String,
}

// A GitHub-style slug: lowercase, spaces to single hyphens, only letters,
// digits, and hyphens kept, no leading or trailing hyphen. Runs of separators
// collapse.
fun _md_slug(text: String) -> String {
    let plain = _md_strip(text).to_lower()
    let out = ""
    let prev_dash = true
    let i = 0
    while i < plain.length() {
        let b = plain.byte_at(i)
        if (b >= 97 && b <= 122) || (b >= 48 && b <= 57) {
            out = out.concat(plain.substring(i, i + 1))
            prev_dash = false
        } else if b == 32 || b == 45 || b == 95 {
            if !prev_dash {
                out = out.concat("-")
                prev_dash = true
            }
        }
        i += 1
    }
    while out.ends_with("-") {
        out = out.substring(0, out.length() - 1)
    }
    return out
}

// Strip inline markdown to plain text: emphasis, strong, code spans, link
// and image syntax, and backslash escapes. Used for slugs and TOC labels.
fun _md_strip(text: String) -> String {
    let out = ""
    let i = 0
    let n = text.length()
    while i < n {
        let b = text.byte_at(i)
        if b == 92 && i + 1 < n {
            out = out.concat(text.substring(i + 1, i + 2))
            i += 2
        } else if b == 96 || b == 42 || b == 95 {
            i += 1
        } else if b == 33 && i + 1 < n && text.byte_at(i + 1) == 91 {
            i += 1
        } else if b == 91 {
            i += 1
        } else if b == 93 {
            // Drop the following (url) of a link, if present.
            if i + 1 < n && text.byte_at(i + 1) == 40 {
                let close = _md_find_byte(text, 41, i + 2)
                if close >= 0 {
                    i = close + 1
                } else {
                    i += 1
                }
            } else {
                i += 1
            }
        } else {
            out = out.concat(text.substring(i, i + 1))
            i += 1
        }
    }
    return out.trim()
}

// Every ATX heading in `source`, in document order, with its level, plain
// text, and slug. Headings inside fenced code blocks are skipped.
fun headings(source: String) -> List<Heading> {
    let out: List<Heading> = []
    let lines = source.split("\n")
    let in_fence = false
    let i = 0
    while i < lines.len() {
        let line = lines.get(i)
        if _md_is_fence(line) {
            in_fence = !in_fence
        } else if !in_fence {
            let t = line.trim()
            let level = _md_heading_level(t)
            if level > 0 {
                let raw = t.substring(level + 1, t.length()).trim()
                out.push(Heading { level, text: _md_strip(raw), slug: _md_slug(raw) })
            }
        }
        i += 1
    }
    return out
}

// A table of contents for `source`: a <nav class="toc"> holding one link per
// heading, indented by level with a data-level attribute so CSS can style the
// hierarchy. Headings from `min_level` to `max_level` inclusive are included
// (2 to 3 is a common choice: skip the h1 title, list sections). A heading
// with an empty slug is skipped, since it has no anchor to point at.
fun table_of_contents(source: String, min_level: Int, max_level: Int) -> Node {
    let nav = Node.nav().class_name("toc").attr("aria-label", "Table of contents")
    let list = Node.ul()
    for heading in headings(source) {
        if heading.level >= min_level && heading.level <= max_level && heading.slug != "" {
            let item = Node.li().attr("data-level", heading.level.to_string()).child(
                Node.link(heading.text, "#".concat(heading.slug)),
            )
            let _ = list.child(item)
        }
    }
    return nav.child(list)
}
