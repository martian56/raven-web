// raven-web: safe browser artifacts for Raven.

import std/json { JsonValue, stringify }
import std/fs { basename, create_dir_all, dirname, join, list_dir, read, remove_file, walk, write }
import std/error { Error }
import std/io { println }
import std/hash { fnv1a }

struct Attribute {
    name: String,
    value: String,
}

// A typed handle to one piece of client state. Declare it once with `signal`,
// then pass the value everywhere: views bind to it and behaviors write to it
// without naming a CSS selector or repeating a state string. `key` is the root
// state key; `path` is what a reader resolves (the same, or deeper via `at`).
struct Signal {
    key: String,
    path: String,
    initial: String,
    // True when `initial` is already JSON (an object, array, or number) rather
    // than a plain string that has to be quoted on the way out.
    raw: Bool,
}

fun signal(name: String, initial: String) -> Signal {
    return Signal { key: name, path: name, initial, raw: false }
}

// A signal seeded with structured data. This is how a typed Raven value reaches
// the client without a fetch: derive ToJson on your domain type and hand it
// over, and the list is already there on first paint.
//
//   let tasks = signal_of("tasks", board.to_json())
//   Node.ul().each_of(tasks, row())
fun signal_of(name: String, initial: JsonValue) -> Signal {
    return Signal { key: name, path: name, initial: stringify(initial), raw: true }
}

impl Signal {
    // Read a field of a stored JSON value: auth.at("token") reads auth.token.
    // Writes still target the root key, so `at` is for reading.
    fun at(self, field: String) -> Signal {
        return Signal {
            key: self.key,
            path: self.path.concat(".").concat(field),
            initial: "",
            raw: false,
        }
    }
}

// Component scoping.
//
// A component is an ordinary Raven function that takes its props as typed
// parameters and a Ctx, and returns a Node. Its props are therefore checked by
// the compiler like any other call. `Ctx.local` gives the instance its own
// state: raven-web allocates a scope id per instance at build time and
// namespaces the key, so the same component used twice has two independent
// pieces of state without the author naming either.
//
//   fun counter(ctx: Ctx, label: String) -> Node {
//       let n = ctx.local("n", "0")
//       return Node.div().child(Node.span().text_of(n)).child(
//           Node.button("+").on_click(Behavior.new().increment(n, 1)))
//   }
//
//   let ui = app()
//   let view = Node.div().child(counter(ui.instance(), "A")).child(counter(ui.instance(), "B"))
//   return ui.page("Counters", view)
//
// Call `instance()` once per component instance. Two components handed the same
// Ctx deliberately share its state; that is how a parent hands a child a signal
// it already owns.
//
// Instances are allocated while the tree is built, so a component is expanded at
// build time. A stateful component cannot yet be repeated per item of a
// runtime-fetched list; list rows remain {{field}} templates.
struct Scope {
    states: List<StatePair>,
    next: Int,
}

struct Ctx {
    scope: Scope,
    id: String,
}

// The root scope for a page.
fun app() -> Ctx {
    let states: List<StatePair> = []
    return Ctx { scope: Scope { states, next: 0 }, id: "r" }
}

impl Ctx {
    // A fresh instance scope. Call once per component instance, including for
    // components nested inside another component.
    fun instance(self) -> Ctx {
        let id = "c".concat(self.scope.next.to_string())
        self.scope.next = self.scope.next + 1
        return Ctx { scope: self.scope, id }
    }

    // State private to this instance. The returned Signal is used exactly like a
    // global one; only its key is scoped.
    fun local(self, name: String, initial: String) -> Signal {
        let key = self.id.concat("_").concat(name)
        self.scope.states.push(StatePair { key, value: initial, raw: false })
        return signal(key, initial)
    }

    // A DOM id unique to this instance. Accessible markup has to point at
    // elements by id (aria-controls, aria-describedby, label for), and a
    // component used twice on a page cannot hard-code one without colliding.
    //
    //   let panel = ctx.id_for("panel")
    //   Node.button(title).attr("aria-controls", panel).aria_if(open, "expanded")
    //   Node.div().id(panel).visible_if(open)
    fun id_for(self, name: String) -> String {
        return self.id.concat("_").concat(name)
    }

    // Instance state seeded with structured data, so a component can be handed
    // a typed value as its starting point.
    fun local_of(self, name: String, initial: JsonValue) -> Signal {
        let key = self.id.concat("_").concat(name)
        let source = signal_of(key, initial)
        self.scope.states.push(StatePair { key, value: source.initial, raw: true })
        return source
    }

    // Build the page, registering every local declared during the tree build.
    fun page(self, title: String, view: Node) -> Page {
        let page = Page.new(title, view)
        for pair in self.scope.states {
            // Carried over whole: a local made with local_of is already JSON and
            // must not be re-quoted on the way out.
            page.state.push(StatePair { key: pair.key, value: pair.value, raw: pair.raw })
        }
        return page
    }
}

// A computed expression over signals. Raven has no operator overloading, so the
// DSL is function calls: Expr.gt(Expr.len(tasks), Expr.num(0)). It compiles to a
// small data tree that the runtime evaluates; nothing is ever eval'd, so the CSP
// and safety model hold. Dependencies are derived from the tree, so a binding
// built from an expression updates when any signal it reads changes.
enum Expr {
    Sig(String),
    Str(String),
    Num(Int),
    Bool(Bool),
    Not(Expr),
    Len(Expr),
    IsEmpty(Expr),
    Eq(Expr, Expr),
    Ne(Expr, Expr),
    Gt(Expr, Expr),
    Lt(Expr, Expr),
    And(Expr, Expr),
    Or(Expr, Expr),
    Add(Expr, Expr),
    Sub(Expr, Expr),
    Concat(Expr, Expr),
    Matches(Expr, String),
    Ternary(Expr, Expr, Expr),
}

impl Expr {
    // Read a signal (or a path into one, via Signal.at).
    fun of(source: Signal) -> Expr = Expr.Sig(source.path)

    fun text(value: String) -> Expr = Expr.Str(value)

    fun int(value: Int) -> Expr = Expr.Num(value)

    fun flag(value: Bool) -> Expr = Expr.Bool(value)

    fun not(inner: Expr) -> Expr = Expr.Not(inner)

    // Length of a string or array.
    fun len(inner: Expr) -> Expr = Expr.Len(inner)

    fun is_empty(inner: Expr) -> Expr = Expr.IsEmpty(inner)

    fun eq(left: Expr, right: Expr) -> Expr = Expr.Eq(left, right)

    fun ne(left: Expr, right: Expr) -> Expr = Expr.Ne(left, right)

    fun gt(left: Expr, right: Expr) -> Expr = Expr.Gt(left, right)

    fun lt(left: Expr, right: Expr) -> Expr = Expr.Lt(left, right)

    fun and(left: Expr, right: Expr) -> Expr = Expr.And(left, right)

    fun or(left: Expr, right: Expr) -> Expr = Expr.Or(left, right)

    fun add(left: Expr, right: Expr) -> Expr = Expr.Add(left, right)

    fun sub(left: Expr, right: Expr) -> Expr = Expr.Sub(left, right)

    fun concat(left: Expr, right: Expr) -> Expr = Expr.Concat(left, right)

    // True when the value matches the regular expression. The pattern is
    // authored, never taken from user input, and is compiled by the runtime as
    // a RegExp: it is data, not code, so nothing is eval'd. An invalid pattern
    // matches nothing rather than throwing.
    fun matches(value: Expr, pattern: String) -> Expr = Expr.Matches(value, pattern)

    fun ternary(cond: Expr, then_value: Expr, else_value: Expr) -> Expr {
        return Expr.Ternary(cond, then_value, else_value)
    }
}

fun _serialize_expr(e: Expr) -> String {
    return match e {
        Sig(path) -> _op2("sig", path),
        Str(value) -> _op2("str", value),
        Num(value) -> "[".concat(_js_string("num")).concat(",").concat(value.to_string()).concat(
            "]",
        ),
        Bool(value) -> {
            let flag = if value {
                "true"
            } else {
                "false"
            }
            "[".concat(_js_string("bool")).concat(",").concat(flag).concat("]")
        },
        Not(inner) -> _expr1("not", inner),
        Len(inner) -> _expr1("len", inner),
        IsEmpty(inner) -> _expr1("empty", inner),
        Eq(left, right) -> _expr2("eq", left, right),
        Ne(left, right) -> _expr2("ne", left, right),
        Gt(left, right) -> _expr2("gt", left, right),
        Lt(left, right) -> _expr2("lt", left, right),
        And(left, right) -> _expr2("and", left, right),
        Or(left, right) -> _expr2("or", left, right),
        Add(left, right) -> _expr2("add", left, right),
        Sub(left, right) -> _expr2("sub", left, right),
        Concat(left, right) -> _expr2("cat", left, right),
        Matches(value, pattern) -> "[".concat(_js_string("re")).concat(",").concat(
            _serialize_expr(value),
        ).concat(",").concat(_js_string(pattern)).concat("]"),
        Ternary(cond, a, b) -> "[".concat(_js_string("if")).concat(",").concat(
            _serialize_expr(cond),
        ).concat(",").concat(_serialize_expr(a)).concat(",").concat(_serialize_expr(b)).concat("]"),
    }
}

fun _expr1(code: String, inner: Expr) -> String {
    return "[".concat(_js_string(code)).concat(",").concat(_serialize_expr(inner)).concat("]")
}

fun _expr2(code: String, left: Expr, right: Expr) -> String {
    return "[".concat(_js_string(code)).concat(",").concat(_serialize_expr(left)).concat(",").concat(
        _serialize_expr(right),
    ).concat("]")
}

// Every root state key the expression reads, so the binding subscribes to all
// of them.
fun _expr_keys(e: Expr, out: List<String>) {
    match e {
        Sig(path) -> {
            let key = _root_key(path)
            if !_contains_str(out, key) {
                out.push(key)
            }
        },
        Str(_) -> {},
        Num(_) -> {},
        Bool(_) -> {},
        Not(inner) -> _expr_keys(inner, out),
        Len(inner) -> _expr_keys(inner, out),
        IsEmpty(inner) -> _expr_keys(inner, out),
        Matches(value, _) -> _expr_keys(value, out),
        Eq(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Ne(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Gt(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Lt(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        And(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Or(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Add(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Sub(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Concat(left, right) -> {
            _expr_keys(left, out)
            _expr_keys(right, out)
        },
        Ternary(cond, a, b) -> {
            _expr_keys(cond, out)
            _expr_keys(a, out)
            _expr_keys(b, out)
        },
    }
}

// A binding a node declares about itself. The element is identified by a marker
// raven-web assigns at render time, so no selector is ever written by hand.
struct NodeBind {
    kind: String,
    path: String,
    arg: String,
    filter_field: String,
    filter_value: String,
    expr: String,
    dep_keys: List<String>,
}

fun _node_bind(kind: String, path: String, arg: String) -> NodeBind {
    let dep_keys: List<String> = [_root_key(path)]
    return NodeBind {
        kind,
        path,
        arg,
        filter_field: "",
        filter_value: "",
        expr: "",
        dep_keys,
    }
}

// A binding whose value is computed from an expression rather than read from a
// single path. It depends on every signal the expression reads.
fun _node_bind_expr(kind: String, value: Expr, arg: String) -> NodeBind {
    let dep_keys: List<String> = []
    _expr_keys(value, dep_keys)
    return NodeBind {
        kind,
        path: "",
        arg,
        filter_field: "",
        filter_value: "",
        expr: _serialize_expr(value),
        dep_keys,
    }
}

struct Node {
    tag: String,
    value: String,
    attrs: List<Attribute>,
    kids: List<Node>,
    binds: List<NodeBind>,
    mark: Int,
    // A rejected element. It renders as nothing at all, subtree included: an
    // element that is refused because it executes code must not leave that code
    // behind as page text.
    dropped: Bool,
    // One line per input this node dropped. Page.warnings() collects them from
    // the whole tree, and write_static prints them, so a silent drop is still
    // safe but no longer invisible.
    warnings: List<String>,
}

fun _node(tag: String) -> Node {
    let attrs: List<Attribute> = []
    let kids: List<Node> = []
    let binds: List<NodeBind> = []
    let warnings: List<String> = []
    return Node { tag, value: "", attrs, kids, binds, mark: -1, dropped: false, warnings }
}

fun _dropped_node(reason: String) -> Node {
    let attrs: List<Attribute> = []
    let kids: List<Node> = []
    let binds: List<NodeBind> = []
    let warnings: List<String> = [reason]
    return Node { tag: "", value: "", attrs, kids, binds, mark: -1, dropped: true, warnings }
}
fun _text_node(value: String) -> Node {
    let attrs: List<Attribute> = []
    let kids: List<Node> = []
    let binds: List<NodeBind> = []
    let warnings: List<String> = []
    return Node { tag: "", value, attrs, kids, binds, mark: -1, dropped: false, warnings }
}

fun _quote_word(value: String) -> String {
    return _quote().concat(value).concat(_quote())
}

// The tag as a warning names it: "<div>" for an element, "a text node" or "a
// fragment" for the tagless kinds, so a message always says where it happened.
fun _describe_node(node: Node) -> String {
    if node.tag == "" {
        if node.value == "" {
            return "a fragment"
        }
        return "a text node"
    }
    return "<".concat(node.tag).concat(">")
}

fun _quote() -> String {
    return stringify(JsonValue.Str("")).substring(0, 1)
}

fun _escape_html(value: String) -> String {
    return value.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;").replace(
        _quote(),
        "&quot;",
    ).replace("'", "&#39;")
}

fun _ascii_letter(b: Int) -> Bool {
    return (b >= 65 && b <= 90) || (b >= 97 && b <= 122)
}

// Letters, digits, hyphen, underscore: the character set of tag, attribute,
// and meta names. Underscore is legal in attribute and meta-property names
// (og:site_name, article:published_time) and carries no execution risk; the
// executable checks are by name, not by character.
fun _name_char(b: Int) -> Bool {
    return _ascii_letter(b) || (b >= 48 && b <= 57) || b == 45 || b == 95
}

// Elements that run code or hand the page to someone else. raven-web owns the
// page's JavaScript, so none of these can be authored: <script> would take a
// raw JS string, <base> would repoint every relative URL, <meta http-equiv>
// would redirect, and the framing and plugin elements load foreign documents
// that execute on their own. Head metadata and styles are Page's job (`Page`
// emits its own meta/link, and `Stylesheet` carries CSS), so nothing legitimate
// needs them here.
fun _dangerous_tag(tag: String) -> Bool {
    return tag == "script" || tag == "base" || tag == "meta" || tag == "link" || tag == "style" || tag == "iframe" || tag == "frame" || tag == "frameset" || tag == "object" || tag == "embed" || tag == "applet" || tag == "portal" || tag == "noembed" || tag == "noscript"
}

fun _valid_tag(tag: String) -> Bool {
    if tag.length() == 0 || !_ascii_letter(tag.byte_at(0)) {
        return false
    }
    let i = 1
    while i < tag.length() {
        if !_name_char(tag.byte_at(i)) {
            return false
        }
        i += 1
    }
    return !_dangerous_tag(tag.to_lower())
}

// Attributes whose value is a URL the browser will follow. The typed builders
// (link, image, href, src) already check these; this is what makes the raw
// attr() escape hatch check them too.
fun _url_attr(name: String) -> Bool {
    return name == "href" || name == "src" || name == "action" || name == "formaction" || name == "xlink:href" || name == "data" || name == "poster" || name == "cite" || name == "ping" || name == "manifest" || name == "longdesc" || name == "background"
}

// Attributes that inject markup or behaviour rather than naming a URL, so there
// is no safe value to allow.
fun _executable_attr(name: String) -> Bool {
    return name.starts_with("on") || name == "style" || name == "srcdoc" || name == "http-equiv"
}

// A DOM key name: letters and digits only ("Escape", "Enter", "ArrowDown",
// "a", "Space"). Long enough for every named key, short enough to be a name.
fun _valid_key_name(value: String) -> Bool {
    if value.length() == 0 || value.length() > 20 {
        return false
    }
    let i = 0
    while i < value.length() {
        let b = value.byte_at(i)
        if !_ascii_letter(b) && !(b >= 48 && b <= 57) {
            return false
        }
        i += 1
    }
    return true
}

fun _valid_attr_name(name: String) -> Bool {
    if name.length() == 0 || !_ascii_letter(name.byte_at(0)) {
        return false
    }
    let i = 1
    while i < name.length() {
        let b = name.byte_at(i)
        if !_name_char(b) && b != 58 {
            return false
        }
        i += 1
    }
    return !_executable_attr(name.to_lower())
}

fun _void_tag(tag: String) -> Bool {
    return tag == "area" || tag == "base" || tag == "br" || tag == "col" || tag == "embed" || tag == "hr" || tag == "img" || tag == "input" || tag == "link" || tag == "meta" || tag == "param" || tag == "source" || tag == "track" || tag == "wbr"
}

// A DOM event an element can react to. The name maps to the delegated event the
// generated runtime listens for. focus/blur and mouseenter/leave map to their
// bubbling equivalents so a single document-level listener can dispatch them.
enum Event {
    Click,
    Input,
    Change,
    Submit,
    KeyDown,
    KeyUp,
    Focus,
    Blur,
    MouseEnter,
    MouseLeave,
    Scroll,
}

impl Event {
    fun name(self) -> String {
        return match self {
            Click -> "click",
            Input -> "input",
            Change -> "change",
            Submit -> "submit",
            KeyDown -> "keydown",
            KeyUp -> "keyup",
            Focus -> "focusin",
            Blur -> "focusout",
            MouseEnter -> "mouseover",
            MouseLeave -> "mouseout",
            Scroll -> "scroll",
        }
    }
}

impl Node {
    // Infallible: an invalid tag yields a fragment (its children still render,
    // the element wrapper is dropped), matching how attr and href silently
    // reject unsafe input. Use try_new to detect an invalid tag.
    fun new(tag: String) -> Node {
        if !_valid_tag(tag) {
            return _dropped_node(
                "dropped element ".concat(_quote_word(tag)).concat(
                    ": invalid or unsafe tag name; the element and its subtree render as nothing",
                ),
            )
        }
        return _node(tag.to_lower())
    }

    fun try_new(tag: String) -> Result<Node, String> {
        if !_valid_tag(tag) {
            return Err("invalid HTML tag")
        }
        return Ok(_node(tag.to_lower()))
    }

    fun text(value: String) -> Node {
        return _text_node(value)
    }

    fun fragment() -> Node {
        return _node("")
    }

    fun div() -> Node {
        return _node("div")
    }

    fun section() -> Node {
        return _node("section")
    }

    fun article() -> Node {
        return _node("article")
    }

    fun header() -> Node {
        return _node("header")
    }

    fun footer() -> Node {
        return _node("footer")
    }

    fun nav() -> Node {
        return _node("nav")
    }

    fun main_node() -> Node {
        return _node("main")
    }

    fun aside() -> Node {
        return _node("aside")
    }

    fun form() -> Node {
        return _node("form")
    }

    fun label() -> Node {
        return _node("label")
    }

    fun table() -> Node {
        return _node("table")
    }

    fun thead() -> Node {
        return _node("thead")
    }

    fun tbody() -> Node {
        return _node("tbody")
    }

    fun tr() -> Node {
        return _node("tr")
    }

    fun th() -> Node {
        return _node("th")
    }

    fun td() -> Node {
        return _node("td")
    }

    fun dl() -> Node {
        return _node("dl")
    }

    fun dt() -> Node {
        return _node("dt")
    }

    fun dd() -> Node {
        return _node("dd")
    }

    fun strong() -> Node {
        return _node("strong")
    }

    fun small() -> Node {
        return _node("small")
    }

    fun time() -> Node {
        return _node("time")
    }

    fun code() -> Node {
        return _node("code")
    }

    fun h1() -> Node {
        return _node("h1")
    }

    fun h2() -> Node {
        return _node("h2")
    }

    fun p() -> Node {
        return _node("p")
    }

    fun span() -> Node {
        return _node("span")
    }

    fun ul() -> Node {
        return _node("ul")
    }

    fun li() -> Node {
        return _node("li")
    }

    fun button(label: String) -> Node {
        return _node("button").attr("type", "button").child_text(label)
    }

    fun submit_button(label: String) -> Node {
        return _node("button").attr("type", "submit").child_text(label)
    }

    fun input_field(placeholder: String) -> Node {
        return _node("input").attr("type", "text").attr("placeholder", placeholder)
    }

    fun textarea(placeholder: String) -> Node {
        return _node("textarea").attr("placeholder", placeholder)
    }

    fun checkbox() -> Node {
        return _node("input").attr("type", "checkbox")
    }

    fun select() -> Node {
        return _node("select")
    }

    fun option(label: String, value: String) -> Node {
        return _node("option").attr("value", value).child_text(label)
    }

    fun link(label: String, url: String) -> Node {
        return _node("a").href(url).child_text(label)
    }

    // Images are lazy and async by default, the class norm; a hero image
    // should call eager() to opt out and take fetch priority instead.
    fun image(url: String, alt: String) -> Node {
        return _node("img").src(url).attr("alt", alt).attr("loading", "lazy").attr(
            "decoding",
            "async",
        )
    }

    // image with intrinsic dimensions, which is what prevents layout shift:
    // the browser reserves the box before the file arrives.
    fun image_sized(url: String, alt: String, width: Int, height: Int) -> Node {
        let out = Node.image(url, alt)
        if width > 0 && height > 0 {
            return out.attr("width", width.to_string()).attr("height", height.to_string())
        }
        out.warnings.push(
            "dropped image dimensions on ".concat(_quote_word(url)).concat(
                ": width and height must be positive",
            ),
        )
        return out
    }

    fun figure() -> Node {
        return _node("figure")
    }

    fun figcaption() -> Node {
        return _node("figcaption")
    }

    fun blockquote() -> Node {
        return _node("blockquote")
    }

    fun details() -> Node {
        return _node("details")
    }

    // A native dialog. Open it with Behavior.open_dialog: the browser
    // supplies the focus trap, Escape handling, and the backdrop.
    fun dialog() -> Node {
        return _node("dialog")
    }

    fun summary() -> Node {
        return _node("summary")
    }

    fun pre() -> Node {
        return _node("pre")
    }

    fun em() -> Node {
        return _node("em")
    }

    fun mark() -> Node {
        return _node("mark")
    }

    fun hr() -> Node {
        return _node("hr")
    }

    fun br() -> Node {
        return _node("br")
    }

    fun ol() -> Node {
        return _node("ol")
    }

    fun h3() -> Node {
        return _node("h3")
    }

    fun h4() -> Node {
        return _node("h4")
    }

    fun fieldset() -> Node {
        return _node("fieldset")
    }

    fun legend() -> Node {
        return _node("legend")
    }

    fun optgroup(label: String) -> Node {
        return _node("optgroup").attr("label", label)
    }

    fun radio(name: String, value: String) -> Node {
        return _node("input").attr("type", "radio").attr("name", name).attr("value", value)
    }

    fun number_field(placeholder: String) -> Node {
        return _node("input").attr("type", "number").attr("placeholder", placeholder)
    }

    fun email_field(placeholder: String) -> Node {
        return _node("input").attr("type", "email").attr("placeholder", placeholder)
    }

    fun password_field(placeholder: String) -> Node {
        return _node("input").attr("type", "password").attr("placeholder", placeholder)
    }

    fun search_field(placeholder: String) -> Node {
        return _node("input").attr("type", "search").attr("placeholder", placeholder)
    }

    // A fragment whose child is `node` only when `cond` holds, otherwise an
    // empty fragment that renders nothing. Lets a component include optional
    // structure inline without an if expression around the whole tree.
    fun when(cond: Bool, node: Node) -> Node {
        if cond {
            return _node("").child(node)
        }
        return _node("")
    }

    // A fragment of `build(item)` for each item, in order. The mapper is an
    // ordinary Raven closure, so components stay declarative instead of
    // building an intermediate list with a manual loop.
    fun each<T>(items: List<T>, build: fun(T) -> Node) -> Node {
        let out = _node("")
        for item in items {
            out.kids.push(build(item))
        }
        return out
    }
}

impl Node {
    // Invalid or executable-looking attributes are ignored rather than
    // emitted. CSS utility classes are ordinary class values and pass through.
    // Setting an attribute twice must not emit it twice: an HTML parser keeps
    // the first copy and silently drops the rest, so a second write would be a
    // no-op. `class` accumulates, which is what a caller adding a class to a
    // component's own markup means; every other attribute is replaced, so the
    // last write wins.
    fun attr(self, name: String, value: String) -> Node {
        if !_valid_attr_name(name) {
            self.warnings.push(
                "dropped attribute ".concat(_quote_word(name)).concat(" on ").concat(_describe_node(self)).concat(
                    ": invalid or executable attribute name",
                ),
            )
            return self
        }
        // A URL attribute set through the raw escape hatch is checked exactly
        // like one set through link() or image(); otherwise attr("href",
        // "javascript:...") would walk straight past the safety the typed
        // builders provide.
        if _url_attr(name.to_lower()) && !_safe_url(value) {
            self.warnings.push(
                "dropped attribute ".concat(_quote_word(name)).concat(" on ").concat(_describe_node(self)).concat(
                    ": unsafe URL ",
                ).concat(_quote_word(value)),
            )
            return self
        }
        for existing in self.attrs {
            if existing.name == name {
                if name == "class" {
                    existing.value = _merge_classes(existing.value, value)
                } else {
                    existing.value = value
                }
                return self
            }
        }
        self.attrs.push(Attribute { name, value })
        return self
    }

    fun id(self, value: String) -> Node {
        return self.attr("id", value)
    }

    fun class_name(self, value: String) -> Node {
        return self.attr("class", value)
    }

    fun title(self, value: String) -> Node {
        return self.attr("title", value)
    }

    // A link that navigates a Router without reloading. It keeps a real href, so
    // it still opens in a new tab, middle-clicks, and is crawlable; only a plain
    // click is intercepted.
    fun route_link(text: String, path: String) -> Node {
        if !_valid_route_pattern(path) {
            let out = Node.fragment()
            out.warnings.push(
                "dropped route_link ".concat(_quote_word(text)).concat(": invalid route path ").concat(
                    _quote_word(path),
                ),
            )
            return out
        }
        let clean = _normalize_path(path)
        return Node.link(text, clean).attr("data-rw-link", clean)
    }

    fun name(self, value: String) -> Node {
        return self.attr("name", value)
    }

    fun value(self, value: String) -> Node {
        return self.attr("value", value)
    }

    fun placeholder(self, value: String) -> Node {
        return self.attr("placeholder", value)
    }

    fun data(self, name: String, value: String) -> Node {
        return self.attr("data-".concat(name), value)
    }

    fun aria(self, name: String, value: String) -> Node {
        return self.attr("aria-".concat(name), value)
    }

    fun disabled(self, value: Bool) -> Node {
        if value {
            return self.attr("disabled", "disabled")
        }
        return self
    }

    // Bind a typed Behavior to an event. The behavior is serialized into a
    // data attribute the generated runtime reads and interprets; the author
    // never writes JavaScript, and the value is escaped like any attribute.
    fun on(self, event: Event, behavior: Behavior) -> Node {
        for warning in behavior.warnings {
            self.warnings.push(warning)
        }
        return self.attr("data-rw-".concat(event.name()), _serialize_behavior(behavior))
    }

    fun on_click(self, behavior: Behavior) -> Node {
        return self.on(Event.Click, behavior)
    }

    fun on_input(self, behavior: Behavior) -> Node {
        return self.on(Event.Input, behavior)
    }

    fun on_change(self, behavior: Behavior) -> Node {
        return self.on(Event.Change, behavior)
    }

    fun on_submit(self, behavior: Behavior) -> Node {
        return self.on(Event.Submit, behavior)
    }

    fun on_key_down(self, behavior: Behavior) -> Node {
        return self.on(Event.KeyDown, behavior)
    }

    // A keydown that only fires for one key: on_key("Escape", close). Key
    // names are the DOM's (Escape, Enter, ArrowDown, a); "Space" is accepted
    // for the space bar.
    fun on_key(self, key: String, behavior: Behavior) -> Node {
        if !_valid_key_name(key) {
            self.warnings.push(
                "dropped on_key on ".concat(_describe_node(self)).concat(": invalid key name ").concat(
                    _quote_word(key),
                ),
            )
            return self
        }
        behavior.key = key
        return self.on(Event.KeyDown, behavior)
    }

    fun on_key_up(self, behavior: Behavior) -> Node {
        return self.on(Event.KeyUp, behavior)
    }

    fun on_focus(self, behavior: Behavior) -> Node {
        return self.on(Event.Focus, behavior)
    }

    fun on_blur(self, behavior: Behavior) -> Node {
        return self.on(Event.Blur, behavior)
    }

    fun on_mouse_enter(self, behavior: Behavior) -> Node {
        return self.on(Event.MouseEnter, behavior)
    }

    fun on_mouse_leave(self, behavior: Behavior) -> Node {
        return self.on(Event.MouseLeave, behavior)
    }

    fun child(self, node: Node) -> Node {
        self.kids.push(node)
        return self
    }

    fun children(self, nodes: List<Node>) -> Node {
        for node in nodes {
            self.kids.push(node)
        }
        return self
    }

    // Append `node` only when `cond` holds. Keeps optional children inline in a
    // build chain instead of splitting the tree around an if expression.
    fun child_when(self, cond: Bool, node: Node) -> Node {
        if cond {
            self.kids.push(node)
        }
        return self
    }

    // Append `build(item)` for each item, in order. Replaces the common
    // pattern of building a List<Node> with a manual loop before `.children`.
    fun child_each<T>(self, items: List<T>, build: fun(T) -> Node) -> Node {
        for item in items {
            self.kids.push(build(item))
        }
        return self
    }

    fun child_text(self, value: String) -> Node {
        self.kids.push(Node.text(value))
        return self
    }

    // The above-the-fold opt-out: load now, and ahead of other requests.
    fun eager(self) -> Node {
        return self.attr("loading", "eager").attr("fetchpriority", "high")
    }

    // Add one candidate to the srcset: srcset_add(url, 640) appends
    // "url 640w". Call once per variant, then set sizes().
    fun srcset_add(self, url: String, width: Int) -> Node {
        if !_safe_url(url) {
            self.warnings.push(
                "dropped srcset candidate on ".concat(_describe_node(self)).concat(": unsafe URL ").concat(
                    _quote_word(url),
                ),
            )
            return self
        }
        if width <= 0 {
            self.warnings.push(
                "dropped srcset candidate on ".concat(_describe_node(self)).concat(
                    ": width must be positive",
                ),
            )
            return self
        }
        let entry = url.concat(" ").concat(width.to_string()).concat("w")
        for existing in self.attrs {
            if existing.name == "srcset" {
                existing.value = existing.value.concat(", ").concat(entry)
                return self
            }
        }
        return self.attr("srcset", entry)
    }

    fun sizes(self, value: String) -> Node {
        return self.attr("sizes", value)
    }

    fun href(self, url: String) -> Node {
        if _safe_url(url) {
            return self.attr("href", url)
        }
        self.warnings.push(
            "dropped href on ".concat(_describe_node(self)).concat(": unsafe URL ").concat(
                _quote_word(url),
            ),
        )
        return self
    }

    fun src(self, url: String) -> Node {
        if _safe_url(url) {
            return self.attr("src", url)
        }
        self.warnings.push(
            "dropped src on ".concat(_describe_node(self)).concat(": unsafe URL ").concat(
                _quote_word(url),
            ),
        )
        return self
    }

    // Reactive bindings, declared on the node itself. raven-web marks the
    // element and wires the binding, so a typo cannot silently target nothing:
    // the signal is a value the compiler checks, not a string it cannot see.
    fun text_of(self, source: Signal) -> Node {
        self.binds.push(_node_bind("text", source.path, ""))
        return self
    }

    // A controlled field: the signal is the value. Typing writes the signal and
    // writing the signal updates the field, so validation is just an Expr over
    // it. A checkbox models as "1" or "".
    //
    // Only a whole signal can be modelled. A field path (auth.at("token")) is a
    // read-only view, so it is rejected rather than silently failing to write.
    fun bind_value(self, source: Signal) -> Node {
        if source.key != source.path {
            self.warnings.push(
                "dropped bind_value on ".concat(_describe_node(self)).concat(
                    ": cannot model the field path ",
                ).concat(_quote_word(source.path)).concat("; bind the whole signal ").concat(
                    _quote_word(source.key),
                ),
            )
            return self
        }
        self.binds.push(_node_bind("value", source.path, ""))
        return self.attr("data-rw-model", source.key)
    }

    fun try_bind_value(self, source: Signal) -> Result<Node, String> {
        if source.key != source.path {
            return Err("cannot model a field path: ".concat(source.path))
        }
        return Ok(self.bind_value(source))
    }

    // Disable the control while the expression is true, so a submit button can
    // turn itself off until the form is valid.
    fun disabled_when(self, cond: Expr) -> Node {
        self.binds.push(_node_bind_expr("disabled", cond, ""))
        return self
    }

    fun class_of(self, source: Signal, class_name: String) -> Node {
        if _valid_class_token(class_name) {
            self.binds.push(_node_bind("class", source.path, class_name))
        } else {
            self.warnings.push(
                "dropped class_of on ".concat(_describe_node(self)).concat(": invalid class token ").concat(
                    _quote_word(class_name),
                ),
            )
        }
        return self
    }

    fun attr_of(self, source: Signal, name: String) -> Node {
        if _valid_attr_name(name) {
            self.binds.push(_node_bind("attr", source.path, name))
        } else {
            self.warnings.push(
                "dropped attr_of on ".concat(_describe_node(self)).concat(
                    ": invalid or executable attribute name ",
                ).concat(_quote_word(name)),
            )
        }
        return self
    }

    fun visible_if(self, source: Signal) -> Node {
        self.binds.push(_node_bind("visible", source.path, ""))
        return self
    }

    // Animate this element's visibility instead of snapping it. The element
    // keeps its box and toggles the `rw-hidden` class, so author CSS owns the
    // transition (opacity, transform). Pair with transition_styles() for a
    // reduced-motion-safe default, or write your own rule against
    // `[data-rw-trans].rw-hidden`. Best for fades, not layout collapse.
    fun transition(self) -> Node {
        return self.attr("data-rw-trans", "")
    }

    fun hidden_if(self, source: Signal) -> Node {
        self.binds.push(_node_bind("hidden", source.path, ""))
        return self
    }

    // Bind to a computed expression instead of a single signal. This is what
    // gives conditionals and derived text: hidden_when(Expr.is_empty(tasks)) or
    // text_expr(Expr.ternary(Expr.eq(n, Expr.int(1)), Expr.text("1 task"), ...)).
    fun text_expr(self, value: Expr) -> Node {
        self.binds.push(_node_bind_expr("text", value, ""))
        return self
    }

    fun visible_when(self, cond: Expr) -> Node {
        self.binds.push(_node_bind_expr("visible", cond, ""))
        return self
    }

    fun hidden_when(self, cond: Expr) -> Node {
        self.binds.push(_node_bind_expr("hidden", cond, ""))
        return self
    }

    fun class_when(self, cond: Expr, class_name: String) -> Node {
        if _valid_class_token(class_name) {
            self.binds.push(_node_bind_expr("class", cond, class_name))
        } else {
            self.warnings.push(
                "dropped class_when on ".concat(_describe_node(self)).concat(": invalid class token ").concat(
                    _quote_word(class_name),
                ),
            )
        }
        return self
    }

    fun attr_expr(self, value: Expr, name: String) -> Node {
        if _valid_attr_name(name) {
            self.binds.push(_node_bind_expr("attr", value, name))
        } else {
            self.warnings.push(
                "dropped attr_expr on ".concat(_describe_node(self)).concat(
                    ": invalid or executable attribute name ",
                ).concat(_quote_word(name)),
            )
        }
        return self
    }

    // An ARIA state bound to a signal: aria_if(open, "expanded") keeps
    // aria-expanded correct as `open` changes.
    //
    // This exists because attr_of is the wrong tool for it. ARIA states take
    // exactly "true" or "false", while raven-web's truthiness is "1" and "", so
    // attr_of(open, "aria-expanded") writes aria-expanded="1", which is invalid
    // and leaves the control announcing as collapsed forever. Nothing errors,
    // which is what makes it worth its own method.
    fun aria_if(self, source: Signal, name: String) -> Node {
        return self.aria_bind(_node_bind("aria", source.path, "aria-".concat(name)), name)
    }

    // The same, computed: aria_when(Expr.not(Expr.of(valid)), "invalid").
    fun aria_when(self, cond: Expr, name: String) -> Node {
        return self.aria_bind(_node_bind_expr("aria", cond, "aria-".concat(name)), name)
    }

    fun aria_bind(self, bind: NodeBind, name: String) -> Node {
        if _valid_attr_name("aria-".concat(name)) {
            self.binds.push(bind)
        } else {
            self.warnings.push(
                "dropped aria binding on ".concat(_describe_node(self)).concat(": invalid ARIA state name ").concat(
                    _quote_word(name),
                ),
            )
        }
        return self
    }

    // Repeat `template` once per item of the array in `source`. The template is
    // rendered to a string here, so its warnings are carried over before the
    // tree is gone.
    fun each_of(self, source: Signal, template: Node) -> Node {
        _collect_warnings(template, self.warnings)
        self.binds.push(_node_bind("list", source.path, template.render()))
        return self
    }

    // each_of, but only items whose `field` equals `value` (board columns).
    fun each_where(self, source: Signal, template: Node, field: String, value: String) -> Node {
        _collect_warnings(template, self.warnings)
        let dep_keys: List<String> = [_root_key(source.path)]
        self.binds.push(
            NodeBind {
                kind: "list",
                path: source.path,
                arg: template.render(),
                filter_field: field,
                filter_value: value,
                expr: "",
                dep_keys,
            },
        )
        return self
    }

    fun render(self) -> String {
        return _render_node(self)
    }
}

// Browsers ignore ASCII whitespace and control characters inside a scheme, so
// "java\tscript:x" navigates like "javascript:x". Strip them before deciding
// what a URL says. The stripped form is only used to judge; what gets emitted
// is the author's original value.
fun _strip_url_noise(value: String) -> String {
    let out = ""
    let i = 0
    while i < value.length() {
        let b = value.byte_at(i)
        if b > 32 && b != 127 {
            out = out.concat(value.substring(i, i + 1))
        }
        i += 1
    }
    return out.to_lower()
}

// True when the value begins with a URL scheme (^[a-z][a-z0-9+-.]*:). A path
// like "a/b:c" is not a scheme, because the slash ends the run first.
fun _has_scheme(value: String) -> Bool {
    if value.length() == 0 || !_ascii_letter(value.byte_at(0)) {
        return false
    }
    let i = 1
    while i < value.length() {
        let b = value.byte_at(i)
        if b == 58 {
            return true
        }
        let scheme_char = _ascii_letter(b) || (b >= 48 && b <= 57) || b == 43 || b == 45 || b == 46
        if !scheme_char {
            return false
        }
        i += 1
    }
    return false
}

// A URL is safe when it names a scheme we allow, or names no scheme at all (it
// is then relative, and cannot navigate anywhere the page could not already).
// Judging by scheme rather than by a prefix allowlist means an ordinary
// relative path like "rows.json" works, while javascript:, vbscript:, and
// data: stay rejected however they are spelled.
fun _safe_url(url: String) -> Bool {
    let cleaned = _strip_url_noise(url)
    if cleaned.length() == 0 {
        return false
    }
    if !_has_scheme(cleaned) {
        return true
    }
    return cleaned.starts_with("http://") || cleaned.starts_with("https://") || cleaned.starts_with(
        "mailto:",
    ) || cleaned.starts_with("tel:")
}

fun _render_attrs(attrs: List<Attribute>) -> String {
    let out = ""
    let q = _quote()
    for attr in attrs {
        out = out.concat(" ").concat(attr.name).concat("=").concat(q)
        out = out.concat(_escape_html(attr.value)).concat(q)
    }
    return out
}

fun _render_node(node: Node) -> String {
    if node.dropped {
        return ""
    }
    if node.tag == "" {
        if node.value != "" {
            return _escape_html(node.value)
        }
        let fragment_out = ""
        for kid in node.kids {
            fragment_out = fragment_out.concat(_render_node(kid))
        }
        return fragment_out
    }
    let out = "<".concat(node.tag).concat(_render_attrs(node.attrs)).concat(">")
    if _void_tag(node.tag) {
        return out
    }
    for kid in node.kids {
        out = out.concat(_render_node(kid))
    }
    return out.concat("</").concat(node.tag).concat(">")
}

trait Component {
    fun to_node(self) -> Node
}

impl Component for Node {
    fun to_node(self) -> Node {
        return self
    }
}

struct CssDeclaration {
    property: String,
    value: String,
}

struct CssRule {
    selector: String,
    declarations: List<CssDeclaration>,
    // Dropped inputs, merged into the Stylesheet this rule is added to.
    warnings: List<String>,
}

struct Stylesheet {
    rules: List<CssRule>,
    raw_blocks: List<String>,
    // Dropped inputs, collected by Page.warnings() through with_styles.
    warnings: List<String>,
}

// Append the classes of `extra` that `current` does not already carry, so
// repeated class_name calls compose instead of colliding.
fun _merge_classes(current: String, extra: String) -> String {
    let out = current.trim()
    for token in extra.split(" ") {
        let clean = token.trim()
        if clean.length() > 0 && !_has_class(out, clean) {
            if out.length() == 0 {
                out = clean
            } else {
                out = out.concat(" ").concat(clean)
            }
        }
    }
    return out
}

// Whole-token membership: "btn" must not match inside "btn-primary".
fun _has_class(list: String, token: String) -> Bool {
    for existing in list.split(" ") {
        if existing == token {
            return true
        }
    }
    return false
}

fun _css_safe_text(value: String) -> Bool {
    let lower = value.to_lower()
    if value.contains("{") || value.contains("}") || value.contains("<") || value.contains(">") || value.contains(
        ";",
    ) {
        return false
    }
    if value.contains("/*") || value.contains("*/") {
        return false
    }
    if lower.contains("javascript:") || lower.contains("expression(") {
        return false
    }
    return value.length() > 0
}

fun _valid_css_property(property: String) -> Bool {
    if property.length() == 0 {
        return false
    }
    let i = 0
    if property.starts_with("--") {
        i = 2
    }
    if i == property.length() {
        return false
    }
    while i < property.length() {
        let b = property.byte_at(i)
        if !_ascii_letter(b) && !(b >= 48 && b <= 57) && b != 45 {
            return false
        }
        i += 1
    }
    return true
}

impl CssRule {
    // Infallible: an invalid selector yields a rule with an empty selector that
    // renders nothing and is skipped by Stylesheet. Use try_new to detect it.
    fun new(selector: String) -> CssRule {
        let declarations: List<CssDeclaration> = []
        if !_css_safe_text(selector) {
            let warnings: List<String> = [
                "dropped CSS rule: invalid selector ".concat(_quote_word(selector)),
            ]
            return CssRule { selector: "", declarations, warnings }
        }
        let warnings: List<String> = []
        return CssRule { selector, declarations, warnings }
    }

    fun try_new(selector: String) -> Result<CssRule, String> {
        if !_css_safe_text(selector) {
            return Err("invalid CSS selector")
        }
        let declarations: List<CssDeclaration> = []
        let warnings: List<String> = []
        return Ok(CssRule { selector, declarations, warnings })
    }

    fun class_name(name: String) -> CssRule {
        return CssRule.new(".".concat(name))
    }

    fun try_class_name(name: String) -> Result<CssRule, String> {
        return CssRule.try_new(".".concat(name))
    }

    fun id(name: String) -> CssRule {
        return CssRule.new("#".concat(name))
    }

    fun try_id(name: String) -> Result<CssRule, String> {
        return CssRule.try_new("#".concat(name))
    }

    fun set(self, property: String, value: String) -> CssRule {
        if !_valid_css_property(property) {
            self.warnings.push("dropped CSS declaration: invalid property ".concat(_quote_word(property)))
            return self
        }
        if !_css_safe_text(value) {
            self.warnings.push(
                "dropped CSS declaration ".concat(_quote_word(property)).concat(": invalid value ").concat(
                    _quote_word(value),
                ),
            )
            return self
        }
        self.declarations.push(CssDeclaration { property, value })
        return self
    }

    fun try_set(self, property: String, value: String) -> Result<CssRule, String> {
        if !_valid_css_property(property) {
            return Err("invalid CSS property")
        }
        if !_css_safe_text(value) {
            return Err("invalid CSS value")
        }
        self.declarations.push(CssDeclaration { property, value })
        return Ok(self)
    }

    fun render(self) -> String {
        if self.selector == "" {
            return ""
        }
        let out = self.selector.concat(" {")
        for declaration in self.declarations {
            out = out.concat(" ").concat(declaration.property).concat(": ").concat(declaration.value).concat(
                ";",
            )
        }
        return out.concat(" }")
    }
}

impl Stylesheet {
    fun new() -> Stylesheet {
        let rules: List<CssRule> = []
        let raw_blocks: List<String> = []
        let warnings: List<String> = []
        return Stylesheet { rules, raw_blocks, warnings }
    }

    fun add(self, rule: CssRule) -> Stylesheet {
        self.rules.push(rule)
        return self
    }

    // Every dropped input in the sheet and its rules. Read at collection time,
    // so a declaration dropped after add() is still seen.
    fun all_warnings(self) -> List<String> {
        let out: List<String> = []
        for warning in self.warnings {
            out.push(warning)
        }
        for rule in self.rules {
            for warning in rule.warnings {
                out.push(warning)
            }
        }
        return out
    }

    // Raw CSS is an explicit build-time escape hatch for authored CSS.
    fun raw(self, css: String) -> Stylesheet {
        self.raw_blocks.push(css)
        return self
    }

    fun render(self) -> String {
        let out = ""
        for rule in self.rules {
            let rendered = rule.render()
            if rendered != "" {
                out = out.concat(rendered).concat("\n")
            }
        }
        for raw in self.raw_blocks {
            out = out.concat(raw)
            if !raw.ends_with("\n") {
                out = out.concat("\n")
            }
        }
        return out
    }
}

struct StaticFile {
    path: String,
    contents: String,
}

fun _valid_static_path(path: String) -> Bool {
    let clean = path.trim()
    if clean.length() == 0 || clean.starts_with("/") {
        return false
    }
    let parts = clean.split("/")
    for part in parts {
        if part.length() == 0 || part == "." || part == ".." {
            return false
        }
        let i = 0
        while i < part.length() {
            let b = part.byte_at(i)
            if b < 32 || b == 34 || b == 58 || b == 60 || b == 62 || b == 92 {
                return false
            }
            i += 1
        }
    }
    let lower = clean.to_lower()
    return lower != "index.html" && lower != "styles.css" && lower != "app.js"
}

fun _valid_css_file_path(path: String) -> Bool {
    return _valid_static_path(path) && path.to_lower().ends_with(".css")
}

fun _asset_href(path: String) -> String {
    return "./".concat(path)
}

impl StaticFile {
    // Infallible: an invalid path yields a file with an empty path, which Page
    // and write_static skip. Use try_new to detect an invalid path.
    fun new(path: String, contents: String) -> StaticFile {
        let clean = path.trim()
        if !_valid_static_path(clean) {
            return StaticFile { path: "", contents }
        }
        return StaticFile { path: clean, contents }
    }

    fun try_new(path: String, contents: String) -> Result<StaticFile, String> {
        let clean = path.trim()
        if !_valid_static_path(clean) {
            return Err("invalid static file path")
        }
        return Ok(StaticFile { path: clean, contents })
    }

    fun css(path: String, contents: String) -> StaticFile {
        let clean = path.trim()
        if !_valid_css_file_path(clean) {
            return StaticFile { path: "", contents }
        }
        return StaticFile { path: clean, contents }
    }

    fun try_css(path: String, contents: String) -> Result<StaticFile, String> {
        let clean = path.trim()
        if !_valid_css_file_path(clean) {
            return Err("CSS file paths must be safe relative .css paths")
        }
        return Ok(StaticFile { path: clean, contents })
    }
}

// One field of a JSON request body. When `selector` is set the value is read
// from that input at send time; otherwise the constant `literal` is sent.
struct BodyField {
    name: String,
    selector: String,
    literal: String,
}

// A typed HTTP request. The author never writes fetch code: raven-web emits it.
// `auth_state` names a state key whose value is sent as a Bearer token.
// `into_state` names a state key to receive the decoded JSON response.
struct FetchSpec {
    method: String,
    url: String,
    body_fields: List<BodyField>,
    auth_state: String,
    into_state: String,
    then: List<Effect>,
    on_error: List<Effect>,
    // Dropped inputs, merged into the Behavior that sends this request.
    warnings: List<String>,
}

enum Effect {
    SetText(String, String),
    SetValue(String, String),
    SetAttribute(String, String, String),
    AddClass(String, String),
    RemoveClass(String, String),
    ToggleClass(String, String),
    Focus(String),
    Show(String),
    Hide(String),
    ToggleVisible(String),
    Navigate(String),
    Go(String),
    ScrollTo(String),
    CopyValue(String, String),
    CopyToClipboard(String),
    SetState(String, String),
    ToggleState(String),
    IncrementState(String, Int),
    Fetch(FetchSpec),
    ClearState(String),
    OpenDialog(String),
    CloseDialog(String),
}

// A composable, typed sequence of DOM effects. Attached to an element event via
// Node.on. raven-web serializes it into the element and interprets it in the
// generated runtime, so the author never writes JavaScript.
struct Behavior {
    effects: List<Effect>,
    prevent: Bool,
    // Debounce window in milliseconds; 0 runs immediately. For events that
    // fire in bursts (typing in a search field).
    wait: Int,
    // A key name filter for keyboard events; empty matches any key. Set via
    // Node.on_key.
    key: String,
    // One line per effect this behavior dropped. Node.on merges them into the
    // element, so Page.warnings() sees them.
    warnings: List<String>,
}

fun _warn_effect(warnings: List<String>, method: String, reason: String, value: String) {
    warnings.push(
        "dropped ".concat(method).concat(": ").concat(reason).concat(" ").concat(_quote_word(value)),
    )
}

fun _valid_class_token(value: String) -> Bool {
    if value.length() == 0 {
        return false
    }
    let i = 0
    while i < value.length() {
        let b = value.byte_at(i)
        if b == 32 || b == 9 || b == 10 || b == 13 {
            return false
        }
        i += 1
    }
    return _css_safe_text(value)
}

// Build a typed request: request("POST", "/login").field("email", "#email")
//     .store("auth").on_ok(Behavior.new().hide("#login"))
fun request(method: String, url: String) -> FetchSpec {
    let body_fields: List<BodyField> = []
    let then: List<Effect> = []
    let on_error: List<Effect> = []
    let warnings: List<String> = []
    return FetchSpec {
        method: method.to_upper(),
        url,
        body_fields,
        auth_state: "",
        into_state: "",
        then,
        on_error,
        warnings,
    }
}

impl FetchSpec {
    // Read `selector`'s value at send time and send it as JSON field `name`.
    fun field(self, name: String, selector: String) -> FetchSpec {
        if _css_safe_text(selector) {
            self.body_fields.push(BodyField { name, selector, literal: "" })
        } else {
            _warn_effect(self.warnings, "fetch field", "invalid selector", selector)
        }
        return self
    }

    // Send a constant JSON field, for a request whose value is not user input.
    fun value(self, name: String, literal: String) -> FetchSpec {
        self.body_fields.push(BodyField { name, selector: "", literal })
        return self
    }

    // Send state[key] as an Authorization: Bearer header.
    fun auth(self, state_key: String) -> FetchSpec {
        if _css_safe_text(state_key) {
            self.auth_state = state_key
        } else {
            _warn_effect(self.warnings, "fetch auth", "invalid state key", state_key)
        }
        return self
    }

    // Store the decoded JSON response in state[key], where bindings can read it.
    fun store(self, state_key: String) -> FetchSpec {
        if _css_safe_text(state_key) {
            self.into_state = state_key
        } else {
            _warn_effect(self.warnings, "fetch store", "invalid state key", state_key)
        }
        return self
    }

    // Typed variants: pass the Signal handle instead of a state string.
    fun store_in(self, target: Signal) -> FetchSpec {
        return self.store(target.key)
    }

    // Send the value at `source` as the Bearer token, for example
    // auth.at("token").
    fun auth_with(self, source: Signal) -> FetchSpec {
        return self.auth(source.path)
    }

    fun on_ok(self, behavior: Behavior) -> FetchSpec {
        for warning in behavior.warnings {
            self.warnings.push(warning)
        }
        for effect in behavior.effects {
            self.then.push(effect)
        }
        return self
    }

    fun on_error(self, behavior: Behavior) -> FetchSpec {
        for warning in behavior.warnings {
            self.warnings.push(warning)
        }
        for effect in behavior.effects {
            self.on_error.push(effect)
        }
        return self
    }
}

fun behavior() -> Behavior {
    let effects: List<Effect> = []
    let warnings: List<String> = []
    return Behavior { effects, prevent: false, wait: 0, key: "", warnings }
}

impl Behavior {
    fun new() -> Behavior {
        return behavior()
    }

    // Suppress the browser default for the event (form submit, link follow).
    fun prevent_default(self) -> Behavior {
        self.prevent = true
        return self
    }

    // Run only after the event has been quiet for `ms` milliseconds, so a
    // search field fires once per pause instead of once per keystroke.
    fun debounce(self, ms: Int) -> Behavior {
        if ms > 0 {
            self.wait = ms
        } else {
            _warn_effect(self.warnings, "debounce", "milliseconds must be positive", ms.to_string())
        }
        return self
    }

    // Open a dialog element as a modal: the browser supplies the focus trap,
    // Escape-to-close, and the backdrop. Falls back to the open attribute
    // where showModal is missing.
    fun open_dialog(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.OpenDialog(selector))
        } else {
            _warn_effect(self.warnings, "open_dialog", "invalid selector", selector)
        }
        return self
    }

    fun close_dialog(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.CloseDialog(selector))
        } else {
            _warn_effect(self.warnings, "close_dialog", "invalid selector", selector)
        }
        return self
    }

    fun set_text(self, selector: String, value: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.SetText(selector, value))
        } else {
            _warn_effect(self.warnings, "set_text", "invalid selector", selector)
        }
        return self
    }

    fun set_value(self, selector: String, value: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.SetValue(selector, value))
        } else {
            _warn_effect(self.warnings, "set_value", "invalid selector", selector)
        }
        return self
    }

    fun set_attribute(self, selector: String, name: String, value: String) -> Behavior {
        if !_css_safe_text(selector) {
            _warn_effect(self.warnings, "set_attribute", "invalid selector", selector)
            return self
        }
        if !_valid_attr_name(name) {
            _warn_effect(self.warnings, "set_attribute", "invalid or executable attribute name", name)
            return self
        }
        self.effects.push(Effect.SetAttribute(selector, name, value))
        return self
    }

    fun add_class(self, selector: String, class_name: String) -> Behavior {
        if !_css_safe_text(selector) {
            _warn_effect(self.warnings, "add_class", "invalid selector", selector)
            return self
        }
        if !_valid_class_token(class_name) {
            _warn_effect(self.warnings, "add_class", "invalid class token", class_name)
            return self
        }
        self.effects.push(Effect.AddClass(selector, class_name))
        return self
    }

    fun remove_class(self, selector: String, class_name: String) -> Behavior {
        if !_css_safe_text(selector) {
            _warn_effect(self.warnings, "remove_class", "invalid selector", selector)
            return self
        }
        if !_valid_class_token(class_name) {
            _warn_effect(self.warnings, "remove_class", "invalid class token", class_name)
            return self
        }
        self.effects.push(Effect.RemoveClass(selector, class_name))
        return self
    }

    fun toggle_class(self, selector: String, class_name: String) -> Behavior {
        if !_css_safe_text(selector) {
            _warn_effect(self.warnings, "toggle_class", "invalid selector", selector)
            return self
        }
        if !_valid_class_token(class_name) {
            _warn_effect(self.warnings, "toggle_class", "invalid class token", class_name)
            return self
        }
        self.effects.push(Effect.ToggleClass(selector, class_name))
        return self
    }

    fun focus(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.Focus(selector))
        } else {
            _warn_effect(self.warnings, "focus", "invalid selector", selector)
        }
        return self
    }

    fun show(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.Show(selector))
        } else {
            _warn_effect(self.warnings, "show", "invalid selector", selector)
        }
        return self
    }

    fun hide(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.Hide(selector))
        } else {
            _warn_effect(self.warnings, "hide", "invalid selector", selector)
        }
        return self
    }

    fun toggle_visible(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.ToggleVisible(selector))
        } else {
            _warn_effect(self.warnings, "toggle_visible", "invalid selector", selector)
        }
        return self
    }

    // Navigate to a safe URL (same rules as href/src). javascript: and other
    // unsafe schemes are rejected, so this can never smuggle in script.
    fun navigate(self, url: String) -> Behavior {
        if _safe_url(url) {
            self.effects.push(Effect.Navigate(url))
        } else {
            _warn_effect(self.warnings, "navigate", "unsafe URL", url)
        }
        return self
    }

    // Move to a client route without reloading the document, so state survives
    // the navigation. Use this with Router; `navigate` still does a full load.
    fun go(self, path: String) -> Behavior {
        if _valid_route_pattern(path) {
            self.effects.push(Effect.Go(_normalize_path(path)))
        } else {
            _warn_effect(self.warnings, "go", "invalid route path", path)
        }
        return self
    }

    fun scroll_to(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.ScrollTo(selector))
        } else {
            _warn_effect(self.warnings, "scroll_to", "invalid selector", selector)
        }
        return self
    }

    // Copy the value or text of one element into another.
    fun copy_value(self, from_selector: String, to_selector: String) -> Behavior {
        if !_css_safe_text(from_selector) {
            _warn_effect(self.warnings, "copy_value", "invalid selector", from_selector)
            return self
        }
        if !_css_safe_text(to_selector) {
            _warn_effect(self.warnings, "copy_value", "invalid selector", to_selector)
            return self
        }
        self.effects.push(Effect.CopyValue(from_selector, to_selector))
        return self
    }

    fun copy_to_clipboard(self, selector: String) -> Behavior {
        if _css_safe_text(selector) {
            self.effects.push(Effect.CopyToClipboard(selector))
        } else {
            _warn_effect(self.warnings, "copy_to_clipboard", "invalid selector", selector)
        }
        return self
    }

    // Client state effects. State is a page-level key to value store; bindings
    // (Page.bind_*) reflect it to the DOM, so counters, tabs, and toggles work
    // with no author JavaScript.
    fun set_state(self, key: String, value: String) -> Behavior {
        if _css_safe_text(key) {
            self.effects.push(Effect.SetState(key, value))
        } else {
            _warn_effect(self.warnings, "set_state", "invalid state key", key)
        }
        return self
    }

    fun toggle_state(self, key: String) -> Behavior {
        if _css_safe_text(key) {
            self.effects.push(Effect.ToggleState(key))
        } else {
            _warn_effect(self.warnings, "toggle_state", "invalid state key", key)
        }
        return self
    }

    fun increment_state(self, key: String, by: Int) -> Behavior {
        if _css_safe_text(key) {
            self.effects.push(Effect.IncrementState(key, by))
        } else {
            _warn_effect(self.warnings, "increment_state", "invalid state key", key)
        }
        return self
    }

    fun clear_state(self, key: String) -> Behavior {
        if _css_safe_text(key) {
            self.effects.push(Effect.ClearState(key))
        } else {
            _warn_effect(self.warnings, "clear_state", "invalid state key", key)
        }
        return self
    }

    // Typed state writes. These take the Signal handle rather than a state
    // string, so the name is written once at the declaration and checked by the
    // compiler everywhere else.
    fun set(self, target: Signal, value: String) -> Behavior {
        return self.set_state(target.key, value)
    }

    fun toggle(self, target: Signal) -> Behavior {
        return self.toggle_state(target.key)
    }

    fun increment(self, target: Signal, by: Int) -> Behavior {
        return self.increment_state(target.key, by)
    }

    fun clear(self, target: Signal) -> Behavior {
        return self.clear_state(target.key)
    }

    // Send a typed HTTP request. raven-web generates the fetch, the JSON body
    // from the named inputs, and the Bearer header; the author writes no JS.
    fun fetch(self, spec: FetchSpec) -> Behavior {
        for warning in spec.warnings {
            self.warnings.push(warning)
        }
        if _safe_url(spec.url) || spec.url.starts_with("/") {
            self.effects.push(Effect.Fetch(spec))
        } else {
            _warn_effect(self.warnings, "fetch", "unsafe URL", spec.url)
        }
        return self
    }
}

fun _js_string(value: String) -> String {
    return stringify(JsonValue.Str(value))
}

// Each effect serializes to a compact JSON op array. Every string is JSON
// encoded, so selectors and values can never break out of the data attribute.
fun _op2(code: String, a: String) -> String {
    return "[".concat(_js_string(code)).concat(",").concat(_js_string(a)).concat("]")
}

fun _op3(code: String, a: String, b: String) -> String {
    return "[".concat(_js_string(code)).concat(",").concat(_js_string(a)).concat(",").concat(
        _js_string(b),
    ).concat("]")
}

fun _op4(code: String, a: String, b: String, c: String) -> String {
    return "[".concat(_js_string(code)).concat(",").concat(_js_string(a)).concat(",").concat(
        _js_string(b),
    ).concat(",").concat(_js_string(c)).concat("]")
}

fun _serialize_effects(effects: List<Effect>) -> String {
    let out = "["
    let first = true
    for effect in effects {
        if !first {
            out = out.concat(",")
        }
        out = out.concat(_serialize_effect(effect))
        first = false
    }
    return out.concat("]")
}

// ["fetch",{"m":..,"u":..,"b":[[name,sel]],"a":authKey,"s":storeKey,"t":[..],"e":[..]}]
fun _serialize_fetch(spec: FetchSpec) -> String {
    let out = "[".concat(_js_string("fetch")).concat(",{")
    out = out.concat(_js_string("m")).concat(":").concat(_js_string(spec.method))
    out = out.concat(",").concat(_js_string("u")).concat(":").concat(_js_string(spec.url))
    out = out.concat(",").concat(_js_string("b")).concat(":[")
    let first = true
    for field in spec.body_fields {
        if !first {
            out = out.concat(",")
        }
        out = out.concat("[").concat(_js_string(field.name)).concat(",").concat(
            _js_string(field.selector),
        ).concat(",").concat(_js_string(field.literal)).concat("]")
        first = false
    }
    out = out.concat("]")
    out = out.concat(",").concat(_js_string("a")).concat(":").concat(_js_string(spec.auth_state))
    out = out.concat(",").concat(_js_string("s")).concat(":").concat(_js_string(spec.into_state))
    out = out.concat(",").concat(_js_string("t")).concat(":").concat(_serialize_effects(spec.then))
    out = out.concat(",").concat(_js_string("e")).concat(":").concat(
        _serialize_effects(spec.on_error),
    )
    return out.concat("}]")
}

fun _serialize_effect(effect: Effect) -> String {
    return match effect {
        SetText(selector, value) -> _op3("st", selector, value),
        SetValue(selector, value) -> _op3("sv", selector, value),
        SetAttribute(selector, name, value) -> _op4("sa", selector, name, value),
        AddClass(selector, class_name) -> _op3("ac", selector, class_name),
        RemoveClass(selector, class_name) -> _op3("rc", selector, class_name),
        ToggleClass(selector, class_name) -> _op3("tc", selector, class_name),
        Focus(selector) -> _op2("fo", selector),
        Show(selector) -> _op2("sh", selector),
        Hide(selector) -> _op2("hd", selector),
        ToggleVisible(selector) -> _op2("tv", selector),
        Navigate(url) -> _op2("nav", url),
        Go(path) -> _op2("go", path),
        ScrollTo(selector) -> _op2("scr", selector),
        CopyValue(from_selector, to_selector) -> _op3("cv", from_selector, to_selector),
        CopyToClipboard(selector) -> _op2("cc", selector),
        SetState(key, value) -> _op3("ss", key, value),
        ToggleState(key) -> _op2("ts", key),
        IncrementState(key, by) -> _op3("is", key, by.to_string()),
        ClearState(key) -> _op2("cs", key),
        Fetch(spec) -> _serialize_fetch(spec),
        OpenDialog(selector) -> _op2("dop", selector),
        CloseDialog(selector) -> _op2("dcl", selector),
    }
}

fun _serialize_behavior(behavior: Behavior) -> String {
    let out = "{".concat(_js_string("p")).concat(":")
    if behavior.prevent {
        out = out.concat("1")
    } else {
        out = out.concat("0")
    }
    if behavior.wait > 0 {
        out = out.concat(",").concat(_js_string("w")).concat(":").concat(behavior.wait.to_string())
    }
    if behavior.key != "" {
        out = out.concat(",").concat(_js_string("k")).concat(":").concat(_js_string(behavior.key))
    }
    out = out.concat(",").concat(_js_string("e")).concat(":[")
    let first = true
    for effect in behavior.effects {
        if !first {
            out = out.concat(",")
        }
        out = out.concat(_serialize_effect(effect))
        first = false
    }
    return out.concat("]}")
}

// The fixed client runtime. It is generated once, contains no author input, and
// only interprets the serialized behavior data attributes. Written with single
// quoted JS strings so the Raven string literal needs no escaping.
// The generated runtime. The dependency graph is resolved at build time, so a
// state write updates only the bindings that read that key, and a list binding
// reconciles by key and updates rows in place instead of rebuilding the subtree.
fun _render_runtime() -> String {
    let out = "(function(){'use strict';"
    out = out.concat(
        "var rw_init=window.RW_INIT||{};var rw_state=rw_init.s||{};var rw_binds=rw_init.b||[];var rw_keep=rw_init.p||[];var rw_onload=rw_init.l||[];var rw_deps=rw_init.d||{};var rw_base=rw_init.z||'';",
    )
    out = out.concat(
        // raven-web's own marks are unique and live as long as the page, so
        // resolving one is worth caching: without it every binding rescans the
        // whole document on every write it takes part in. An author's selector
        // is not cached, because it may match rows a list rebuilds.
        // Two caches, not one: rw_find stores an element and rw_all stores a
        // node list, so sharing a key would hand back the wrong shape.
        "var rw_c1={},rw_cn={},rw_booted=false,rw_seen=null;function rw_mark(s){return s.indexOf('[data-rw-b=')===0;}",
    )
    out = out.concat(
        "function rw_find(s){if(rw_c1[s]!==undefined){return rw_c1[s];}try{var el=document.querySelector(s);if(rw_mark(s)){rw_c1[s]=el;}return el;}catch(e){console.error('raven-web: bad selector',s);return null;}}",
    )
    out = out.concat(
        "function rw_all(s){if(rw_cn[s]!==undefined){return rw_cn[s];}try{var found=document.querySelectorAll(s);if(rw_mark(s)){rw_cn[s]=found;}return found;}catch(e){console.error('raven-web: bad selector',s);return [];}}",
    )
    // A transition element keeps its box and toggles the rw-hidden class, so
    // author CSS can animate opacity or transform; a plain element flips
    // display. rw_shown reads the current state through the same split.
    out = out.concat(
        "function rw_vis(el,on){if(!el){return;}if(el.getAttribute&&el.getAttribute('data-rw-trans')!==null){if(on){el.classList.remove('rw-hidden');}else{el.classList.add('rw-hidden');}}else{el.style.display=on?'':'none';}}",
    )
