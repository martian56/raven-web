// Dev workflow: cli() wraps the generator in the standard commands.
//
//   raven build examples/dev.rv -o target/dev.exe
//   ./target/dev.exe dev
//
// opens http://localhost:8080 with live reload. Edit this file and save: the
// harness recompiles it, regenerates dist, and the page reloads. Break the
// syntax and save: the compiler error appears in the browser until it is
// fixed.

import std/io { println }
import "../lib" { Behavior, Node, Page }
import "../dev" { cli }

fun build() {
    let page = Page.new(
        "raven-web dev",
        Node.main_node().child(Node.h1().child_text("Live reload")).child(
            Node.button("Toggle note").on_click(Behavior.new().toggle_visible("#note")),
        ).child(Node.p().id("note").child_text("Edit examples/dev.rv and save to see this reload.")),
    )
    match page.write_static("dist") {
        Ok(out) -> println("built ".concat(out.file_count().to_string()).concat(" files")),
        Err(error) -> println(error.to_string()),
    }
}

fun main() {
    cli("examples/dev.rv", "dist").run(
        fun() -> Unit {
            build()
        },
    )
}
